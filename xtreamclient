import java.util.concurrent.TimeUnit

/**
 * Xtream Codes API client.
 *
 * All requests are stateless — no handshake, no token, no MAC address.
 * Every call authenticates via username + password in the query string.
 *
 * Base URL format:  http://server:port
 * API endpoint:     http://server:port/player_api.php?username=X&password=Y&action=...
 * Stream URL:       http://server:port/live/username/password/streamId.m3u8
 */
class XtreamClient(
    private val serverUrl: String,  // e.g. http://pro.server.com:8080
    private val username: String,
    private val password: String
) {
    companion object {
        private const val TAG = "XtreamClient"

        /**
         * Try to parse Xtream credentials from a pasted URL.
         * Handles formats:
         *   http://server/get.php?username=X&password=Y&type=m3u_plus
         *   http://server/player_api.php?username=X&password=Y
         *   http://server/live/username/password/streamid.m3u8
         *
         * Returns Triple(serverUrl, username, password) or null if not Xtream.
         */
        fun parseFromUrl(url: String): Triple<String, String, String>? {
            return try {
                val uri = android.net.Uri.parse(url.trim())
                val u = uri.getQueryParameter("username")
                val p = uri.getQueryParameter("password")
                if (!u.isNullOrBlank() && !p.isNullOrBlank()) {
                    // Reconstruct server URL without path or query
                    val port = if (uri.port != -1) ":${uri.port}" else ""
                    val server = "${uri.scheme}://${uri.host}$port"
                    Triple(server, u, p)
                } else null
            } catch (e: Exception) {
                null
            }
        }
    }

    private val client = OkHttpClient.Builder()
        .connectTimeout(15, TimeUnit.SECONDS)
        .readTimeout(30, TimeUnit.SECONDS)
        .followRedirects(true)
        .build()

    // ── Internal request helper ───────────────────────────────────────────────

    private fun get(action: String, extraParams: String = ""): JSONObject {
        val url = "$serverUrl/player_api.php?username=$username&password=$password&action=$action$extraParams"
        Log.d(TAG, "GET $url")
        val request = Request.Builder()
            .url(url)
            .header("User-Agent", "Mozilla/5.0")
            .build()
        client.newCall(request).execute().use { response ->
            if (!response.isSuccessful) throw IOException("HTTP ${response.code} for $action")
            val body = response.body?.string() ?: throw IOException("Empty response for $action")
            return JSONObject(body)
        }
    }

    private fun getArray(action: String, extraParams: String = ""): JSONArray {
        val url = "$serverUrl/player_api.php?username=$username&password=$password&action=$action$extraParams"
        Log.d(TAG, "GET $url")
        val request = Request.Builder()
            .url(url)
            .header("User-Agent", "Mozilla/5.0")
            .build()
        client.newCall(request).execute().use { response ->
            if (!response.isSuccessful) throw IOException("HTTP ${response.code} for $action")
            val body = response.body ?: throw IOException("Empty response for $action")
            // FIX: OOM on large playlists (50k+ items = 20-50MB JSON).
            // Stream directly from the response body instead of calling body.string()
            // which loads the entire payload into a single String on the heap.
            // JSONArray(reader) is not available in org.json — use a capped read:
            // read up to 16MB safely, warn and truncate beyond that.
            return parseArrayBody(body)
        }
    }

    private fun parseArrayBody(body: ResponseBody): JSONArray {
        // FIX: OOM protection for large Xtream playlists (50k items = 20-50MB JSON).
        // Cap at 16MB — this fits ~30,000 channel entries comfortably.
        // Servers returning more than this are misconfigured; the user should
        // filter by category instead of fetching all streams at once.
        val maxBytes = 8 * 1024 * 1024L   // 8MB — per-category calls are small; full-list calls are blocked upstream
        val source = body.source()
        source.request(maxBytes)
        val actualSize = source.buffer.size
        if (actualSize >= maxBytes) {
            Log.w(TAG, "Response truncated at 16MB (server returned ${actualSize / 1024 / 1024}MB+)")
        }
        val text = source.buffer.readUtf8(minOf(actualSize, maxBytes))

        return try {
            JSONArray(text)
        } catch (e: Exception) {
            try {
                val obj = JSONObject(text)
                obj.optJSONArray("data") ?: JSONArray()
            } catch (e2: Exception) {
                Log.e(TAG, "Failed to parse response: ${e2.message}")
                JSONArray()
            }
        }
    }
    /**
     * Per-category live-TV counts: Map<category_id, channelCount>.
     *
     * Uses the same streaming category_id tally as VOD/Series instead of the old
     * name->id round-trip in PortalReloader, which silently produced 0 live counts
     * when a stream's category_name didn't exactly match a category list entry
     * (whitespace, HTML entities, or a blank name falling back to category_id).
     * Tallying category_id directly off the stream objects sidesteps that entirely.
     */
    fun getLiveCategoryCounts(): Map<String, Int> = streamCategoryTally("get_live_streams")
    // ── Account info ──────────────────────────────────────────────────────────

    /**
     * Fetch account info to verify credentials are valid.
     * Returns true if the server accepts the credentials.
     */
    sealed class CredentialsResult {
        /** Server confirmed credentials are valid and the account is usable. */
        object Valid : CredentialsResult()
        /** Server explicitly said credentials are wrong (auth=0 etc.). */
        object Invalid : CredentialsResult()
        /** Account exists but isn't usable: expired, banned, disabled, etc. */
        data class AccountIssue(val status: String) : CredentialsResult()
        /** Could not reach server or parse its response (network/server problem). */
        data class Unreachable(val reason: String) : CredentialsResult()
    }

    /**
     * Verify Xtream credentials by hitting player_api.php with no action,
     * which returns the account_info payload on every Xtream-compatible
     * server we've seen.
     *
     * Distinguishes four outcomes so callers can show meaningful errors
     * rather than the catch-all "invalid credentials" that triggers
     * false-positive complaints whenever the network is flaky.
     */
    fun verifyCredentialsDetailed(): CredentialsResult {
        val obj: JSONObject = try {
            get("")
        } catch (e: IOException) {
            // Network-level failure (timeout, connection refused, DNS).
            // NOT a credential problem — don't blame the user.
            Log.w(TAG, "verifyCredentials: unreachable: ${e.message}")
            return CredentialsResult.Unreachable(e.message ?: "network error")
        } catch (e: Exception) {
            // JSON parse failures, SSL issues, anything else.
            Log.w(TAG, "verifyCredentials: parse/other: ${e.message}")
            return CredentialsResult.Unreachable(e.message ?: "server error")
        }

        val userInfo = obj.optJSONObject("user_info")
        if (userInfo == null) {
            // No user_info object at all — server returned something but not
            // what Xtream servers return. Could be an HTML error page wrapped
            // in JSON, a generic error response, or a non-Xtream server at
            // the URL. Treat as Invalid only if there's also no server_info
            // (some servers omit user_info when auth fails entirely).
            return if (obj.has("server_info")) {
                CredentialsResult.Valid  // permissive: server responded, no user_info field
            } else {
                CredentialsResult.Invalid
            }
        }

        // Xtream's "auth" field is 1 on success, 0 on failure. Some servers
        // return it as int, some as string. Handle both.
        val auth = when (val v = userInfo.opt("auth")) {
            is Int -> v
            is String -> v.toIntOrNull() ?: 1
            else -> 1   // missing → assume valid (older servers don't send it)
        }
        if (auth == 0) return CredentialsResult.Invalid

        // Status field — many Xtream forks expose subscription state here.
        // Common values: "Active", "Expired", "Banned", "Disabled", "Trial".
        // Active and Trial are usable; anything else is an account issue.
        val status = userInfo.optString("status").trim()
        if (status.isNotBlank()) {
            val normalised = status.lowercase()
            val usable = normalised == "active" || normalised == "trial"
            if (!usable) {
                return CredentialsResult.AccountIssue(status)
            }
        }

        return CredentialsResult.Valid
    }

    // Keep the old boolean method as a thin wrapper so existing callers
// continue to compile. Only PortalReloader needs the detailed version.
    fun verifyCredentials(): Boolean = verifyCredentialsDetailed() is CredentialsResult.Valid

    // ── Live TV ───────────────────────────────────────────────────────────────

    fun getLiveCategories(): List<VodCategory> {
        return try {
            val arr = getArray("get_live_categories")
            (0 until arr.length()).map { i ->
                val o = arr.getJSONObject(i)
                VodCategory(
                    id    = o.optString("category_id"),
                    title = o.optString("category_name")
                )
            }.filter { it.id.isNotBlank() }.distinctBy { it.id }
        } catch (e: Exception) {
            Log.e(TAG, "getLiveCategories failed: ${e.message}")
            emptyList()
        }
    }

    fun getLiveStreams(categoryId: String = ""): List<Channel> {
        return try {
            val params = if (categoryId.isNotBlank() && categoryId != "*")
                "&category_id=$categoryId" else ""
            val arr = getArray("get_live_streams", params)
            (0 until arr.length()).map { i ->
                val o = arr.getJSONObject(i)
                val streamId = o.optString("stream_id")
                Channel(
                    id       = streamId,
                    epgId    = o.optString("epg_channel_id").ifBlank { streamId },
                    name     = o.optString("name"),
                    category = o.optString("category_name").ifBlank {
                        o.optString("category_id")
                    },
                    cmd      = buildStreamUrl(streamId),
                    logo     = o.optString("stream_icon").ifBlank { null }
                )
            }.filter { it.id.isNotBlank() }.distinctBy { it.id }
        } catch (e: Exception) {
            Log.e(TAG, "getLiveStreams failed: ${e.message}")
            emptyList()
        }
    }

