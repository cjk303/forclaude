    /**
     * Full series detail — returns seasons and episodes in one call.
     * This is the richest data source in the Xtream API.
     */
    fun getSeriesInfo(seriesId: String): XtreamSeriesInfo? {
        return try {
            val obj = get("get_series_info", "&series_id=$seriesId")
            Log.d(TAG, "getSeriesInfo raw keys: ${obj.keys().asSequence().toList()}")
            Log.d(TAG, "seasons type: ${obj.opt("seasons")?.javaClass?.simpleName}, episodes type: ${obj.opt("episodes")?.javaClass?.simpleName}")
            val info = obj.optJSONObject("info") ?: return null

            val seasons = mutableListOf<XtreamSeason>()

            // "seasons" can be a JSON object (keys = season numbers) OR a JSON array
            // on different server implementations. Handle both.
            val seasonsRaw = obj.opt("seasons")
            when (seasonsRaw) {
                is org.json.JSONObject -> seasonsRaw.keys().forEach { key ->
                    val s = seasonsRaw.optJSONObject(key) ?: return@forEach
                    seasons.add(XtreamSeason(
                        seasonNumber = s.optInt("season_number", key.toIntOrNull() ?: 0),
                        name         = s.optString("name").ifBlank { "Season $key" },
                        cover        = s.optString("cover").ifBlank { null },
                        episodeCount = s.optInt("episode_count", 0)
                    ))
                }
                is org.json.JSONArray -> {
                    for (i in 0 until seasonsRaw.length()) {
                        val s = seasonsRaw.optJSONObject(i) ?: continue
                        val num = s.optInt("season_number", i + 1)
                        seasons.add(XtreamSeason(
                            seasonNumber = num,
                            name         = s.optString("name").ifBlank { "Season $num" },
                            cover        = s.optString("cover").ifBlank { null },
                            episodeCount = s.optInt("episode_count", 0)
                        ))
                    }
                }
            }

            val episodes = mutableListOf<XtreamEpisode>()
            val episodesObj = obj.optJSONObject("episodes")
            episodesObj?.keys()?.forEach { seasonKey ->
                val arr = episodesObj.optJSONArray(seasonKey) ?: return@forEach
                for (i in 0 until arr.length()) {
                    val e = arr.getJSONObject(i)
                    val epInfo = e.optJSONObject("info")
                    val ext = e.optString("container_extension").ifBlank { "mp4" }
                    val epId = e.optString("id")
                    episodes.add(XtreamEpisode(
                        id           = epId,
                        title        = e.optString("title").ifBlank { "Episode ${e.optInt("episode_num")}" },
                        seasonNum    = seasonKey.toIntOrNull() ?: 0,
                        episodeNum   = e.optInt("episode_num"),
                        plot         = epInfo?.optString("plot").orEmpty(),
                        duration     = epInfo?.optString("duration").orEmpty(),
                        releaseDate  = epInfo?.optString("releasedate").orEmpty(),
                        rating       = epInfo?.optString("rating").orEmpty(),
                        still        = epInfo?.optString("movie_image").ifNullOrBlank { null },
                        streamUrl    = buildSeriesUrl(epId, ext)
                    ))
                }
            }

            // Fallback: if server returned no seasons block, derive seasons
            // from episode season keys — common on some Xtream panel builds
            if (seasons.isEmpty() && episodes.isNotEmpty()) {
                episodes.map { it.seasonNum }.distinct().sorted().forEach { num ->
                    seasons.add(XtreamSeason(
                        seasonNumber = num,
                        name         = "Season $num",
                        cover        = null,
                        episodeCount = episodes.count { it.seasonNum == num }
                    ))
                }
                Log.d(TAG, "Derived ${seasons.size} seasons from episode keys")
            }

            XtreamSeriesInfo(
                seriesId    = seriesId,
                name        = info.optString("name"),
                cover       = info.optString("cover").ifBlank { null },
                plot        = info.optString("plot").ifBlank { "" },
                cast        = info.optString("cast").ifBlank { "" },
                genre       = info.optString("genre").ifBlank { "" },
                releaseDate = info.optString("releaseDate").ifBlank { "" },
                rating      = info.optString("rating").ifBlank { "" },
                seasons     = seasons.sortedBy { it.seasonNumber },
                episodes    = episodes.sortedWith(compareBy({ it.seasonNum }, { it.episodeNum }))
            )
        } catch (e: Exception) {
            Log.e(TAG, "getSeriesInfo failed for $seriesId: ${e.message}")
            null
        }
    }

    // ── EPG ───────────────────────────────────────────────────────────────────

    /**
     * Fetch short EPG (current + next programme) for a stream.
     * Returns empty list on failure — EPG is best-effort.
     */
    fun getShortEpg(streamId: String, limit: Int = 2): List<com.kam.magplayer.epg.StalkerEpgEvent> {
        return try {
            val obj = get("get_short_epg", "&stream_id=$streamId&limit=$limit")
            val arr = obj.optJSONArray("epg_listings") ?: return emptyList()
            (0 until arr.length()).mapNotNull { i ->
                val e = arr.getJSONObject(i)
                val start = e.optLong("start_timestamp")
                val end = e.optLong("stop_timestamp")
                if (start == 0L || end == 0L) return@mapNotNull null
                com.kam.magplayer.epg.StalkerEpgEvent(
                    title       = decodeBase64Title(e.optString("title")),
                    description = decodeBase64Title(e.optString("description")),
                    start       = start,
                    end         = end
                )
            }
        } catch (e: Exception) {
            Log.w(TAG, "getShortEpg failed for $streamId: ${e.message}")
            emptyList()
        }
    }

// -- Per-category counts (streaming) ---------------------------------------

    /**
     * Per-category VOD counts: Map<category_id, itemCount>.
     *
     * Streams get_vod_streams with android.util.JsonReader and tallies
     * category_id without ever holding the full list in memory. The full VOD
     * payload can be 20MB+/50k+ items on real providers, which is why this
     * does NOT go through getArray()/parseArrayBody() (those cap+truncate at
     * 8MB and build a full JSON tree). Counts equal what the per-category
     * browse screen shows because the server filters on the same category_id.
     *
     * Returns an empty map on any failure (including OutOfMemoryError) -- a
     * missing count just means no badge, never a crash.
     */
    fun getVodCategoryCounts(): Map<String, Int> = streamCategoryTally("get_vod_streams")

    /**
     * Per-category Series counts: Map<category_id, showCount>.
     * Counts are show-counts (not episode-counts), matching the series browse
     * list. Same streaming + OOM-survivable approach as getVodCategoryCounts().
     */
    fun getSeriesCategoryCounts(): Map<String, Int> = streamCategoryTally("get_series")

    /**
     * Streams a get_..._streams response and tallies the "category_id" field of
     * every object into a Map<categoryId, count>.
     *
     * Memory profile: holds one JSON object's worth of tokens at a time plus
     * the result map (a few dozen entries). The multi-megabyte body is consumed
     * incrementally off the socket; it is never materialised as a String or a
     * JSONArray.
     *
     * Tolerates two top-level shapes seen in the wild:
     *   [ {..}, {..}, ... ]              (bare array -- the common case)
     *   { "data": [ {..}, {..}, ... ] }  (wrapped -- some panel builds)
     *
     * category_id values that are null/blank (the occasional orphan item) are
     * skipped, so we never invent a phantom category.
     *
     * catch (Throwable): an OutOfMemoryError on a pathological provider yields
     * the partial tally gathered so far (or empty), never a crash -- same
     * defensive posture as PortalReloader's bulk-count blocks.
     */
    private fun streamCategoryTally(action: String): Map<String, Int> {
        val url = "$serverUrl/player_api.php?username=$username&password=$password&action=$action"
        Log.d(TAG, "GET (stream tally) $url")
        val counts = HashMap<String, Int>()
        val request = Request.Builder()
            .url(url)
            .header("User-Agent", "Mozilla/5.0")
            .build()
        try {
            client.newCall(request).execute().use { response ->
                if (!response.isSuccessful) {
                    Log.w(TAG, "streamCategoryTally: HTTP ${response.code} for $action")
                    return counts
                }
                val body = response.body ?: run {
                    Log.w(TAG, "streamCategoryTally: empty body for $action")
                    return counts
                }
                // charStream() reads straight off the socket -- no full-payload
                // String allocation. JsonReader pulls tokens incrementally.
                JsonReader(body.charStream()).use { reader ->
                    readTopLevel(reader, counts)
                }
            }
        } catch (t: Throwable) {
            // Includes OutOfMemoryError. Return whatever we gathered; a partial
            // or empty map degrades to "no badge", which is acceptable.
            Log.w(TAG, "streamCategoryTally($action) aborted: ${t.javaClass.simpleName} ${t.message}")
        }
        Log.d(TAG, "streamCategoryTally($action): ${counts.size} categories tallied")
        return counts
    }

    /**
     * Dispatches on the top-level token: either a bare array of items, or an
     * object that (somewhere) contains a "data" array of items. Anything else
     * is skipped.
     */
    private fun readTopLevel(reader: JsonReader, counts: HashMap<String, Int>) {
        when (reader.peek()) {
            JsonToken.BEGIN_ARRAY -> readItemArray(reader, counts)
            JsonToken.BEGIN_OBJECT -> {
                reader.beginObject()
                while (reader.hasNext()) {
                    val key = reader.nextName()
                    if (key == "data" && reader.peek() == JsonToken.BEGIN_ARRAY) {
                        readItemArray(reader, counts)
                    } else {
                        reader.skipValue()
                    }
                }
                reader.endObject()
            }
            else -> reader.skipValue()
        }
    }

    /** Walks an array of stream/series objects, tallying category_id on each. */
    private fun readItemArray(reader: JsonReader, counts: HashMap<String, Int>) {
        reader.beginArray()
        while (reader.hasNext()) {
            // Per object: read only category_id, skip everything else.
            var categoryId: String? = null
            if (reader.peek() == JsonToken.BEGIN_OBJECT) {
                reader.beginObject()
                while (reader.hasNext()) {
                    if (reader.nextName() == "category_id") {
                        categoryId = nextStringOrNull(reader)
                    } else {
                        reader.skipValue()
                    }
                }
                reader.endObject()
            } else {
                reader.skipValue()
            }
            val cid = categoryId?.trim()
            if (!cid.isNullOrBlank() && cid != "null") {
                counts[cid] = (counts[cid] ?: 0) + 1
            }
        }
        reader.endArray()
    }

    /**
     * Reads the current value as a String regardless of whether the server
     * encodes category_id as a JSON string ("63") or a number (63). Returns
     * null for JSON null. Never throws on type -- defends against mixed-type
     * panels.
     */
    private fun nextStringOrNull(reader: JsonReader): String? {
        return when (reader.peek()) {
            JsonToken.NULL -> { reader.nextNull(); null }
            JsonToken.NUMBER, JsonToken.STRING -> reader.nextString()
            else -> { reader.skipValue(); null }
        }
    }

// -- URL builders ----------------------------------------------------------

    fun buildStreamUrl(streamId: String, ext: String = "m3u8") =
        "$serverUrl/live/$username/$password/$streamId.$ext"

    fun buildVodUrl(streamId: String, ext: String = "mp4") =
        "$serverUrl/movie/$username/$password/$streamId.$ext"

    fun buildSeriesUrl(episodeId: String, ext: String = "mp4") =
        "$serverUrl/series/$username/$password/$episodeId.$ext"

    // ── Helpers ───────────────────────────────────────────────────────────────

    private fun decodeBase64Title(encoded: String): String {
        return try {
            String(android.util.Base64.decode(encoded, android.util.Base64.DEFAULT))
        } catch (e: Exception) {
            encoded  // Already plain text on some servers
        }
    }

    private fun String?.ifNullOrBlank(default: () -> String?): String? =
        if (isNullOrBlank()) default() else this
}

// ── Data models for Xtream series ────────────────────────────────────────────

data class XtreamSeriesInfo(
    val seriesId: String,
    val name: String,
    val cover: String?,
    val plot: String,
    val cast: String,
    val genre: String,
    val releaseDate: String,
    val rating: String,
    val seasons: List<XtreamSeason>,
    val episodes: List<XtreamEpisode>
)

data class XtreamSeason(
