/**
 * Returns the list of categories for a portal + content type, populating the
 * PortalCache as a side effect. The cache's mutable lists are the source of
 * truth -- this function just reads them, refreshing from the network if empty.
 */
private suspend fun loadCategoriesFor(
    portal: Portal,
    contentType: ContentType,
    viewModel: TvHomeViewModel,
    context: Context
): List<CategoryItem> = withContext(Dispatchers.IO) {
    val cache = PortalCache.get(portal.id)

    when (contentType) {
        ContentType.IPTV -> {
            if (cache.genres.isEmpty()) {
                val genres = when {
                    portal.isM3U -> {
                        M3uCache.loadMeta(context, portal.effectiveUrl)?.genres ?: emptyList()
                    }
                    portal.isXtream -> {
                        XtreamClient(portal.effectiveUrl, portal.username, portal.password)
                            .getLiveCategories()
                            .map { StalkerGenre(it.id, it.title, "") }
                    }
                    else -> {
                        val sc = viewModel.getStalkerClient(portal.effectiveUrl, portal.macAddress)
                        StalkerSession.client = sc
                        sc.getGenres()
                    }
                }
                if (genres.isNotEmpty()) {
                    cache.genres.clear(); cache.genres.addAll(genres)
                    CategoryStore.saveGenres(context, portal.id, genres)   // <-- ADD
                }
            }
            cache.genres.map { CategoryItem(it.id, it.title, false) }
        }

        ContentType.VOD -> {
            if (cache.vodCategories.isEmpty()) {
                val cats = when {
                    portal.isM3U -> M3uCache.loadMeta(context, portal.effectiveUrl)?.vodCategories ?: emptyList()
                    portal.isXtream -> XtreamClient(portal.effectiveUrl, portal.username, portal.password).getVodCategories()
                    else -> viewModel.getVodClient(portal.effectiveUrl, portal.macAddress).getVodCategories()
                }
                if (cats.isNotEmpty()) {
                    cache.vodCategories.clear(); cache.vodCategories.addAll(cats)
                    CategoryStore.saveCategories(context, portal.id, ContentType.VOD, cats)   // <-- ADD
                }
            }
            cache.vodCategories.map { CategoryItem(it.id, it.title, false) }
        }

        ContentType.SERIES -> {
            if (cache.seriesCategories.isEmpty()) {
                val cats = when {
                    portal.isM3U -> M3uCache.loadMeta(context, portal.effectiveUrl)?.seriesCategories ?: emptyList()
                    portal.isXtream -> XtreamClient(portal.effectiveUrl, portal.username, portal.password).getSeriesCategories()
                    else -> viewModel.getVodClient(portal.effectiveUrl, portal.macAddress).getSeriesCategories()
                }
                if (cats.isNotEmpty()) {
                    cache.seriesCategories.clear(); cache.seriesCategories.addAll(cats)
                    CategoryStore.saveCategories(context, portal.id, ContentType.SERIES, cats)   // <-- ADD
                }
            }
            cache.seriesCategories.map { CategoryItem(it.id, it.title, false) }
        }
    }
}

/** Reads whichever cached list matches the content type, without any network. */
private fun cachedCategoriesFor(portal: Portal, contentType: ContentType): List<CategoryItem> {
    val cache = PortalCache.get(portal.id)
    return when (contentType) {
        ContentType.IPTV   -> cache.genres.map { CategoryItem(it.id, it.title, false) }
        ContentType.VOD    -> cache.vodCategories.map { CategoryItem(it.id, it.title, false) }
        ContentType.SERIES -> cache.seriesCategories.map { CategoryItem(it.id, it.title, false) }
    }
}

