private sealed class ListEntry {
    data class Header(val label: String, val accent: Color) : ListEntry()
    data class Item(val category: CategoryItem) : ListEntry()
}

@OptIn(ExperimentalTvMaterial3Api::class)
@Composable
private fun GroupedList(
    categories: List<CategoryItem>,
    contentType: ContentType,
    viewModel: TvHomeViewModel,
    focusRequester: FocusRequester,
    favoriteIds: Set<String>,
    onSelected: (String, String) -> Unit,
    onFavoriteToggle: (CategoryItem) -> Unit,
    onLockClick: (CategoryItem) -> Unit,
    onHideClick: (CategoryItem) -> Unit,
    portalId: String?,
    cacheVersion: Int
) {
    val favLabel = stringResource(R.string.category_favorites)
    val otherLabel = stringResource(R.string.category_other)
    
    val flatList = remember(categories, favoriteIds, favLabel, otherLabel) {
        val favs = categories.filter { it.id in favoriteIds }
        val rest = categories.filter { it.id !in favoriteIds }
        val byPrefix = rest.groupBy { name ->
            extractPrefix(name.name).ifEmpty { otherLabel }
        }.toSortedMap()
        buildList {
            if (favs.isNotEmpty()) {
                add(ListEntry.Header(favLabel, Color(0xFFFBBF24)))
                favs.forEach { add(ListEntry.Item(it)) }
            }
            byPrefix.forEach { (prefix, items) ->
                val accent = regionColors[prefix] ?: defaultAccent
                add(ListEntry.Header(prefix, accent))
                items.sortedBy { it.name }.forEach { add(ListEntry.Item(it)) }
            }
        }
    }

    LazyColumn(
        modifier = Modifier.focusRequester(focusRequester),
        contentPadding = PaddingValues(top = 4.dp, bottom = 24.dp),
        verticalArrangement = Arrangement.spacedBy(3.dp)
    ) {
        itemsIndexed(flatList, key = { i, entry ->
            when (entry) {
                is ListEntry.Header -> "h_${i}_${entry.label}"
                is ListEntry.Item -> entry.category.id
            }
        }) { _, entry ->
            when (entry) {
                is ListEntry.Header -> GroupHeader(entry.label, entry.accent)
                is ListEntry.Item -> CompactCategoryRow(
                    item = entry.category.copy(isFavorite = entry.category.id in favoriteIds),
                    contentType = contentType,
                    viewModel = viewModel,
                    portalId = portalId,
                    cacheVersion = cacheVersion,
                    onClick = { onSelected(entry.category.id, entry.category.name) },
                    onFavoriteClick = { onFavoriteToggle(entry.category) },
                    onLockClick = { onLockClick(entry.category) },
                    onHideClick = { onHideClick(entry.category) }
                )
            }
        }
    }
}

@Composable
private fun GroupHeader(label: String, accent: Color) {
    Row(
        modifier = Modifier.fillMaxWidth().padding(top = 14.dp, bottom = 4.dp),
        verticalAlignment = Alignment.CenterVertically
    ) {
        Box(modifier = Modifier.width(3.dp).height(14.dp).background(accent, RoundedCornerShape(2.dp)))
        Spacer(modifier = Modifier.width(8.dp))
        Text(text = label, fontSize = 11.sp, fontWeight = FontWeight.Bold, color = accent, letterSpacing = 1.5.sp)
        Spacer(modifier = Modifier.width(10.dp))
        Box(modifier = Modifier.weight(1f).height(1.dp).background(accent.copy(alpha = 0.2f)))
    }
}

// -----------------------------------------------------------------------------
// Favourite star -- shared between compact + grid
// -----------------------------------------------------------------------------

@OptIn(ExperimentalTvMaterial3Api::class)
@Composable
private fun FavouriteStar(
    isFavourite: Boolean,
    rowFocused: Boolean,
    onFocusChange: (Boolean) -> Unit,
    onClick: () -> Unit,
    cornerEnd: androidx.compose.ui.unit.Dp
) {
    var starFocused by remember { mutableStateOf(false) }
    Surface(
        onClick = onClick,
        modifier = Modifier
            .width(44.dp)
            .fillMaxHeight()
            .onFocusChanged {
                starFocused = it.isFocused
                onFocusChange(it.isFocused)
            },
        shape = ClickableSurfaceDefaults.shape(RoundedCornerShape(topEnd = cornerEnd, bottomEnd = cornerEnd)),
        scale = ClickableSurfaceDefaults.scale(focusedScale = 1.0f),
        colors = ClickableSurfaceDefaults.colors(
            containerColor = Color.Transparent,
            focusedContainerColor = Color(0xFFFBBF24).copy(alpha = 0.15f)
        ),
        border = ClickableSurfaceDefaults.border(
            border = Border(BorderStroke(0.dp, Color.Transparent)),
            focusedBorder = Border(BorderStroke(0.dp, Color.Transparent))
        )
    ) {
        Box(contentAlignment = Alignment.Center, modifier = Modifier.fillMaxSize()) {
            Text(
                text = if (isFavourite) stringResource(R.string.star_icon) else "+",
                fontSize = 16.sp,
                color = when {
                    isFavourite -> Color(0xFFFBBF24)
                    starFocused -> Color(0xFFFBBF24).copy(alpha = 0.8f)
                    rowFocused -> Color.White.copy(alpha = 0.4f)
                    else -> Color.White.copy(alpha = 0.15f)
                }
            )
        }
    }
}

