private fun extractPrefix(name: String): String {
    val pipeIdx = name.indexOf('|')
    if (pipeIdx > 0) return name.substring(0, pipeIdx).trim().uppercase()
    val firstWord = name.substringBefore(' ').trim().uppercase()
    return if (regionColors.containsKey(firstWord)) firstWord else ""
}

private fun accentFor(name: String): Color = regionColors[extractPrefix(name)] ?: defaultAccent

private fun stripPrefix(name: String): Pair<String, String> {
    val pipeIdx = name.indexOf('|')
    if (pipeIdx > 0) {
        return name.substring(0, pipeIdx).trim() to name.substring(pipeIdx + 1).trim()
    }
    val firstWord = name.substringBefore(' ').trim()
    return if (regionColors.containsKey(firstWord.uppercase()))
        firstWord to name.substring(firstWord.length).trim()
    else "" to name
}

/** Cached prefix data per row -- avoids recomputing on every recomposition. */
private data class PrefixInfo(val prefix: String, val display: String, val accent: Color)

@Composable
private fun rememberPrefixInfo(name: String): PrefixInfo = remember(name) {
    val (prefix, display) = stripPrefix(name)
    PrefixInfo(prefix, display.ifEmpty { name }, accentFor(name))
}

// -----------------------------------------------------------------------------
// Logo prefetch cache
//
// Top-level so logos persist across fragment re-creations in the same session
// (avoiding redundant network calls), but capped via clearPrefetchedLogos()
// called from the fragment's onDestroyView.
// -----------------------------------------------------------------------------

private val prefetchedLogos = mutableStateMapOf<String, List<String>>()

fun clearPrefetchedLogos() = prefetchedLogos.clear()

object CategoryLogoPrefetcher {

    private var currentJob: kotlinx.coroutines.Job? = null

    fun start(
        scope: kotlinx.coroutines.CoroutineScope,
        context: Context,
        categories: List<CategoryItem>,
        contentType: ContentType,
        portalId: String,
        isDirectClientPortal: Boolean,   // true for M3U or Xtream
        portalUrl: String,
        macAddress: String
    ) {
        // Always cancel any previous job. By the time start() is called from a
        // new composition, the old composition is already torn down -- its
        // coroutine scope is dead and the cancel is a harmless no-op.
        currentJob?.cancel()

        currentJob = scope.launch(Dispatchers.IO) {
            val ordered = categories.sortedByDescending { it.isFavorite }
            for (category in ordered) {
                if (!isActive) break
                if (prefetchedLogos[category.id]?.isNotEmpty() == true) continue

                try {
                    val logos = fetchLogosForCategory(
                        context, portalId, category.id, contentType,
                        isDirectClientPortal, portalUrl
                    )
                    if (logos.isNotEmpty()) {
                        withContext(Dispatchers.Main) { prefetchedLogos[category.id] = logos }
                    }
                } catch (_: Exception) {}

                if (!category.isFavorite) delay(120)
            }
        }
    }

    fun cancel() {
        currentJob?.cancel()
        currentJob = null
    }

    private suspend fun fetchLogosForCategory(
        context: Context,
        portalId: String,
        categoryId: String,
        contentType: ContentType,
        isDirectClientPortal: Boolean,
        portalUrl: String
    ): List<String> {
        val cache = PortalCache.get(portalId)

        // Already in cache?
        cache.channelPagesByGenre[categoryId]?.values?.flatten()?.let { channels ->
            return channels.mapNotNull { it.logo?.takeIf { l -> l.startsWith("http") } }
                .distinct().take(4)
        }

        // Need to fetch
        val channels = if (isDirectClientPortal) {
            M3uCache.loadChannelsForCategory(context, portalUrl, categoryId, contentType)
                ?.also { ch ->
                    cache.channelPagesByGenre.getOrPut(categoryId) { mutableMapOf() }[1] = ch
                } ?: emptyList()
        } else {
            val page = StalkerSession.client.getChannelsPage(categoryId, page = 1, limit = 20)
            cache.channelPagesByGenre.getOrPut(categoryId) { mutableMapOf() }[1] = page.channels
            page.channels
        }

        return channels.mapNotNull { it.logo?.takeIf { l -> l.startsWith("http") } }
            .distinct().take(4)
    }
}

@Composable
private fun rememberCategoryLogos(
    categoryId: String,
    contentType: ContentType,
    maxLogos: Int = 4
): List<String> {
    // Fast path
    prefetchedLogos[categoryId]?.takeIf { it.isNotEmpty() }?.let { return it.take(maxLogos) }

    val context = LocalContext.current
    val logos = remember(categoryId, contentType) { mutableStateOf<List<String>>(emptyList()) }

    // Stagger first-frame I/O so all visible rows don't simultaneously hit disk
    var isVisible by remember { mutableStateOf(false) }
    LaunchedEffect(categoryId) {
        delay(50)
        isVisible = true
    }

    LaunchedEffect(categoryId, contentType, isVisible) {
        if (!isVisible || logos.value.isNotEmpty()) return@LaunchedEffect
        val activeId = withContext(Dispatchers.IO) {
            PortalRepository(context).getActivePortalId()
        } ?: return@LaunchedEffect
        val channels = PortalCache.get(activeId).channelPagesByGenre[categoryId]
            ?.values?.flatten() ?: return@LaunchedEffect
        logos.value = channels
            .mapNotNull { it.logo?.takeIf { l -> l.startsWith("http") } }
            .distinct().take(maxLogos)
    }

    return logos.value
}

