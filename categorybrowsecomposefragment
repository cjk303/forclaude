class CategoryBrowseComposeFragment : Fragment() {

    companion object {
        private const val ARG_CONTENT_TYPE = "content_type"

        // Bump to force-wipe all EPG cache files on next launch.
        private const val EPG_CACHE_VERSION = 2

        // Guards rapid re-entry into the EPG download from concurrent
        // onViewCreated calls. AtomicLong.compareAndSet replaces the previous
        // unsynchronised read-then-write of EpgRepository.lastEpgLoadAttemptMs.
        private val epgDownloadStartedAt = AtomicLong(0L)

        // Guards the one-time startup reload (when no counts are on disk) so it
        // fires at most once per portal per process, never on every launch.
        private val startupReloadAttempted =
            java.util.concurrent.ConcurrentHashMap<String, java.util.concurrent.atomic.AtomicBoolean>()
        fun newInstance(contentType: ContentType): CategoryBrowseComposeFragment =
            CategoryBrowseComposeFragment().apply {
                arguments = android.os.Bundle().apply {
                    putString(ARG_CONTENT_TYPE, contentType.name)
                }
            }
    }

    override fun onCreateView(
        inflater: android.view.LayoutInflater,
        container: android.view.ViewGroup?,
        savedInstanceState: android.os.Bundle?
    ): android.view.View {
        val contentType = ContentType.valueOf(
            arguments?.getString(ARG_CONTENT_TYPE) ?: ContentType.IPTV.name
        )
        val viewModel = ViewModelProvider(requireActivity())[TvHomeViewModel::class.java]

        return androidx.compose.ui.platform.ComposeView(requireContext()).apply {
            setViewCompositionStrategy(
                androidx.compose.ui.platform.ViewCompositionStrategy.DisposeOnViewTreeLifecycleDestroyed
            )
            setContent {
                androidx.compose.material3.MaterialTheme {
                    CategoryBrowseScreen(
                        contentType = contentType,
                        viewModel = viewModel,
                        onCategorySelected = { id, name ->
                            tvGoDrillDown(ContentBrowseComposeFragment.newInstance(contentType, id, name))
                        },
                        onNavigate = { fragment -> tvGoTopLevel(fragment) }
                    )
                }
            }
        }
    }

    override fun onViewCreated(view: android.view.View, savedInstanceState: android.os.Bundle?) {
        super.onViewCreated(view, savedInstanceState)
        val contentType = ContentType.valueOf(
            arguments?.getString(ARG_CONTENT_TYPE) ?: ContentType.IPTV.name
        )
        if (contentType != ContentType.IPTV) return

        val context = requireContext()
        val viewModel = ViewModelProvider(requireActivity())[TvHomeViewModel::class.java]

        // EPG download must survive fragment navigation -- use the application
        // scope so the download completes even if the user taps a category
        // while the .gz is still downloading.
        val appScope = ProcessLifecycleOwner.get().lifecycleScope

        appScope.launch(Dispatchers.IO) {
            runCatching { downloadEpgIfNeeded(context, viewModel) }
                .onFailure { Log.e("EPG_DIAG", "EPG setup error: ${it.message}") }
        }

        // Startup counts: restore from disk (instant, no network) and, only if
        // nothing was saved for this portal, fall back to a one-time background
        // reload to populate them. Runs in appScope so it survives the user
        // navigating into a category while it works.
        appScope.launch(Dispatchers.IO) {
            runCatching { restoreOrReloadCounts(context) }
                .onFailure { Log.w("CountStartup", "startup count task failed: ${it.message}") }
        }
    }

    /**
     * Cheap-first startup count population:
     *   1. Restore persisted counts from disk. If anything was restored, bump
     *      the count-version signal so the category screen re-reads + shows them.
     *   2. If NOTHING was on disk (restored == 0) -- fresh install or a portal
     *      never reloaded -- do a one-time full reload to populate + persist,
     *      which bumps the signal itself on completion (PortalReloader.reload).
     *
     * The reloadAttempted guard makes step 2 fire at most once per portal per
     * process, so we never auto-reload on every launch -- only when there's
     * genuinely nothing to show. Best-effort throughout; failures just leave
     * counts to the existing on-demand path.
     */
    private suspend fun restoreOrReloadCounts(context: Context) {
        val repo = PortalRepository(context)
        val portal = repo.getPortals().find { it.id == repo.getActivePortalId() } ?: return

        val cache = PortalCache.get(portal.id)

        // Step 1: restore from disk.
        val restored = ChannelCountStore.restore(context, portal.id, cache)
        if (restored > 0) {
            Log.d("CountStartup", "Restored $restored counts from disk for ${portal.name}")
            PortalCache.bumpCountsVersion()
            return
        }

        // Step 2: nothing saved -> one-time background reload to populate.
        val key = "startup_reload:${portal.id}"
        val flag = startupReloadAttempted.getOrPut(key) { java.util.concurrent.atomic.AtomicBoolean(false) }
        if (!flag.compareAndSet(false, true)) {
            Log.d("CountStartup", "Startup reload already attempted this session for ${portal.name}")
            return
        }
        Log.d("CountStartup", "No saved counts for ${portal.name} -- running one-time startup reload")
        // PortalReloader.reload populates + persists the maps and bumps
        // countsVersion itself on completion, so the screen updates when done.
        PortalReloader.reload(context, portal)
    }

    private suspend fun downloadEpgIfNeeded(context: Context, viewModel: TvHomeViewModel) {
        val portalRepo = PortalRepository(context)
        val activePortal = portalRepo.getPortals().find { it.id == portalRepo.getActivePortalId() }
            ?: return

        val epgUrl = activePortal.epgUrl.orEmpty()
            .ifBlank { activePortal.xmltvUrl.orEmpty() }
        if (epgUrl.isBlank()) return

        val nowMs = System.currentTimeMillis()
        val timeSinceLast = nowMs - EpgRepository.lastEpgLoadAttemptMs
        val hasData = EpgRepository.hasXmlTvData()

        Log.d("EPG_DIAG", "epgUrl='$epgUrl' lastAttempt=${timeSinceLast / 1000}s hasData=$hasData")

        // Skip if we have fresh data, or if we recently failed and need to back off
        if (hasData && timeSinceLast < 4 * 60 * 60 * 1000L) return
        if (!hasData && timeSinceLast in 1L until 5_000L) return

        // Atomic guard: only one download in flight at a time
        if (!epgDownloadStartedAt.compareAndSet(0L, nowMs) &&
            (nowMs - epgDownloadStartedAt.get()) < 60_000L) {
            Log.d("EPG_DIAG", "EPG download already in progress, skipping")
            return
        }
        EpgRepository.lastEpgLoadAttemptMs = nowMs

        try {
            val prefs = context.getSharedPreferences("epg_prefs", Context.MODE_PRIVATE)

            // Cache versioning + URL change detection
            val storedVersion = prefs.getInt("epg_cache_version", 0)
            if (storedVersion < EPG_CACHE_VERSION) {
                Log.d("EPG_DIAG", "Cache version bump ($storedVersion -> $EPG_CACHE_VERSION)")
                com.kam.magplayer.epg.ExternalEpgManager.clearAllCaches(context)
                prefs.edit().putInt("epg_cache_version", EPG_CACHE_VERSION).apply()
            }
            val lastUrl = prefs.getString("last_epg_url", null)
            if (lastUrl != epgUrl) {
                Log.d("EPG_DIAG", "URL changed ($lastUrl -> $epgUrl) -- clearing caches")
                com.kam.magplayer.epg.ExternalEpgManager.clearAllCaches(context)
                prefs.edit().putString("last_epg_url", epgUrl).apply()
            }

            val httpClient = if (!activePortal.isM3U && !activePortal.isXtream) {
                viewModel.getStalkerClient(activePortal.effectiveUrl, activePortal.macAddress)
                    .getHttpClient()
            } else okhttp3.OkHttpClient()

            val map = com.kam.magplayer.epg.XmlTvLoader.loadXmlTv(epgUrl, httpClient, context = context)
            Log.d("EPG_DIAG", "Loaded ${map.size} channels")

            if (map.isNotEmpty()) {
                EpgRepository.putXmlTvMap(map)
                EpgRepository.setOverrides(com.kam.magplayer.epg.EpgOverrideRepository(context).getOverrides(activePortal.id))
            } else {
                Log.w("EPG_DIAG", "Map empty -- resetting timestamp for retry")
                EpgRepository.lastEpgLoadAttemptMs = 0L
            }
        } catch (e: Exception) {
            Log.e("EPG_DIAG", "Download failed: ${e.message}")
            EpgRepository.lastEpgLoadAttemptMs = 0L
        } finally {
            epgDownloadStartedAt.set(0L)
        }
    }

    override fun onDestroyView() {
        super.onDestroyView()
        CategoryLogoPrefetcher.cancel()
        clearPrefetchedLogos()
        Log.d("CategoryBrowse", "onDestroyView -- prefetcher cancelled, logo cache cleared")
    }
}

