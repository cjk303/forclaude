@Composable
private fun CategoryListContent(
    mode: CategoryLayoutMode,
    categories: List<CategoryItem>,
    contentType: ContentType,
    viewModel: TvHomeViewModel,
    focusRequester: FocusRequester,
    favoriteIds: Set<String>,
    onSelected: (String, String) -> Unit,
    onFavoriteToggle: (CategoryItem) -> Unit,
    onLockClick: (CategoryItem) -> Unit,
    onHideClick: (CategoryItem) -> Unit,
    portalId: String?,
    cacheVersion: Int,
    targetCategoryId: String? = null
) {
    when (mode) {
        CategoryLayoutMode.COMPACT -> CompactList(
            categories, contentType, viewModel, focusRequester,
            favoriteIds, onSelected, onFavoriteToggle, onLockClick, onHideClick, portalId, cacheVersion,
            targetCategoryId
        )
        CategoryLayoutMode.GRID -> GridLayout(
            categories, contentType, viewModel, focusRequester,
            favoriteIds, onSelected, onFavoriteToggle, onLockClick, onHideClick, portalId, cacheVersion
        )
        CategoryLayoutMode.GROUPED -> GroupedList(
            categories, contentType, viewModel, focusRequester,
            favoriteIds, onSelected, onFavoriteToggle, onLockClick, onHideClick, portalId, cacheVersion
        )
    }
}

// -----------------------------------------------------------------------------
// Layout 1: Compact list
// -----------------------------------------------------------------------------

@OptIn(ExperimentalTvMaterial3Api::class)
@Composable
private fun CompactList(
    categories: List<CategoryItem>,
    contentType: ContentType,
    viewModel: TvHomeViewModel,
    focusRequester: FocusRequester,
    favoriteIds: Set<String>,
    onSelected: (String, String) -> Unit,
    onFavoriteToggle: (CategoryItem) -> Unit,
    onLockClick: (CategoryItem) -> Unit,
    onHideClick: (CategoryItem) -> Unit,
    portalId: String?,
    cacheVersion: Int,
    targetCategoryId: String? = null
) {
    val listState = androidx.compose.foundation.lazy.rememberLazyListState()

    // Focus restore: a dedicated FocusRequester attached to the row whose id
    // matches targetCategoryId. We scroll it into view (so the row is composed
    // and exists), then request focus on THAT row specifically -- not the list
    // -- which avoids the off-by-one where the list focused the row above.
    val targetRowFocusRequester = remember { FocusRequester() }

    LaunchedEffect(targetCategoryId, categories) {
        val id = targetCategoryId ?: return@LaunchedEffect
        val index = categories.indexOfFirst { it.id == id }
        if (index < 0) return@LaunchedEffect

        // Bring the target row into view.
        runCatching { listState.scrollToItem(index) }

        // Wait until the row is actually composed + placed before focusing.
        // A fixed delay() races composition on slow TV boxes: when the row
        // isn't ready, requestFocus() throws, runCatching swallows it, and the
        // TV focus engine falls back to a default item -- the "cursor jumps a
        // few categories up" bug. Poll the layout per frame instead, with a
        // bounded ceiling so we never hang.
        var ready = false
        var frames = 0
        while (frames < 48) {                  // ~0.8s ceiling at 60fps
            if (listState.layoutInfo.visibleItemsInfo.any { it.index == index }) {
                ready = true
                break
            }
            withFrameNanos { }
            frames++
        }
        if (!ready) return@LaunchedEffect

        // One settle frame so the row's focusRequester node is attached.
        withFrameNanos { }
        runCatching { targetRowFocusRequester.requestFocus() }
    }

    LazyColumn(
        state = listState,
        modifier = Modifier.focusRequester(focusRequester),
        contentPadding = PaddingValues(top = 4.dp, bottom = 24.dp),
        verticalArrangement = Arrangement.spacedBy(4.dp)
    ) {
        itemsIndexed(categories, key = { idx, item -> item.id.ifBlank { "cat_$idx" } }) { _, item ->
            // Attach the restore focus-requester only to the row we're
            // returning to; all other rows get an empty modifier.
            val rowModifier = if (item.id == targetCategoryId)
                Modifier.focusRequester(targetRowFocusRequester)
            else
                Modifier
            CompactCategoryRow(
                item = item.copy(isFavorite = item.id in favoriteIds),
                contentType = contentType,
                viewModel = viewModel,
                portalId = portalId,
                cacheVersion = cacheVersion,
                onClick = { onSelected(item.id, item.name) },
                onFavoriteClick = { onFavoriteToggle(item) },
                onLockClick = { onLockClick(item) },
                onHideClick = { onHideClick(item) },
                rowModifier = rowModifier
            )
        }
    }
}

@OptIn(ExperimentalTvMaterial3Api::class)
@Composable
private fun CompactCategoryRow(
    item: CategoryItem,
    contentType: ContentType,
    viewModel: TvHomeViewModel,
    portalId: String?,
    cacheVersion: Int,
    onClick: () -> Unit,
    onFavoriteClick: () -> Unit,
    onLockClick: () -> Unit = {},
    onHideClick: () -> Unit = {},
    rowModifier: Modifier = Modifier
) {
    val interactionSource = remember { MutableInteractionSource() }
    val isFocused by interactionSource.collectIsFocusedAsState()
    val count by rememberCategoryCount(item.id, contentType, 0, viewModel, portalId)
    val prefix = rememberPrefixInfo(item.name)

    var starFocused by remember { mutableStateOf(false) }
    var dotsFocused by remember { mutableStateOf(false) }
    val rowFocused = isFocused || starFocused || dotsFocused

    // Synthetic rows (Favourite Channels meta-entry) get no dots menu --
    // the actions don't apply to a pseudo-category. Detect by id prefix
    // so the same logic survives future synthetic entries we might add.
    val isMetaRow = item.id == FAV_CHANNELS_ID
    val menuActions = if (isMetaRow) emptyList<RowAction>() else listOf(
        RowAction(
            label = stringResource(R.string.menu_lock_with_pin),
            onClick = onLockClick
        ),
        RowAction(
            label = stringResource(R.string.menu_hide_category),
            onClick = onHideClick
        )
    )

    Row(
        modifier = rowModifier
            .fillMaxWidth()
            .height(48.dp)
            .clip(RoundedCornerShape(6.dp))
            .background(if (rowFocused) Color.Black.copy(alpha = 0.7f) else Color.Black.copy(alpha = 0.5f))
            .border(
                width = if (rowFocused) 2.dp else 1.dp,
                color = if (rowFocused) prefix.accent else Color.White.copy(alpha = 0.1f),
                shape = RoundedCornerShape(6.dp)
            ),
        verticalAlignment = Alignment.CenterVertically
    ) {
        // Accent bar
        Box(modifier = Modifier.width(3.dp).fillMaxHeight()
            .background(if (rowFocused) prefix.accent else prefix.accent.copy(alpha = 0.4f)))

        // Main surface
        Surface(
            onClick = onClick,
            modifier = Modifier.weight(1f).fillMaxHeight(),
            interactionSource = interactionSource,
            shape = ClickableSurfaceDefaults.shape(RoundedCornerShape(0.dp)),
            scale = ClickableSurfaceDefaults.scale(focusedScale = 1.0f, pressedScale = 0.98f),
            colors = ClickableSurfaceDefaults.colors(
                containerColor = Color.Transparent,
                focusedContainerColor = Color.Transparent
            ),
            border = ClickableSurfaceDefaults.border(
                border = Border(BorderStroke(0.dp, Color.Transparent)),
                focusedBorder = Border(BorderStroke(0.dp, Color.Transparent))
            )
        ) {
            Row(
                modifier = Modifier.fillMaxSize().padding(start = 14.dp),
                verticalAlignment = Alignment.CenterVertically
            ) {
                if (prefix.prefix.isNotEmpty()) {
                    Text(
                        text = prefix.prefix, fontSize = 10.sp, fontWeight = FontWeight.Bold,
                        color = prefix.accent,
                        modifier = Modifier.clip(RoundedCornerShape(3.dp))
                            .background(prefix.accent.copy(alpha = 0.12f))
                            .padding(horizontal = 5.dp, vertical = 2.dp)
                    )
                    Spacer(modifier = Modifier.width(8.dp))
                }
                Text(
                    text = prefix.display,
                    modifier = Modifier.weight(1f), fontSize = 14.sp,
                    fontWeight = if (rowFocused) FontWeight.SemiBold else FontWeight.Normal,
                    color = if (rowFocused) Color.White else Color(0xFFCBD5E1),
                    maxLines = 1, overflow = TextOverflow.Ellipsis
                )
                CountAndLogos(count, item.id, contentType, rowFocused, prefix.accent)
            }
        }

        // When the dots menu is present, the star gets square right-side
        // corners and the menu takes the outer rounding. When the menu
        // is suppressed (meta rows), the star keeps its rounded corners.
        FavouriteStar(
            isFavourite = item.isFavorite,
            rowFocused = rowFocused,
            onFocusChange = { starFocused = it },
            onClick = onFavoriteClick,
            cornerEnd = if (menuActions.isEmpty()) 6.dp else 0.dp
        )
        RowActionMenu(
            items = menuActions,
            onFocusChange = { dotsFocused = it },
            cornerEnd = 6.dp,
            tint = prefix.accent
        )
    }
}

@Composable
private fun CountAndLogos(
    count: String,
    itemId: String,
    contentType: ContentType,
    rowFocused: Boolean,
    accent: Color
) {
    val logos = rememberCategoryLogos(itemId, contentType)
    Row(
        modifier = Modifier.padding(end = 8.dp),
        horizontalArrangement = Arrangement.spacedBy(8.dp),
        verticalAlignment = Alignment.CenterVertically
    ) {
// Only show the badge for a real positive count. "..." (still
        // loading) and "0" (empty, or a synthetic/unknown category like the
        // Favourite Channels meta-row whose count lives in its name) are
        // both hidden so we never render a misleading "(0)".
        val countN = count.toIntOrNull()
        if (countN != null && countN > 0) {
            Text(
                text = "($countN)", fontSize = 12.sp,
                color = if (rowFocused) accent else Color(0xFF64748B),
                fontWeight = if (rowFocused) FontWeight.SemiBold else FontWeight.Normal
            )
        }
        if (logos.isNotEmpty()) {
            Row(
                horizontalArrangement = Arrangement.spacedBy(4.dp),
                verticalAlignment = Alignment.CenterVertically
            ) {
                logos.forEach { logoUrl ->
                    AsyncImage(
                        model = coil.request.ImageRequest.Builder(LocalContext.current)
                            .data(logoUrl).size(80, 80).allowHardware(DeviceInfo.allowHardwareBitmaps).build(),
                        contentDescription = null,
                        modifier = Modifier.size(24.dp).clip(RoundedCornerShape(4.dp))
                            .border(1.dp, Color.White.copy(alpha = 0.08f), RoundedCornerShape(4.dp)),
                        contentScale = ContentScale.Crop
                    )
                }
            }
        }
    }
}

