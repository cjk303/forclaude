@OptIn(ExperimentalTvMaterial3Api::class)
@Composable
fun CategoryBrowseScreen(
    contentType: ContentType,
    viewModel: TvHomeViewModel,
    onCategorySelected: (String, String) -> Unit,
    onNavigate: (Fragment) -> Unit = {}
) {
    val context = LocalContext.current
    val portalRepository = remember { PortalRepository(context) }
    val favoriteRepository = remember { FavoriteRepository(context) }
    val categoryFilterRepo = remember { CategoryFilterRepository(context) }
    val parentalRepo = remember { ParentalControlsRepository(context) }
    val scope = rememberCoroutineScope()
    val focusManager = LocalFocusManager.current

    // -- Core state ----------------------------------------------------------
    val allCategories = remember { mutableStateListOf<CategoryItem>() }
    val favoriteIds = remember { mutableStateOf<Set<String>>(emptySet()) }
    var activePortalId by remember { mutableStateOf<String?>(null) }
    var searchQuery by remember { mutableStateOf("") }
    var isLoading by remember { mutableStateOf(false) }
    var errorMessage by remember { mutableStateOf<String?>(null) }
    var searchFocused by remember { mutableStateOf(false) }
    var layoutMode by remember { mutableStateOf(CategoryLayoutMode.COMPACT) }
    var lastSelectedCategoryId by rememberSaveable { mutableStateOf<String?>(null) }

    // Re-trigger load on lifecycle resume (e.g. coming back from settings).
    // Also re-triggered by a coarse time tick so unlock-window expiry is
    // reflected naturally without explicit cross-screen signalling.
    var filterVersion by remember { mutableStateOf(0) }

    // PinDialog trigger: when non-null, the dialog is shown at the bottom of
    // this composable to handle PIN setup for a brand-new lock action.
    var categoryAwaitingPinSetup by remember { mutableStateOf<CategoryItem?>(null) }

    val title = when (contentType) {
        ContentType.IPTV -> stringResource(id = R.string.category_title_iptv)
        ContentType.VOD -> stringResource(id = R.string.category_title_vod)
        ContentType.SERIES -> stringResource(id = R.string.category_title_series)
    }

    // -- Filtered + sorted list ----------------------------------------------
    // Sorting only re-runs when the *size* or search changes -- not when a
    // favourite toggles. That keeps LazyColumn keys stable during * clicks so
    // D-pad focus is never lost. */* display is driven by `favoriteIds` instead.
    val filteredCategories by remember(allCategories, searchQuery) {
        derivedStateOf {
            val src = if (searchQuery.isBlank()) allCategories
            else allCategories.filter { it.name.contains(searchQuery, ignoreCase = true) }
            src.sortedWith(compareByDescending<CategoryItem> { it.id in favoriteIds.value }.thenBy { it.name })
        }
    }
// Back handling. This screen had none, so D-pad Back while the search field
    // was focused (keyboard up) left the user stuck: the IME ate the event but
    // nothing cleared focus or dismissed the keyboard. Enabled only when there's
    // something search-related to clean up, so normal "Back exits the screen"
    // behaviour is untouched when the handler is disabled.
    BackHandler(enabled = searchFocused || searchQuery.isNotBlank()) {
        when {
            searchFocused -> {
                focusManager.clearFocus()
                searchFocused = false
            }
            searchQuery.isNotBlank() -> {
                searchQuery = ""
            }
        }
    }
    // -- Lifecycle: refresh on resume ----------------------------------------
    val lifecycleOwner = androidx.compose.ui.platform.LocalLifecycleOwner.current
    DisposableEffect(lifecycleOwner) {
        val observer = androidx.lifecycle.LifecycleEventObserver { _, event ->
            if (event == androidx.lifecycle.Lifecycle.Event.ON_RESUME) {
                categoryFilterRepo.invalidateCache()
                filterVersion++
            }
        }
        lifecycleOwner.lifecycle.addObserver(observer)
        onDispose { lifecycleOwner.lifecycle.removeObserver(observer) }
    }

    // -- Favourite toggle plumbing -------------------------------------------
    suspend fun refreshFavorites() {
        val newFavs = withContext(Dispatchers.IO) {
            val active = portalRepository.getActivePortal() ?: return@withContext emptySet()
            favoriteRepository.getFavoriteCategories(active.macAddress, contentType).toSet()
        }
        favoriteIds.value = newFavs
    }

    val onFavoriteToggle: (CategoryItem) -> Unit = remember(contentType) {
        { item ->
            scope.launch(Dispatchers.IO) {
                val active = portalRepository.getActivePortal() ?: return@launch
                val mac = active.macAddress
                if (item.id in favoriteIds.value) {
                    favoriteRepository.removeFavoriteCategory(mac, contentType, item.id)
                } else {
                    favoriteRepository.addFavoriteCategory(mac, contentType, item.id)
                }
                refreshFavorites()
            }
            Unit
        }
    }

    // -- Dots-menu action handlers -------------------------------------------
    val onLockClick: (CategoryItem) -> Unit = { item ->
        val portalIdSnapshot = activePortalId
        when {
            portalIdSnapshot.isNullOrBlank() -> {
                Toast.makeText(context, context.getString(R.string.error_no_active_portal), Toast.LENGTH_SHORT).show()
            }
            parentalRepo.isEnabled(portalIdSnapshot) -> {
                // PIN already set: just lock the category immediately.
                scope.launch(Dispatchers.IO) {
                    parentalRepo.lockCategory(portalIdSnapshot, item.id)
                    withContext(Dispatchers.Main) {
                        Toast.makeText(
                            context,
                            context.getString(R.string.parental_toast_locked, item.name),
                            Toast.LENGTH_SHORT
                        ).show()
                        filterVersion++
                    }
                }
            }
            else -> {
                // No PIN yet: trigger PinDialog at the layout level (below).
                categoryAwaitingPinSetup = item
            }
        }
    }

    val onHideClick: (CategoryItem) -> Unit = { item ->
        scope.launch(Dispatchers.IO) {
            categoryFilterRepo.hideCategory(item.name)
            withContext(Dispatchers.Main) {
                Toast.makeText(
                    context,
                    context.getString(R.string.parental_toast_hidden, item.name),
                    Toast.LENGTH_SHORT
                ).show()
                filterVersion++
            }
        }
    }

    // -- Wrapped category selection (handles synthetic favourites entry) ----
    val wrappedOnCategorySelected = remember<(String, String) -> Unit>(
        scope, portalRepository, context, onCategorySelected
    ) {
        { id, name ->
            lastSelectedCategoryId = id
            if (id == FAV_CHANNELS_ID) {
                scope.launch(Dispatchers.IO) {
                    val portal = portalRepository.getActivePortal()
                    if (portal != null) {
                        val favChannels = FavoriteChannelsRepository(context).getFavoriteChannels(portal.id)
                        PortalCache.get(portal.id).channelPagesByGenre
                            .getOrPut(FAV_CHANNELS_ID) { mutableMapOf() }[1] = favChannels
                    }
                    withContext(Dispatchers.Main) { onCategorySelected(id, name) }
                }
            } else {
                onCategorySelected(id, name)
            }
        }
    }

    // -- Main load effect ----------------------------------------------------
    LaunchedEffect(contentType, filterVersion) {
        isLoading = true
        errorMessage = null
        try {
            val activePortal = withContext(Dispatchers.IO) { portalRepository.getActivePortal() }
                ?: run { errorMessage = context.getString(R.string.error_no_active_portal); isLoading = false; return@LaunchedEffect }
            activePortalId = activePortal.id

            // Cold-start recovery: if the in-memory cache was wiped (process
            // death under memory pressure on a quick back-out from the player),
            // repaint from disk BEFORE any network handshake. Mirrors
            // ChannelCountStore for counts. Without this, an empty cache forces
            // a live getGenres() handshake whose transient failure blanks the
            // screen to the portal-handshake / no-categories error.
            withContext(Dispatchers.IO) {
                val restored = CategoryStore.restore(
                    context, activePortal.id, PortalCache.get(activePortal.id)
                )
                if (restored > 0)
                    Log.d("CategoryBrowse", "Restored $restored categories from disk")
            }


            // Parental control filter -- per portal. Computed once per load so
            // both the cachedFast and fetched paths apply the same rule.
            // Empty set when parental controls are disabled OR the session is
            // currently unlocked, which makes the .filter step a no-op.
            val parentallyLocked: Set<String> =
                if (parentalRepo.isEnabled(activePortal.id) &&
                    !ParentalSession.isUnlocked(activePortal.id))
                    parentalRepo.getLockedCategoryIds(activePortal.id)
                else emptySet()

            // Fast path: show whatever's already cached. Doesn't clear isLoading
            // because the network refresh underneath might still update things.
            val cachedFast = cachedCategoriesFor(activePortal, contentType)
                .distinctBy { it.id }
                .filter { categoryFilterRepo.shouldShowCategory(it.name) }
                .filter { it.id !in parentallyLocked }
            if (cachedFast.isNotEmpty() && allCategories.isEmpty()) {
                allCategories.clear(); allCategories.addAll(cachedFast)
            }

            // Full load (no-op if cache is already populated)
            val fetched = loadCategoriesFor(activePortal, contentType, viewModel, context)
                .distinctBy { it.id }
                .filter { categoryFilterRepo.shouldShowCategory(it.name) }
                .filter { it.id !in parentallyLocked }

            // Inject synthetic "* Favourite Channels" entry at the top for IPTV.
            // Stays unfiltered by parental controls -- it's a meta-entry that
            // references the user's hand-picked channel favourites, not a
            // portal-side category.
            val withFavChannels = if (contentType == ContentType.IPTV) {
                val favCount = withContext(Dispatchers.IO) {
                    FavoriteChannelsRepository(context).getFavoriteChannels(activePortal.id).size
                }
                if (favCount > 0) {
                    listOf(CategoryItem(FAV_CHANNELS_ID, context.getString(R.string.category_fav_channels_count, favCount), false)) + fetched
                } else fetched
            } else fetched

// Only replace the visible list if the load actually produced
            // categories. On a fast back-press the handshake can fail and
            // loadCategoriesFor returns empty -- in that case keep whatever is
            // already shown (cachedFast) instead of blanking to an error.
            if (withFavChannels.isNotEmpty()) {
                allCategories.clear()
                allCategories.addAll(withFavChannels)
            } else if (allCategories.isEmpty() && cachedFast.isNotEmpty()) {
                allCategories.clear()
                allCategories.addAll(cachedFast)
            }
            refreshFavorites()

// Background logo prefetch (IPTV only).
// M3U excluded: for M3U portals, fetchLogosForCategory falls through to
// M3uCache.loadChannelsForCategory, which re-scans the entire playlist file
// per category -- a sustained full-file-scan storm that thrashes GC on
// low-RAM boxes (Shield/Amlogic/Rockchip ANRs). Stalker/Xtream keep their
// cheap 20-channel page prefetch. M3U logos still fill in lazily via
// rememberCategoryLogos once a category is opened and its channels cached.
            if (contentType == ContentType.IPTV && !activePortal.isM3U) {
                try {
                    CategoryLogoPrefetcher.start(
                        scope = scope,
                        context = context,
                        categories = allCategories,
                        contentType = contentType,
                        portalId = activePortal.id,
                        isDirectClientPortal = activePortal.isXtream,   // M3U no longer reaches here
                        portalUrl = activePortal.effectiveUrl,
                        macAddress = activePortal.macAddress
                    )
                } catch (_: Exception) { /* scope already dead */ }
            }
        } catch (e: IOException) {
            // Don't show a handshake error if we already have a usable list --
            // this is the fast-back-press case where the refresh failed but the
            // cache is intact. Only error when there's genuinely nothing to show.
            if (allCategories.isEmpty()) {
                errorMessage = context.getString(R.string.error_portal_handshake)
            }
        } catch (e: Exception) {
            // Suppress internal Compose/coroutine errors -- they're framework
            // noise from navigation timing, not real portal failures.
            val msg = e.message ?: ""
            errorMessage = when {
                msg.contains("coroutine scope", ignoreCase = true) ||
                        msg.contains("composition", ignoreCase = true) ||
                        msg.contains("left the composition", ignoreCase = true) -> null
                msg.isBlank() -> context.getString(R.string.error_unknown)
                else -> msg
            }
        } finally {
            isLoading = false
        }
    }

    // -- Layout --------------------------------------------------------------
    val listFocusRequester = remember { FocusRequester() }

    Box(modifier = Modifier.fillMaxSize()) {
        Image(
            painter = painterResource(id = R.drawable.tvbackground),
            contentDescription = null,
            modifier = Modifier.fillMaxSize(),
            contentScale = ContentScale.Crop
        )
        Box(modifier = Modifier.fillMaxSize().background(Color.Black.copy(alpha = 0.45f)))

        Row(modifier = Modifier.fillMaxSize()) {
            Sidebar(onNavigate)

            Column(
                modifier = Modifier
                    .weight(1f)
                    .fillMaxHeight()
                    .padding(start = 32.dp, end = 32.dp, top = 16.dp, bottom = 24.dp)
            ) {
                Header(
                    title = title,
                    layoutMode = layoutMode,
                    onLayoutToggle = {
                        layoutMode = when (layoutMode) {
                            CategoryLayoutMode.COMPACT -> CategoryLayoutMode.GRID
                            CategoryLayoutMode.GRID -> CategoryLayoutMode.GROUPED
                            CategoryLayoutMode.GROUPED -> CategoryLayoutMode.COMPACT
                        }
                    },
                    searchQuery = searchQuery,
                    onSearchQueryChange = { searchQuery = it },
                    searchFocused = searchFocused,
                    onSearchFocusChange = { searchFocused = it }
                )

                when {
                    filteredCategories.isNotEmpty() -> {
                        LaunchedEffect(filteredCategories.size, searchFocused) {
                            // When returning to a remembered category, CompactList
                            // handles focus via its per-row requester. Only do the
                            // default top-focus when there's no category to restore.
                            if (!searchFocused && filteredCategories.isNotEmpty()
                                && lastSelectedCategoryId == null) {
                                kotlinx.coroutines.delay(60)
                                runCatching { listFocusRequester.requestFocus() }
                            }
                        }
                        CategoryListContent(
                            mode = layoutMode,
                            categories = filteredCategories,
                            contentType = contentType,
                            viewModel = viewModel,
                            focusRequester = listFocusRequester,
                            favoriteIds = favoriteIds.value,
                            onSelected = wrappedOnCategorySelected,
                            onFavoriteToggle = onFavoriteToggle,
                            onLockClick = onLockClick,
                            onHideClick = onHideClick,
                            portalId = activePortalId,
                            cacheVersion = filterVersion,
                            targetCategoryId = lastSelectedCategoryId
                        )
                    }
                    isLoading -> LoadingState()
                    !errorMessage.isNullOrBlank() -> ErrorState(errorMessage!!)
                    else -> EmptyState()
                }
            }
        }

        // PinDialog overlay -- lives at the outer Box level so it overlays
        // the screen content. Triggered when onLockClick fires while no PIN
        // has been set; sets the PIN AND locks the chosen category atomically
        // on confirm.
        categoryAwaitingPinSetup?.let { itemToLock ->
            val portalIdSnapshot = activePortalId
            if (portalIdSnapshot.isNullOrBlank()) {
                categoryAwaitingPinSetup = null
            } else {
                PinDialog(
                    mode = PinDialogMode.Setup,
                    onConfirm = { pin ->
                        scope.launch(Dispatchers.IO) {
                            parentalRepo.setPin(portalIdSnapshot, pin)
                            parentalRepo.lockCategory(portalIdSnapshot, itemToLock.id)
                            withContext(Dispatchers.Main) {
                                categoryAwaitingPinSetup = null
                                Toast.makeText(
                                    context,
                                    context.getString(R.string.parental_toast_locked_setup, itemToLock.name),
                                    Toast.LENGTH_LONG
                                ).show()
                                filterVersion++
                            }
                        }
                    },
                    onCancel = { categoryAwaitingPinSetup = null }
                )
            }
        }
    }
}

