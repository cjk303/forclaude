package com.kam.magplayer

import android.content.Context
import android.util.Log
import org.json.JSONArray
import org.json.JSONObject
import java.io.File
import java.io.InputStream
import java.io.OutputStream
import java.text.SimpleDateFormat
import java.util.Date
import java.util.Locale
import com.kam.magplayer.epg.EpgSourceRepository
import com.kam.magplayer.epg.EpgOverrideRepository
/**
 * Export / import of user setup to a single versioned JSON file.
 *
 * Scope (v1): portals (+ active selection) and the category-filter config
 * (keyword filter, include/exclude mode, hidden categories with their order).
 * Portals are stored OPAQUELY -- the raw JSON array from PortalRepository is
 * embedded as-is and round-tripped untouched, so this class never needs to
 * know the Portal schema. Favourites / parental / watch-history are NOT yet
 * included (their storage hasn't been wired in here); they can be added as
 * new top-level sections without breaking older backups, thanks to the
 * version field.
 *
 * I/O is stream-based so callers can plug in either a SAF document Uri
 * (phone + Shield) or a plain File (fallback for TV boxes lacking a document
 * picker).
 */
object BackupManager {

    private const val TAG = "BackupManager"
    const val BACKUP_VERSION = 2

    // Mirrors CategoryFilterRepository's storage exactly.
    private const val CATEGORY_PREFS  = "category_filter_prefs"
    private const val K_FILTER        = "category_filter"
    private const val K_MODE          = "category_filter_mode"
    private const val K_HIDDEN        = "hidden_category_names"
    private const val K_HIDDEN_ORDER  = "hidden_category_order"

    enum class ImportMode { MERGE, REPLACE }

    data class ImportResult(
        val success: Boolean,
        val message: String,
        val portalsAdded: Int = 0,
        val totalPortals: Int = 0
    )

    fun suggestedFileName(): String {
        val ts = SimpleDateFormat("yyyyMMdd-HHmm", Locale.US).format(Date())
        return "magplayer-backup-$ts.json"
    }

    /** Convenience target for the no-document-picker fallback path on TV. */
    fun fallbackFile(context: Context): File =
        File(context.getExternalFilesDir(null), suggestedFileName())

    // ── Build ──────────────────────────────────────────────────────────────

    fun buildBackupJson(context: Context): String {
        val portalRepo = PortalRepository(context)
        val root = JSONObject()
        root.put("magplayer_backup", BACKUP_VERSION)
        root.put("exported_at", System.currentTimeMillis())
        root.put("app_version", appVersion(context))

        // Portals -- opaque raw array, plus active selection.
        val rawPortals = portalRepo.exportPortalsRawJson()
        root.put("portals", if (!rawPortals.isNullOrBlank()) JSONArray(rawPortals) else JSONArray())
        portalRepo.getActivePortalId()?.let { root.put("active_portal_id", it) }

        // Category-filter config.
        val cp = context.getSharedPreferences(CATEGORY_PREFS, Context.MODE_PRIVATE)
        val cat = JSONObject()
        cat.put("filter", cp.getString(K_FILTER, "") ?: "")
        cat.put("mode", cp.getString(K_MODE, "include") ?: "include")
        cat.put("hidden_names", JSONArray((cp.getStringSet(K_HIDDEN, emptySet()) ?: emptySet()).toList()))
        cat.put("hidden_order", JSONArray((cp.getStringSet(K_HIDDEN_ORDER, emptySet()) ?: emptySet()).toList()))
        root.put("category_filter", cat)

        // EPG sources (Phase 1) -- opaque array of {id,name,url}, merged by id on import.
        val rawSources = EpgSourceRepository(context).exportSourcesRawJson()
        root.put("epg_sources", if (!rawSources.isNullOrBlank()) JSONArray(rawSources) else JSONArray())

        // EPG per-channel overrides (Phase 2) -- object keyed by "overrides:<portalId>".
        val rawOverrides = EpgOverrideRepository(context).exportRawJson()
        root.put("epg_overrides", if (!rawOverrides.isNullOrBlank()) JSONObject(rawOverrides) else JSONObject())

        return root.toString(2)
    }

    fun exportToStream(context: Context, out: OutputStream) {
        out.bufferedWriter(Charsets.UTF_8).use { it.write(buildBackupJson(context)) }
    }

    // ── Restore ──────────────────────────────────────────────────────────────

    fun importFromStream(context: Context, input: InputStream, mode: ImportMode): ImportResult {
        val text = input.bufferedReader(Charsets.UTF_8).use { it.readText() }

        val root = try { JSONObject(text) } catch (e: Exception) {
            return ImportResult(false, context.getString(R.string.backup_error_invalid_file))
        }
        if (root.optInt("magplayer_backup", -1) <= 0) {
            return ImportResult(false, context.getString(R.string.backup_error_not_magplayer))
        }

        val portalRepo = PortalRepository(context)

        // ---- Portals ----
        val imported = root.optJSONArray("portals") ?: JSONArray()
        val existing = try {
            portalRepo.exportPortalsRawJson()?.takeIf { it.isNotBlank() }?.let { JSONArray(it) } ?: JSONArray()
        } catch (e: Exception) { JSONArray() }

        var added = 0
        val finalArr: JSONArray = when (mode) {
            ImportMode.REPLACE -> { added = imported.length(); imported }
            ImportMode.MERGE -> {
                val ids = HashSet<String>()
                for (i in 0 until existing.length()) {
                    existing.optJSONObject(i)?.optString("id")
                        ?.takeIf { it.isNotBlank() }?.let { ids.add(it) }
                }
                for (i in 0 until imported.length()) {
                    val obj = imported.optJSONObject(i) ?: continue
                    val id = obj.optString("id")
                    if (id.isBlank() || id !in ids) {
                        existing.put(obj); added++
                        if (id.isNotBlank()) ids.add(id)
                    }
                }
                existing
            }
        }
        portalRepo.importPortalsRawJson(finalArr.toString())

        // ---- Active selection ----
        val backupActive = root.optString("active_portal_id", "")
        if (backupActive.isNotBlank()) {
            val shouldSet = mode == ImportMode.REPLACE || portalRepo.getActivePortalId().isNullOrBlank()
            if (shouldSet) portalRepo.setActivePortalId(backupActive)
        }

        // ---- Category-filter config ----
        root.optJSONObject("category_filter")?.let { cat ->
            val cp = context.getSharedPreferences(CATEGORY_PREFS, Context.MODE_PRIVATE)
            val ed = cp.edit()

            // Hidden sets: union in both modes -- restoring hides should never
            // remove a hide the user already has.
            val hidden = (cp.getStringSet(K_HIDDEN, emptySet()) ?: emptySet()).toMutableSet()
            val order  = (cp.getStringSet(K_HIDDEN_ORDER, emptySet()) ?: emptySet()).toMutableSet()
            cat.optJSONArray("hidden_names")?.let { a -> for (i in 0 until a.length()) hidden.add(a.optString(i)) }
            cat.optJSONArray("hidden_order")?.let { a -> for (i in 0 until a.length()) order.add(a.optString(i)) }
            ed.putStringSet(K_HIDDEN, hidden)
            ed.putStringSet(K_HIDDEN_ORDER, order)

            // Keyword filter + mode: overwrite on replace, or fill in if blank.
            val curFilter = cp.getString(K_FILTER, "") ?: ""
            if (mode == ImportMode.REPLACE || curFilter.isBlank()) {
                ed.putString(K_FILTER, cat.optString("filter", curFilter))
                ed.putString(K_MODE, cat.optString("mode", "include"))
            }
            ed.apply()
        }

// ---- EPG sources (merge by id, mirroring the portal logic above) ----
        root.optJSONArray("epg_sources")?.let { importedSources ->
            val sourceRepo = EpgSourceRepository(context)
            val finalSources: JSONArray = when (mode) {
                ImportMode.REPLACE -> importedSources
                ImportMode.MERGE -> {
                    val existingSources = try {
                        sourceRepo.exportSourcesRawJson()?.takeIf { it.isNotBlank() }?.let { JSONArray(it) } ?: JSONArray()
                    } catch (e: Exception) { JSONArray() }
                    val ids = HashSet<String>()
                    for (i in 0 until existingSources.length()) {
                        existingSources.optJSONObject(i)?.optString("id")
                            ?.takeIf { it.isNotBlank() }?.let { ids.add(it) }
                    }
                    for (i in 0 until importedSources.length()) {
                        val obj = importedSources.optJSONObject(i) ?: continue
                        val id = obj.optString("id")
                        if (id.isBlank() || id !in ids) {
                            existingSources.put(obj)
                            if (id.isNotBlank()) ids.add(id)
                        }
                    }
                    existingSources
                }
            }
            sourceRepo.importSourcesRawJson(finalSources.toString())
        }

        // ---- EPG per-channel overrides ----
        root.optJSONObject("epg_overrides")?.let { overridesObj ->
            EpgOverrideRepository(context)
                .importRawJson(overridesObj.toString(), replace = (mode == ImportMode.REPLACE))
        }

        val total = portalRepo.getPortals().size
        Log.d(TAG, "Import ($mode): added=$added total=$total")
        return ImportResult(
            true,
            context.getString(R.string.backup_restore_success, added, total),
            added,
            total
        )
    }

    private fun appVersion(context: Context): String = try {
        context.packageManager.getPackageInfo(context.packageName, 0).versionName ?: ""
    } catch (e: Exception) { "" }
}
