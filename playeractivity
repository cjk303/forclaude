            // player. We always keep the currently-active category in the
            // list -- the user got here legitimately (session unlock,
            // pre-existing playback, parental state changed mid-session),
            // and yanking it out would interrupt their stream. The filter
            // only prevents switching TO new locked categories.
            val intentIds   = intent.getStringArrayListExtra("CAT_IDS")   ?: emptyList()
            val intentNames = intent.getStringArrayListExtra("CAT_NAMES") ?: emptyList()
            val catFilterRepo = CategoryFilterRepository(this)
            val parentalRepo  = ParentalControlsRepository(this)
