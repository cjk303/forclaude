    private fun buildVlcOptions(streamType: StreamType): List<String> {
        val options = playerOptimizer.buildVlcOptions(streamType).toMutableList()
        val stripPrefixes = listOf("--avcodec-hw","--codec","--drop-late-frames","--aout","--audio-resampler","--no-stats","--vout")
        options.removeAll { opt -> stripPrefixes.any { opt.startsWith(it) } }
        val isEmulator = android.os.Build.FINGERPRINT.contains("generic") ||
                android.os.Build.FINGERPRINT.contains("emulator") ||
                android.os.Build.MODEL.contains("Emulator") ||
                android.os.Build.MODEL.contains("Android SDK")
        val voutOption: String? = when {
            isEmulator -> null
            // VOD: leave libVLC to pick its default (OpenGL) vout.
            // android_display is the legacy SurfaceFlinger renderer -- it
            // can't blit 10-bit HEVC output from the hardware decoder,
            // which is what most 4K content (and all 4K HDR content) uses.
            // Symptom is audio plays but video is a black screen. The GL
            // vout handles 10-bit fine via textures, so VOD gets the
            // default and 4K HDR movies actually render.
            isVOD -> null
            // Live IPTV: force android_display. The default OpenGL vout
            // triggers GPU driver crashes on cheap Android TV boxes with
            // Mali drivers (CHiQ, Hisense, etc) during channel switching.
            // android_display uses SurfaceFlinger directly -- fewer code
            // paths, much higher compatibility. Live IPTV streams are
            // almost always 1080p or lower H.264, well within what
            // android_display can render, so we don't lose anything.
            else -> "--vout=android_display"
        }
        options.addAll(listOfNotNull(
            "--http-reconnect","--no-sub-autodetect-file","--no-media-library",
            "--clock-jitter=0","--clock-synchro=0",
            if (isEmulator) "--avcodec-hw=none" else "--avcodec-hw=any",
            "--aout=android_audiotrack","--verbose=-1","--log-verbose=-1",
            voutOption
        ))
        return options
    }

    private var isStatsPollingActive = false

    // Last time we saw a successful Buffering event with buffering == 100.
    // Updated from the MediaPlayer.Event.Buffering handler on the main
    // thread. Read by the watchdog (no native calls).
    @Volatile private var lastFullBufferingTs = 0L

    /**
     * Stall-detection watchdog. Runs on a background coroutine, polls
     * once per second, and triggers softReconnect() if the stream has
     * been stuck (no full-buffer event in 12+ seconds while still
     * supposedly playing).
     *
     * Rewritten in 1.3.3 to remove the native stats poll
     * (mp.media?.stats) that was the source of the nativeGetStats
     * SIGSEGV crash (75% of 1.3.2 crashes). Detection now relies
     * entirely on:
     *   - currentBuffering: updated from MediaPlayer.Event.Buffering
     *     (main thread, no race)
     *   - lastFullBufferingTs: timestamp of the last buffering=100 event
     *   - playerGeneration: ensures we bail before touching native state
     *
     * The generation guard makes the watchdog inert if teardown happened
     * mid-iteration: even if mediaPlayer hasn't been nulled yet, the
     * captured generation won't match and the loop exits.
     *
     * Behavior change vs 1.3.2:
     *   - We no longer detect "no decoded frames" directly. Instead we
     *     detect "buffering hasn't completed for 12s". In practice the
     *     two are tightly correlated -- a stalled stream will either
     *     show buffering < 100 or stop receiving Playing events. The
     *     buffer-stuck detection covers both.
     *   - We don't read decoded-frame counts, so we can't distinguish
     *     "actively decoding low-bitrate stream" from "stuck buffer that
     *     happens to be 100% full of stale data". The latter is rare.
     */
    private fun startStatsPolling() {
        if (isStatsPollingActive) return
        isStatsPollingActive = true
        val myGen = playerGeneration   // capture the generation we're watching
        lastFullBufferingTs = System.currentTimeMillis()
        lifecycleScope.launch(Dispatchers.Default) {
            try {
                while (playerActive && playerGeneration == myGen) {
                    // No native dereferencing in this loop. Everything we
                    // read is either pure Kotlin state (currentBuffering,
                    // lastFullBufferingTs, isChannelSwitching, isVOD) or
                    // accessed via methods we already know to be safe in
                    // the racing case.
                    val now = System.currentTimeMillis()
                    val timeSinceFullBuffer = now - lastFullBufferingTs

                    // If buffering is currently at 100 (good), reset the
                    // stall timer continuously. The Buffering event
                    // handler also updates this, but we double-check here
                    // in case events aren't firing.
                    if (currentBuffering >= 100f) {
                        lastFullBufferingTs = now
                    }

                    // Stall detection: live streams only, not during
                    // channel switches, only after we've been running long
                    // enough that a stall is meaningful.
                    if (!isVOD && !isChannelSwitching && timeSinceFullBuffer > 12_000L) {
                        Log.w("PlayerActivity",
                            "Watchdog: no full buffer event in ${timeSinceFullBuffer}ms -> reconnect")
                        // Re-check generation before dispatching the
                        // reconnect; softReconnect has its own guards but
                        // there's no harm in failing fast here.
                        if (playerGeneration != myGen) break
                        withContext(Dispatchers.Main) {
                            if (playerGeneration == myGen) softReconnect()
                        }
                        // Give the reconnect time to settle before
                        // re-evaluating. Reset the stall timer so we don't
                        // immediately re-trigger.
                        lastFullBufferingTs = System.currentTimeMillis()
                        delay(5_000)
                        continue
                    }

                    // Update the UI stream-health badge based on the
                    // pure-Kotlin signals we have. No more "frames per
                    // second" granularity, just a coarse buffering view.
                    val health = when {
                        currentBuffering >= 100f -> StreamHealthState.Excellent
                        currentBuffering > 0f    -> StreamHealthState.LowBitrate
                        else                     -> StreamHealthState.NoSignal
                    }
                    streamInfoViewModel.update(
                        StreamInfo(
                            health = health,
                            resolution = "Unknown",
                            bitrate = 0,
                            fps = 0,
                            codec = ""
                        )
                    )

                    delay(1_000)
                }
            } finally {
                isStatsPollingActive = false
            }
        }
    }

    private fun softReconnect() {
        val url = lastStreamUrl ?: return
        val now = System.currentTimeMillis()
        if (now - lastReconnectTs < reconnectCooldownMs) return
        if (reconnectAttempts >= maxReconnectAttempts) {
            runOnUiThread { Toast.makeText(this, getString(R.string.player_stream_unavailable), Toast.LENGTH_SHORT).show(); finish() }
            return
        }
        reconnectAttempts++; lastReconnectTs = now
        Log.w("PlayerActivity", "Soft reconnect #$reconnectAttempts")
        lifecycleScope.launch(Dispatchers.IO) {
            // Bail if the player is already torn down. The Media constructor
            // dereferences libVLC in native code, which SIGABRTs if released.
            if (!playerActive) return@launch
            val vlc = libVLC ?: return@launch
            try { mediaPlayer?.stop() } catch (_: Exception) {}
            delay(200)
            if (!playerActive) return@launch
            val media = try {
                Media(vlc, Uri.parse(url)).apply {
                    addOption(":http-user-agent=${lastStreamUserAgent ?: "Mozilla/5.0 (QtEmbedded; MAG254 stb) WebKit"}")
                    addOption(":http-referrer=${lastStreamReferrer ?: portalUrl}")
                    // Only force legacy HLS demux if this stream was flagged
                    // as needing it (set by the EncounteredError handler).
                    if (isHlsUrl && forceLegacyHlsDemux) addOption(":demux=hls")
                }
            } catch (e: Exception) {
                Log.w("PlayerActivity", "softReconnect: Media creation failed: ${e.message}")
                return@launch
            }
            withContext(Dispatchers.Main) {
                val mp = mediaPlayer
                if (isDestroyed || isFinishing || !playerActive || mp == null) {
                    media.release(); return@withContext
                }
                try {
                    if (mp.vlcVout?.areViewsAttached() == false)
                        mp.attachViews(binding.playerView, null, false, false)
                    mp.media = media
                    mp.play()
                } catch (e: Exception) {
                    Log.w("PlayerActivity", "softReconnect: playback failed: ${e.message}")
                } finally {
                    // Exactly one release: balances the Media() constructor's initial
                    // refcount; the player retains its own ref via mp.media = media
                    try { media.release() } catch (_: Exception) {}
                }
            }
        }
    }

    private fun liveEndReachedReconnect() {
        val url = lastStreamUrl ?: return
        val now = System.currentTimeMillis()
        if (now - lastReconnectTs < reconnectCooldownMs) return
        endReachedAttempts++; lastReconnectTs = now
        if (endReachedAttempts > maxEndReachedAttempts) {
            runOnUiThread { Toast.makeText(this, getString(R.string.player_stream_interrupted), Toast.LENGTH_SHORT).show() }
            endReachedAttempts = 0
        }
        lifecycleScope.launch(Dispatchers.IO) {
            delay(1000)
            // Same release-race protection as softReconnect.
            if (!playerActive) return@launch
            val vlc = libVLC ?: return@launch
            try { mediaPlayer?.stop() } catch (_: Exception) {}
            delay(200)
            if (!playerActive) return@launch
            val media = try {
                Media(vlc, Uri.parse(url)).apply {
                    addOption(":http-user-agent=${lastStreamUserAgent ?: "Mozilla/5.0 (QtEmbedded; MAG254 stb) WebKit"}")
                    addOption(":http-referrer=${lastStreamReferrer ?: portalUrl}")
                    // Same fallback-flag gating as softReconnect, so the
                    // demuxer choice stays consistent across all reconnect paths.
                    if (isHlsUrl && forceLegacyHlsDemux) addOption(":demux=hls")
                }
            } catch (e: Exception) {
                Log.w("PlayerActivity", "liveEndReachedReconnect: Media creation failed: ${e.message}")
                return@launch
            }
            withContext(Dispatchers.Main) {
                val mp = mediaPlayer
                if (isDestroyed || isFinishing || !playerActive || mp == null) {
                    media.release(); return@withContext
                }
                try {
                    if (mp.vlcVout?.areViewsAttached() == false)
                        mp.attachViews(binding.playerView, null, false, false)
                    mp.media = media
                    mp.play()
                } catch (e: Exception) {
                    Log.w("PlayerActivity", "liveEndReachedReconnect: playback failed: ${e.message}")
                } finally {
                    try { media.release() } catch (_: Exception) {}
                }
            }
        }
    }

    private var lastVlcOptionsFingerprint: String = ""

    private suspend fun initializePlayer(streamType: StreamType) {
        isStatsPollingActive = false
        val newOptions  = buildVlcOptions(streamType)
        val fingerprint = newOptions.joinToString("|")
        if (libVLC != null && fingerprint == lastVlcOptionsFingerprint) {
            val oldMp = mediaPlayer
            // detachViews() acquires libVLC's internal mutex which can be held by
            // a background release thread from a previous channel switch. Calling
            // it from the main thread caused ANRs ("blocked on futex_wait" inside
            // vlc_mutex_lock). It's safe to call from any thread, so push it to IO.
            withContext(Dispatchers.IO) { try { oldMp?.detachViews() } catch (_: Exception) {} }
            val newMp = withContext(Dispatchers.IO) { MediaPlayer(libVLC).apply { setEventListener(this@PlayerActivity) } }
            withContext(Dispatchers.Main) { mediaPlayer = newMp }
            // Release the OLD player on the shared serialized teardown thread.
            val swTag = VlcTeardownExecutor.nextTag()
            VlcTeardownExecutor.submit("channel-switch release", swTag) {
                try { oldMp?.setEventListener(null) } catch (_: Throwable) {}
                try { oldMp?.stop()                  } catch (_: Throwable) {}
                try { oldMp?.release()               } catch (_: Throwable) {}
            }
        } else {
            val oldMp  = mediaPlayer
            val oldVlc = libVLC
            // Null out the references on the main thread (state change) but do
            // the actual detachViews on IO -- same reasoning as above.
            withContext(Dispatchers.Main) {
                mediaPlayer = null; libVLC = null
            }
            withContext(Dispatchers.IO) { try { oldMp?.detachViews() } catch (_: Exception) {} }
            val (newVlc, newMp) = withContext(Dispatchers.IO) {
                val vlc = LibVLC(this@PlayerActivity, newOptions)
                val mp  = MediaPlayer(vlc).apply { setEventListener(this@PlayerActivity) }
                vlc to mp
            }
            withContext(Dispatchers.Main) {
                libVLC = newVlc; mediaPlayer = newMp; lastVlcOptionsFingerprint = fingerprint
            }
            // Release the OLD player + lib on the shared serialized teardown thread.
            val swTag = VlcTeardownExecutor.nextTag()
            VlcTeardownExecutor.submit("channel-switch release(+vlc)", swTag) {
                try { oldMp?.setEventListener(null) } catch (_: Throwable) {}
                try { oldMp?.stop()                  } catch (_: Throwable) {}
                try { oldMp?.release()               } catch (_: Throwable) {}
                try { oldVlc?.release()              } catch (_: Throwable) {}
            }
        }
    }

    private fun setupControls() {
        binding.backButton.setOnClickListener { savePlaybackPosition(); finish() }
        binding.playPauseButton.setOnClickListener {
            mediaPlayer?.let {
                if (it.isPlaying) { it.pause(); showControls() } else { it.play(); hideControls() }
            }
        }
        binding.prevButton.setOnClickListener { playPreviousChannel() }
        binding.nextButton.setOnClickListener { playNextChannel() }
        binding.rewindButton.setOnClickListener { seekVOD(-10000) }
        binding.fastForwardButton.setOnClickListener { seekVOD(10000) }
        binding.subtitlesButton.setOnClickListener { showSubtitleDialog() }
        binding.audioButton.setOnClickListener { showAudioTrackDialog() }
        binding.controlsContainer.alpha = 1f
        binding.controlsContainer.visibility = View.INVISIBLE
        binding.seekBar.max = 1000
        binding.seekBar.setOnSeekBarChangeListener(object : SeekBar.OnSeekBarChangeListener {
            override fun onProgressChanged(s: SeekBar?, p: Int, fromUser: Boolean) {
                if (fromUser) mediaPlayer?.let { if (it.length > 0) it.time = it.length * p / 1000L }
            }
            override fun onStartTrackingTouch(s: SeekBar?) { isSeeking = true; hideControlsHandler.removeCallbacksAndMessages(null) }
            override fun onStopTrackingTouch(s: SeekBar?) { isSeeking = false; scheduleHideControls() }
        })
    }

