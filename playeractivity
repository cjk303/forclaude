    override fun dispatchKeyEvent(event: KeyEvent): Boolean {
        // When the TV keyboard is showing, let keys flow naturally through the
        // view hierarchy to the focused Compose key. Only intercept BACK to close.
        if (!isVOD && showChannelOverlay && tvKeyboardOpen) {
            if (event.action == KeyEvent.ACTION_DOWN && event.keyCode == KeyEvent.KEYCODE_BACK) {
                overlayCloseKeyboard++
                return true
            }
            return super.dispatchKeyEvent(event)
        }
        if (event.action == KeyEvent.ACTION_DOWN) {
            return onKeyDown(event.keyCode, event)
        }
        return super.dispatchKeyEvent(event)
    }

    override fun onKeyDown(keyCode: Int, event: KeyEvent?): Boolean {

        // ___ Menu open: handle D-pad within the two panes ____________________
        if (!isVOD && showChannelOverlay) {
            // TV keyboard open: let Compose handle all keys natively.
            // We only catch BACK to close the keyboard cleanly.
            if (tvKeyboardOpen) {
                if (keyCode == KeyEvent.KEYCODE_BACK) {
                    overlayCloseKeyboard++
                    return true
                }
                return super.onKeyDown(keyCode, event)
            }

            return when (keyCode) {
                KeyEvent.KEYCODE_DPAD_UP -> {
                    when (menuFocusedPane) {
                        MenuPane.CATEGORIES -> {
                            // -1 = search; 0..filtered.size-1 = categories
                            // UP from category 0 -> search (-1); UP from search stays at -1
                            if (categoryFocusedIndex > -1) categoryFocusedIndex--
                        }
                        MenuPane.CHANNELS -> {
                            if (channelFocusedIndex > 0) channelFocusedIndex--
                        }
                    }
                    true
                }
                KeyEvent.KEYCODE_DPAD_DOWN -> {
                    when (menuFocusedPane) {
                        MenuPane.CATEGORIES -> {
                            val filteredSize = filteredCategoryIndices.size
                            if (categoryFocusedIndex < filteredSize - 1) categoryFocusedIndex++
                        }
                        MenuPane.CHANNELS -> {
                            if (channelFocusedIndex < channels.size - 1) channelFocusedIndex++
                        }
                    }
                    true
                }
                KeyEvent.KEYCODE_DPAD_LEFT -> {
                    if (menuFocusedPane == MenuPane.CHANNELS) {
                        menuFocusedPane = MenuPane.CATEGORIES
                        // Land directly on the filter pill so search is always
                        // reachable in one press from the channel list.
                        categoryFocusedIndex = -1
                    }
                    true
                }
                KeyEvent.KEYCODE_DPAD_RIGHT -> {
                    if (menuFocusedPane == MenuPane.CATEGORIES) {
                        // From the search pill, RIGHT also crosses to channels
                        menuFocusedPane = MenuPane.CHANNELS
                    }
                    true
                }
                KeyEvent.KEYCODE_DPAD_CENTER, KeyEvent.KEYCODE_ENTER -> {
                    when (menuFocusedPane) {
                        MenuPane.CATEGORIES -> {
                            if (categoryFocusedIndex == -1) {
                                // OK on search pill -> open TV keyboard
                                overlayOpenKeyboard++
                            } else {
                                // Map filtered position -> original index in allCategoryNames
                                val filtered = filteredCategoryIndices
                                val originalIdx = filtered.getOrNull(categoryFocusedIndex)
                                if (originalIdx != null) {
                                    if (isTV) previewCategory(originalIdx)
                                    else switchToCategory(originalIdx)
                                    // Commit: clear the search filter, jump focus to channels
                                    categoryQuery = ""
                                    val newFiltered = filteredCategoryIndices
                                    val newPos = newFiltered.indexOf(originalIdx)
                                    categoryFocusedIndex = if (newPos >= 0) newPos else 0
                                    menuFocusedPane = MenuPane.CHANNELS
                                    channelFocusedIndex = 0
                                }
                            }
                        }
                        MenuPane.CHANNELS -> {
                            val picked = channelFocusedIndex
                            showChannelOverlay = false
                            if (picked != currentIndex && picked in channels.indices) {
                                currentIndex = picked
                                updateTitle()
                                playIptvStream()
                            }
                        }
                    }
                    true
                }
                KeyEvent.KEYCODE_MENU, KeyEvent.KEYCODE_BOOKMARK, KeyEvent.KEYCODE_F -> {
                    if (menuFocusedPane == MenuPane.CHANNELS) {
                        val ch = channels.getOrNull(channelFocusedIndex)
                        if (ch != null) {
                            val isFav = favoriteChannelsRepository.toggleFavorite(portalId, ch)
                            Toast.makeText(this@PlayerActivity,
                                if (isFav) getString(R.string.player_toast_favourite_added_format, ch.name)
                                else getString(R.string.player_toast_favourite_removed_format, ch.name),
                                Toast.LENGTH_SHORT).show()
                        }
                    }
                    true
                }
                KeyEvent.KEYCODE_BACK -> {
                    showChannelOverlay = false
                    true
                }
                else -> super.onKeyDown(keyCode, event)
            }
        }

        // ___ Menu closed: standard player controls ___________________________
        when (keyCode) {
            KeyEvent.KEYCODE_DPAD_CENTER, KeyEvent.KEYCODE_ENTER -> {
                if (!isVOD) {
                    // If the controls bar is up and the user is on one of its
                    // buttons (audio, subtitles, play/pause, back), OK must
                    // activate THAT button -- not open the channel list.
                    // Without this, the live-TV audio + subtitle pickers were
                    // unreachable: OK always swallowed the press to open the
                    // channel overlay (the list sliding in from the left was
                    // exactly the symptom reported). VOD never had this problem
                    // because its OK path (below) checks control focus first;
                    // live TV skipped straight to opening the overlay.
                    val focusedCtl = currentFocus
                    if (binding.controlsContainer.visibility == View.VISIBLE &&
                        focusedCtl != null && focusedCtl != binding.playerView
                    ) {
                        focusedCtl.performClick()
                        scheduleHideControls()
                        return true
                    }
                    // Default live-TV behaviour: OK opens the channel overlay.
                    channelFocusedIndex = currentIndex.coerceAtLeast(0)
                    categoryQuery = ""
                    val filtered = filteredCategoryIndices
                    val filteredPos = filtered.indexOf(currentCatIndex)
                    categoryFocusedIndex = if (filteredPos >= 0) filteredPos else 0
                    menuFocusedPane = MenuPane.CHANNELS
                    showChannelOverlay = true
                    return true
                }
                if (binding.controlsContainer.visibility != View.VISIBLE) {
                    showControls(); return true
                }
                val focused = currentFocus
                return when {
                    focused == null || focused == binding.playerView -> { showControls(); true }
                    focused == binding.backButton -> { savePlaybackPosition(); finish(); true }
                    else -> { focused.performClick(); true }
                }
            }
            KeyEvent.KEYCODE_DPAD_LEFT -> {
                // Live TV, controls hidden: left = previous channel (unchanged).
                if (!isVOD && binding.controlsContainer.visibility != View.VISIBLE) {
                    playPreviousChannel(); return true
                }
                // VOD/series: left scrubs back. If the controls are hidden we
                // pop them up (focused on the seek bar) so the scrubber is
                // visible and repeated left/right keep seeking -- no need to
                // d-pad down to the seek bar first.
                if (isVOD) {
                    val controlsVisible = binding.controlsContainer.visibility == View.VISIBLE
                    if (!controlsVisible) {
                        seekVOD(-seekStepMs)
                        showControls()
                        binding.seekBar.post { binding.seekBar.requestFocus() }
                        return true
                    }
                    if (binding.seekBar.isFocused) {
                        seekVOD(-seekStepMs); scheduleHideControls(); return true
                    }
                    // Controls up, focus on a button row: let the system move
                    // focus between buttons instead of hijacking left as a seek.
                    scheduleHideControls()
                    return super.onKeyDown(keyCode, event)
                }
                if (binding.controlsContainer.visibility == View.VISIBLE) scheduleHideControls()
                return super.onKeyDown(keyCode, event)
            }
            KeyEvent.KEYCODE_DPAD_RIGHT -> {
                // Live TV, controls hidden: right = next channel (unchanged).
                if (!isVOD && binding.controlsContainer.visibility != View.VISIBLE) {
                    playNextChannel(); return true
                }
                // VOD/series: right scrubs forward (same model as left).
                if (isVOD) {
                    val controlsVisible = binding.controlsContainer.visibility == View.VISIBLE
                    if (!controlsVisible) {
                        seekVOD(seekStepMs)
                        showControls()
                        binding.seekBar.post { binding.seekBar.requestFocus() }
                        return true
                    }
                    if (binding.seekBar.isFocused) {
                        seekVOD(seekStepMs); scheduleHideControls(); return true
                    }
                    scheduleHideControls()
                    return super.onKeyDown(keyCode, event)
                }
                if (binding.controlsContainer.visibility == View.VISIBLE) scheduleHideControls()
                return super.onKeyDown(keyCode, event)
            }
            KeyEvent.KEYCODE_DPAD_UP -> {
                showControls()
                return super.onKeyDown(keyCode, event)
            }
            KeyEvent.KEYCODE_DPAD_DOWN -> {
                if (binding.controlsContainer.visibility != View.VISIBLE) {
                    showControls(); return true
                }
                val current: View? = currentFocus
                if (current != null) {
                    val next = FocusFinder.getInstance()
                        .findNextFocus(binding.root as ViewGroup, current, View.FOCUS_DOWN)
                    if (next == null) { hideControls(); return true }
                }
                return super.onKeyDown(keyCode, event)
            }
            KeyEvent.KEYCODE_BACK -> {
                savePlaybackPosition()
                finish()
                return true
            }
        }

        return super.onKeyDown(keyCode, event)
    }

    private var isChannelSwitching = false

    // Set to false before VLC release happens; checked by background
    // coroutines (stats watchdog, reconnect logic) to bail out before
    // calling into native libVLC on a torn-down player. The ~33% of
    // production crashes that surfaced as SIGABRT inside libvlc.so
    // were all racing operations on a player that had already been
    // released -- this flag closes the window between teardown and the
    // next native call. Volatile because it's read on background
    // threads (Dispatchers.IO, Dispatchers.Default).
    @Volatile private var playerActive = true

    // Player instance generation. Incremented on every teardown.
    // Background coroutines (especially the stats watchdog) capture
    // their starting generation; any call into the libVLC native layer
    // is gated by a check that the generation hasn't changed.
    //
    // Why this exists on top of playerActive: playerActive is a single
    // bit and can flip back to true when a new player is created. A
    // background thread that captured "playerActive=true" might run
    // again later when playerActive is true again -- but that's a
    // different player than the one it was watching, and any captured
    // references to the old MediaPlayer / Media are now stale. The
    // generation counter never reuses values, so a captured generation
    // unambiguously identifies one specific player instance.
    //
    // This fixes the nativeGetStats SIGSEGV (75% of 1.3.2 crashes) by
    // making it impossible for a stale watchdog to touch the released
    // native media object of a previous player instance.
    @Volatile private var playerGeneration: Long = 0

    /**
     * Detaches libVLC's AWindow from the VLCVideoLayout surface via the shared
     * teardown executor, but never blocks the calling (main) thread for longer
     * than [timeoutMs].
     *
     * detachViews() only severs the surface binding; the heavy input_Close /
     * vlc_join lives in stop() (which also runs on the executor). So this is
     * normally cheap. But a previous release on the executor could briefly
     * hold the mutex detachViews needs, so we run it on the executor and wait
     * with a timeout. If it doesn't finish in time we return anyway -- the
     * executor will complete the detach+stop+release in order, and worst case
     * the surface-destroy path behaves as it does today. Never worse.
     */
    private fun detachSurfaceBounded(mp: MediaPlayer?, tag: Long, timeoutMs: Long = 250L) {
        if (mp == null) return
        VlcTeardownExecutor.runDetachBounded("full detach", tag, timeoutMs) {
            try { mp.detachViews() } catch (_: Throwable) {}
        }
    }

    private fun playNextChannel() {
        if (isChannelSwitching) return
        if (channels.isNotEmpty() && currentIndex < channels.size - 1) {
            currentIndex++
            channelFocusedIndex = currentIndex
            updateTitle()
            playIptvStream()
        }
    }

    private fun playPreviousChannel() {
        if (isChannelSwitching) return
        if (channels.isNotEmpty() && currentIndex > 0) {
            currentIndex--
            channelFocusedIndex = currentIndex
            updateTitle()
            playIptvStream()
        }
    }

    private fun previewCategory(newCatIndex: Int) {
        if (newCatIndex !in allCategoryIds.indices) return
        val newCatId   = allCategoryIds[newCatIndex]
        val newCatName = allCategoryNames[newCatIndex]
        currentCategoryId   = newCatId
        currentCategoryName = newCatName
        currentCatIndex     = newCatIndex
        channelFocusedIndex = 0
        lifecycleScope.launch(Dispatchers.Default) {
            val cache   = PortalCache.get(portalId)
            val pageMap = cache.channelPagesByGenre[newCatId]
            val result  = if (pageMap != null && pageMap.isNotEmpty())
                pageMap.keys.sorted().flatMap { pageMap[it].orEmpty() }
            else emptyList()
            withContext(Dispatchers.Main) { channels = result }
            if (portalId.isNotEmpty()) {
                withContext(Dispatchers.IO) { loadRemainingChannelPages(portalId, newCatId) }
            }
        }
    }

    private fun switchToCategory(newCatIndex: Int) {
        if (newCatIndex !in allCategoryIds.indices) return
        previewCategory(newCatIndex)
        currentIndex = 0
        if (channels.isNotEmpty()) {
            updateTitle()
            playIptvStream()
        }
    }

