/**
 * Channel menu focus model.
 * Two panes: category rail (left) and channel list (right).
 * D-pad LEFT/RIGHT moves between panes, UP/DOWN within a pane.
 */
enum class MenuPane { CATEGORIES, CHANNELS }

/**
 * Simple category match: the category name must contain the query
 * (case-insensitive, whitespace trimmed).
 *
 * "pl" matches "PL| Premium Play"   YES
 * "pl" matches "DE| Plex TV"        YES
 * "pl" matches "Starzplay"          YES
 * "pl" does NOT match "News"        NO
 */
internal fun matchesCategoryQuery(name: String, query: String): Boolean {
    if (query.isBlank()) return true
    return name.contains(query.trim(), ignoreCase = true)
}

