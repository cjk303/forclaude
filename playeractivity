            categoryFocusedIndex = currentCatIndex.coerceAtLeast(0)
            Log.d("PlayerActivity", "Categories received: ${allCategoryNames.size} after filter (idx=$currentCatIndex)")
            currentFilter       = intent.getStringExtra("FILTER") ?: ""
            contentTypeName     = intent.getStringExtra("CONTENT_TYPE") ?: "IPTV"
            isXtream        = intent.getBooleanExtra("IS_XTREAM", false)
