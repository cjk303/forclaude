@OptIn(androidx.compose.foundation.ExperimentalFoundationApi::class)
@Composable
private fun TabletCategoryDropdown(
    genres: List<StalkerGenre>,
    selectedGenreId: String,
    favouriteIds: Set<String> = emptySet(),
    onGenreSelected: (StalkerGenre) -> Unit,
    onFavToggle: (StalkerGenre) -> Unit = {},
    onLockClick: (StalkerGenre) -> Unit = {},
    onHideClick: (StalkerGenre) -> Unit = {}
) {
    var showMenu by remember { mutableStateOf(false) }
    var search   by remember { mutableStateOf("") }
    val selectedName = genres.find { it.id == selectedGenreId }?.title ?: stringResource(R.string.all_label)

    Box(modifier = Modifier.fillMaxWidth().padding(horizontal = 8.dp, vertical = 6.dp)) {
        Row(
            modifier = Modifier
                .fillMaxWidth()
                .clip(RoundedCornerShape(8.dp))
                .background(CardDark)
                .border(1.dp, Divider, RoundedCornerShape(8.dp))
                .clickable { showMenu = true }
                .padding(horizontal = 12.dp, vertical = 8.dp),
            verticalAlignment = Alignment.CenterVertically,
            horizontalArrangement = Arrangement.SpaceBetween
        ) {
            Text(selectedName, color = TextPrimary, fontSize = 12.sp,
                fontWeight = FontWeight.SemiBold, maxLines = 1, overflow = TextOverflow.Ellipsis,
                modifier = Modifier.weight(1f))
            Text(stringResource(R.string.arrow_down), color = TextSecond, fontSize = 9.sp)
        }

        // Category panel -- slides open below the pill, overlays with clear bg
        if (showMenu) {
            Popup(
                onDismissRequest = { showMenu = false; search = "" },
                properties = PopupProperties(focusable = true)
            ) {
                Box(
                    modifier = Modifier
                        .width(284.dp)
                        .heightIn(max = 380.dp)
                        .clip(RoundedCornerShape(10.dp))
                        .background(Color(0xFF0F0F18))
                        .border(1.dp, AccentBlue.copy(alpha = 0.25f), RoundedCornerShape(10.dp))
                ) {
                    Column {
                        // Search field
                        Box(
                            modifier = Modifier
                                .fillMaxWidth()
                                .padding(8.dp)
                                .clip(RoundedCornerShape(6.dp))
                                .background(CardDark)
                                .border(1.dp, Divider, RoundedCornerShape(6.dp))
                                .padding(horizontal = 10.dp, vertical = 7.dp)
                        ) {
                            if (search.isEmpty()) Text(stringResource(R.string.category_search_hint), color = TextSecond, fontSize = 12.sp)
                            androidx.compose.foundation.text.BasicTextField(
                                value = search, onValueChange = { search = it }, singleLine = true,
                                textStyle = androidx.compose.ui.text.TextStyle(color = TextPrimary, fontSize = 12.sp),
                                cursorBrush = androidx.compose.ui.graphics.SolidColor(AccentBlue),
                                modifier = Modifier.fillMaxWidth()
                            )
                        }
                        HorizontalDivider(color = Divider)
                        val filtered = if (search.isBlank()) genres
                        else genres.filter { it.title.contains(search, true) }
                        LazyColumn {
                            // Index-suffixed key so duplicate or blank genre ids
                            // can't collide during a measure pass (the
                            // SubcomposeLayout IllegalArgumentException class).
                            itemsIndexed(filtered, key = { i, g -> g.id.ifBlank { g.title } + "_" + i }) { _, genre ->
                                val sel   = genre.id == selectedGenreId
                                val isFav = favouriteIds.contains(genre.id)
                                Row(
                                    modifier = Modifier
                                        .fillMaxWidth()
                                        .height(48.dp)
                                        .background(if (sel) AccentBlue.copy(alpha = 0.12f) else Color.Transparent),
                                    verticalAlignment = Alignment.CenterVertically,
                                    horizontalArrangement = Arrangement.spacedBy(6.dp)
                                ) {
                                    // Title area -- own clickable, isolates from star/dots
                                    Row(
                                        verticalAlignment = Alignment.CenterVertically,
                                        horizontalArrangement = Arrangement.spacedBy(6.dp),
                                        modifier = Modifier
                                            .weight(1f)
                                            .fillMaxHeight()
                                            .clickable { showMenu = false; search = ""; onGenreSelected(genre) }
                                            .padding(start = 12.dp, end = 4.dp)
                                    ) {
                                        if (sel) Box(Modifier.width(3.dp).height(14.dp)
                                            .background(AccentBlue, RoundedCornerShape(2.dp)))
                                        else Spacer(Modifier.width(3.dp))
                                        if (isFav) Text(stringResource(R.string.star_icon), color = AccentGold, fontSize = 11.sp)
                                        Text(
                                            genre.title,
                                            color = if (sel) AccentBlue else TextPrimary,
                                            fontWeight = if (sel || isFav) FontWeight.SemiBold else FontWeight.Normal,
                                            fontSize = 13.sp,
                                            maxLines = 1,
                                            overflow = TextOverflow.Ellipsis,
                                            modifier = Modifier.weight(1f)
                                        )
                                    }
                                    // Favourite star -- own click area, bigger tap target than phone's old one
                                    Text(
                                        if (isFav) stringResource(R.string.star_icon) else stringResource(R.string.star_outline_icon),
                                        color = if (isFav) AccentGold else TextSecond.copy(alpha = 0.3f),
                                        fontSize = 14.sp,
                                        modifier = Modifier
                                            .clip(RoundedCornerShape(4.dp))
                                            .clickable { onFavToggle(genre) }
                                            .padding(8.dp)
                                    )
                                    // Dots menu
                                    RowActionMenu(
                                        items = listOf(
                                            RowAction(label = stringResource(R.string.menu_lock_with_pin), onClick = {
                                                showMenu = false; search = ""; onLockClick(genre)
                                            }),
                                            RowAction(label = stringResource(R.string.menu_hide_category), onClick = {
                                                showMenu = false; search = ""; onHideClick(genre)
                                            })
                                        ),
                                        cornerEnd = 4.dp,
                                        tint = AccentBlue
                                    )
                                }
                            }
                        }
                        if (filtered.isEmpty()) {
                            DropdownMenuItem(text = { Text(stringResource(R.string.no_categories_found), color = TextSecond, fontSize = 13.sp) }, onClick = {})
                        }
                    }
                }
            }
        }
    }
}

// -- Channel list -------------------------------------------------------------

@Composable
private fun TabletChannelList(
    channels: List<Channel>,
    selectedChannel: Channel?,
    onChannelClick: (Channel) -> Unit,
    onVisibleChannelsChanged: (List<Channel>) -> Unit,
    onAssignEpg: (Channel) -> Unit = {}
) {
    val listState = androidx.compose.foundation.lazy.rememberLazyListState()

    // snapshotFlow keeps layoutInfo reads OUT of composition (reading it in
    // a composable key recomposes every scroll frame), debounce fires once
    // per scroll-rest, and keying on channels prevents stale reports after
    // a category switch. Same fix as the phone's ChannelList.
    LaunchedEffect(listState, channels) {
        snapshotFlow {
            listState.firstVisibleItemIndex to listState.layoutInfo.visibleItemsInfo.size
        }
            .debounce(200)
            .collect {
                val visible = listState.layoutInfo.visibleItemsInfo
                    .mapNotNull { channels.getOrNull(it.index) }
                if (visible.isNotEmpty()) onVisibleChannelsChanged(visible)
            }
    }

    LazyColumn(state = listState, modifier = Modifier.fillMaxSize(),
        contentPadding = PaddingValues(vertical = 4.dp)) {
        // Index-suffixed key: portals can hand back duplicate channel ids, and
        // a dupe key throws IllegalArgumentException on the next measure during
        // a scroll. The suffix makes every key unique even on id collision or
        // blank id.
        itemsIndexed(channels, key = { i, ch -> ch.id.ifBlank { "ch_$i" } + "_" + i }) { _, channel ->
            val isSelected = channel.id == selectedChannel?.id
            val xmltvVersion by EpgRepository.xmltvVersion.collectAsState()
            val stalkerVersion by EpgRepository.stalkerEpgVersion.collectAsState()
            var epg by remember(channel.id) { mutableStateOf<com.kam.magplayer.epg.StalkerEpgEvent?>(null) }
            LaunchedEffect(channel.id, xmltvVersion, stalkerVersion) {
                val result = withContext(Dispatchers.Default) { EpgRepository.getBestEpg(channel).first }
                epg = result
            }

            Row(
                modifier = Modifier
                    .fillMaxWidth()
                    .background(if (isSelected) AccentBlue.copy(alpha = 0.15f) else Color.Transparent)
                    .clickable { onChannelClick(channel) }
                    .padding(horizontal = 12.dp, vertical = 10.dp),
                verticalAlignment = Alignment.CenterVertically,
                horizontalArrangement = Arrangement.spacedBy(10.dp)
            ) {
                ChannelLogo(channel = channel, size = 36.dp)
                // Name + now playing
                Column(modifier = Modifier.weight(1f)) {
                    Text(channel.name, color = if (isSelected) TextPrimary else TextPrimary,
                        fontSize = 12.sp, fontWeight = if (isSelected) FontWeight.Bold else FontWeight.SemiBold,
                        maxLines = 1, overflow = TextOverflow.Ellipsis)
                    val epgSnapshot = epg
                    if (epgSnapshot != null) {
                        Text(epgSnapshot.title, color = TextSecond, fontSize = 10.sp,
                            maxLines = 1, overflow = TextOverflow.Ellipsis)
                    }
                }
                RowActionMenu(
                    items = listOf(
                        RowAction(
                            label = stringResource(R.string.menu_epg_override),
                            onClick = { onAssignEpg(channel) }
                        )
                    ),
                    cornerEnd = 8.dp,
                    tint = AccentBlue
                )
                if (isSelected) {
                    Box(modifier = Modifier.width(3.dp).height(20.dp)
                        .background(AccentBlue, RoundedCornerShape(2.dp)))
                }
            }
        }
    }
}

// -- VOD list (left pane) -----------------------------------------------------

@Composable
private fun TabletVodList(items: List<VodItem>, selectedVod: VodItem?, onVodClick: (VodItem) -> Unit) {
    LazyColumn(modifier = Modifier.fillMaxSize(), contentPadding = PaddingValues(vertical = 4.dp)) {
        // Index-suffixed key for the same dup-id/blank-id safety as the channel
        // list above.
        itemsIndexed(items, key = { i, v -> v.id.ifBlank { "vod_$i" } + "_" + i }) { _, vod ->
            val isSelected = vod.id == selectedVod?.id
            Row(
                modifier = Modifier
                    .fillMaxWidth()
                    .background(if (isSelected) AccentBlue.copy(alpha = 0.15f) else Color.Transparent)
                    .clickable { onVodClick(vod) }
                    .padding(horizontal = 12.dp, vertical = 10.dp),
                verticalAlignment = Alignment.CenterVertically,
                horizontalArrangement = Arrangement.spacedBy(10.dp)
            ) {
                AsyncImage(model = vod.poster, contentDescription = null,
                    modifier = Modifier.size(40.dp, 54.dp).clip(RoundedCornerShape(4.dp)),
                    contentScale = ContentScale.Crop)
                Column(modifier = Modifier.weight(1f)) {
                    Text(vod.name, color = if (isSelected) TextPrimary else TextPrimary,
                        fontSize = 12.sp, fontWeight = if (isSelected) FontWeight.Bold else FontWeight.SemiBold,
                        maxLines = 2, overflow = TextOverflow.Ellipsis)
                    if (vod.isSeries) Text(stringResource(R.string.home_menu_series), color = AccentGold, fontSize = 10.sp)
                }
                if (isSelected) {
                    Box(Modifier.width(3.dp).height(36.dp).background(AccentBlue, RoundedCornerShape(2.dp)))
                }
            }
        }
    }
}

// -- VOD/Series detail (right pane) -------------------------------------------

@Composable
private fun TabletVodDetail(vod: VodItem, onPlay: () -> Unit) {
    Column(
        modifier = Modifier
            .fillMaxSize()
            .verticalScroll(rememberScrollState())
    ) {
        // Poster -- centred, fixed width, natural aspect ratio, not full width
        Box(
            modifier = Modifier.fillMaxWidth().padding(vertical = 16.dp),
            contentAlignment = Alignment.Center
        ) {
            if (!vod.poster.isNullOrBlank()) {
                AsyncImage(
                    model = vod.poster,
                    contentDescription = vod.name,
                    modifier = Modifier
                        .width(280.dp)
                        .clip(RoundedCornerShape(10.dp)),
                    contentScale = ContentScale.FillWidth
                )
            } else {
                Box(
                    modifier = Modifier
                        .size(120.dp, 180.dp)
                        .clip(RoundedCornerShape(10.dp))
                        .background(CardDark)
                        .border(1.dp, Divider, RoundedCornerShape(10.dp)),
                    contentAlignment = Alignment.Center
                ) {
                    Text(vod.name.take(1).uppercase(), color = AccentBlue,
                        fontSize = 36.sp, fontWeight = FontWeight.Bold)
                }
            }
        }

        // Info section
        Column(
            modifier = Modifier.fillMaxWidth().padding(16.dp),
            verticalArrangement = Arrangement.spacedBy(10.dp)
        ) {
            // Title
            Text(vod.name, color = TextPrimary, fontSize = 18.sp, fontWeight = FontWeight.Bold)

            // Metadata row
            Row(horizontalArrangement = Arrangement.spacedBy(8.dp), verticalAlignment = Alignment.CenterVertically) {
                if (!vod.year.isNullOrBlank()) {
                    Box(modifier = Modifier
                        .clip(RoundedCornerShape(4.dp))
                        .background(CardDark)
                        .border(1.dp, Divider, RoundedCornerShape(4.dp))
                        .padding(horizontal = 8.dp, vertical = 3.dp)) {
                        Text(vod.year, color = TextSecond, fontSize = 11.sp)
                    }
                }
                if (vod.isSeries) {
                    Box(modifier = Modifier
                        .clip(RoundedCornerShape(4.dp))
                        .background(AccentGold.copy(alpha = 0.15f))
                        .border(1.dp, AccentGold.copy(alpha = 0.3f), RoundedCornerShape(4.dp))
                        .padding(horizontal = 8.dp, vertical = 3.dp)) {
                        Text(stringResource(R.string.home_menu_series), color = AccentGold, fontSize = 11.sp, fontWeight = FontWeight.SemiBold)
                    }
                }
            }

            // Description
            if (!vod.description.isNullOrBlank()) {
                HorizontalDivider(color = Divider)
                Text(
                    vod.description,
                    color = TextSecond,
                    fontSize = 13.sp,
                    lineHeight = 20.sp
                )
            }

            HorizontalDivider(color = Divider)

            // Play button
            Box(
                modifier = Modifier
                    .fillMaxWidth()
                    .clip(RoundedCornerShape(10.dp))
                    .background(AccentBlue)
                    .clickable { onPlay() }
                    .padding(vertical = 14.dp),
                contentAlignment = Alignment.Center
            ) {
                Row(verticalAlignment = Alignment.CenterVertically,
                    horizontalArrangement = Arrangement.spacedBy(8.dp)) {
                    Text("\u25B6", color = Color.White, fontSize = 14.sp)
                    Text(if (vod.isSeries) stringResource(R.string.select_season) else stringResource(R.string.play_label),
                        color = Color.White, fontSize = 14.sp, fontWeight = FontWeight.Bold)
                }
            }
        }
    }
}

// -- Channel detail (right pane) ----------------------------------------------

@Composable
private fun TabletChannelDetail(channel: Channel, onPlay: () -> Unit) {
    val xmltvVersion   by EpgRepository.xmltvVersion.collectAsState()
    val stalkerVersion by EpgRepository.stalkerEpgVersion.collectAsState()
    val timeFormatter  = remember { SimpleDateFormat("HH:mm", Locale.getDefault()) }

    var epgResult by remember(channel.id) {
        mutableStateOf<Pair<com.kam.magplayer.epg.StalkerEpgEvent?, com.kam.magplayer.epg.StalkerEpgEvent?>>(null to null)
    }
    LaunchedEffect(channel.id, xmltvVersion, stalkerVersion) {
        val result = withContext(Dispatchers.Default) { EpgRepository.getBestEpg(channel) }
        epgResult = result
    }
    val (nowEvent, nextEvent) = epgResult
    val nowSec = System.currentTimeMillis() / 1000
    val progress = remember(nowEvent, nowSec) {
        if (nowEvent == null) 0f
        else {
            val dur = nowEvent.end - nowEvent.start
            if (dur <= 0) 0f else ((nowSec - nowEvent.start).toFloat() / dur).coerceIn(0f, 1f)
        }
    }

    // Stream URL for mini player
    // Resolve Stalker "ffmpeg http://..." cmd to a direct playable URL
    var streamUrl by remember(channel) { mutableStateOf("") }
    LaunchedEffect(channel.id) {
        val cmd = channel.cmd
        if (cmd.isBlank()) return@LaunchedEffect
        val isDirectUrl = cmd.startsWith("http://") || cmd.startsWith("https://") ||
                cmd.startsWith("rtsp://")  || cmd.startsWith("rtmp://")
        streamUrl = if (isDirectUrl) {
            cmd
        } else {
            withContext(Dispatchers.IO) {
                try { StalkerSession.client.resolveStreamUrl(cmd) ?: "" }
                catch (e: Exception) { "" }
            }
        }
    }

    Column(modifier = Modifier.fillMaxSize()) {
        // Mini player -- top half
        Box(
            modifier = Modifier
                .fillMaxWidth()
                .aspectRatio(16f / 9f)
                .background(Color.Black)
        ) {
            if (streamUrl.isNotBlank()) {
                MiniPlayer(streamUrl = streamUrl, modifier = Modifier.fillMaxSize())
            } else {
                // No stream URL -- show logo placeholder
                Box(Modifier.fillMaxSize(), contentAlignment = Alignment.Center) {
                    Column(horizontalAlignment = Alignment.CenterHorizontally) {
                        if (!channel.logo.isNullOrBlank()) {
                            AsyncImage(model = channel.logo, contentDescription = null,
                                modifier = Modifier.size(64.dp).clip(CircleShape),
                                contentScale = ContentScale.Crop)
                        }
                        Spacer(Modifier.height(8.dp))
                        Text(channel.name, color = Color.White.copy(alpha = 0.5f), fontSize = 13.sp)
                    }
                }
            }
        }

        // Channel info
        Column(
            modifier = Modifier
                .fillMaxWidth()
                .padding(16.dp),
            verticalArrangement = Arrangement.spacedBy(10.dp)
        ) {
            // Channel name + logo
            Row(verticalAlignment = Alignment.CenterVertically,
                horizontalArrangement = Arrangement.spacedBy(10.dp)) {
                if (!channel.logo.isNullOrBlank()) {
                    AsyncImage(model = channel.logo, contentDescription = null,
                        modifier = Modifier.size(32.dp).clip(CircleShape),
                        contentScale = ContentScale.Crop)
                }
                Text(channel.name, color = TextPrimary, fontSize = 16.sp,
                    fontWeight = FontWeight.Bold, modifier = Modifier.weight(1f),
                    maxLines = 1, overflow = TextOverflow.Ellipsis)
            }

            HorizontalDivider(color = Divider)

            // EPG now
            if (nowEvent != null) {
                Column(verticalArrangement = Arrangement.spacedBy(4.dp)) {
                    Text(nowEvent.title, color = TextPrimary, fontSize = 14.sp,
                        fontWeight = FontWeight.SemiBold)
                    Text(
                        "${timeFormatter.format(Date(nowEvent.start * 1000))} \u2013 ${timeFormatter.format(Date(nowEvent.end * 1000))}",
                        color = TextSecond, fontSize = 11.sp
                    )
                    LinearProgressIndicator(
                        progress = { progress },
                        modifier = Modifier.fillMaxWidth().height(3.dp).clip(RoundedCornerShape(2.dp)),
                        color = AccentBlue, trackColor = Color.White.copy(alpha = 0.1f)
                    )
                }
            } else {
                Text(stringResource(R.string.no_program_information),
                    color = TextSecond, fontSize = 12.sp)
            }

            // Next program
            if (nextEvent != null) {
                Text(
                    text = stringResource(R.string.player_epg_next, nextEvent.title),
                    color = TextSecond, fontSize = 11.sp, maxLines = 1, overflow = TextOverflow.Ellipsis
                )
            }

            Spacer(Modifier.weight(1f))

            // Play button
            Box(
                modifier = Modifier
                    .fillMaxWidth()
                    .clip(RoundedCornerShape(10.dp))
                    .background(AccentBlue)
                    .clickable { onPlay() }
                    .padding(vertical = 12.dp),
                contentAlignment = Alignment.Center
            ) {
                Row(verticalAlignment = Alignment.CenterVertically,
                    horizontalArrangement = Arrangement.spacedBy(8.dp)) {
                    Text("\u25B6", color = Color.White, fontSize = 14.sp)
                    Text(stringResource(R.string.play_label), color = Color.White, fontSize = 14.sp, fontWeight = FontWeight.Bold)
                }
            }
        }
    }
}
