/**
 * Tablet-only home screen.
 * Layout:
 *   LEFT (300dp): top bar + category dropdown/search + channel list
 *   RIGHT: mini player + channel detail (name, EPG, play button)
 */
@Composable
fun TabletMainScreen(
    contentType:              ContentType,
    onContentTypeChange:      (ContentType) -> Unit,
    genres:                   List<StalkerGenre>,
    selectedGenreId:          String,
    onGenreSelected:          (StalkerGenre) -> Unit,
    channels:                 List<Channel>,
    vodItems:                 List<VodItem>,
    seriesItems:              List<VodItem>,
    isLoading:                Boolean,
    portalName:               String,
    portals:                  List<Portal>,
    activePortalId:           String,
    onPortalSwitch:           (Portal) -> Unit,
    onChannelClick:           (Channel) -> Unit,
    onVodClick:               (VodItem) -> Unit,
    onSearchClick:            () -> Unit,
    onRefreshClick:           () -> Unit,
    onSettingsClick:          () -> Unit,
    isReloading:              Boolean = false,
    onVisibleChannelsChanged: (List<Channel>) -> Unit = {}
) {
    var selectedChannel by remember { mutableStateOf<Channel?>(null) }
    var selectedVod     by remember { mutableStateOf<VodItem?>(null) }
    var inlineFilter    by remember { mutableStateOf("") }
    val context = LocalContext.current
    val coroutineScope = rememberCoroutineScope()

    // -- Filter infrastructure ---------------------------------------------
    // Brings tablet to parity with phone + TV: keyword filter, exact-name
    // hidden list (from the dots menu) and parental controls all apply
    // before genres reach the dropdown. resumeVersion bumps on lifecycle
    // resume so the cache is reread when the user comes back from settings.
    val categoryFilterRepo = remember { CategoryFilterRepository(context) }
    val parentalRepo = remember { ParentalControlsRepository(context) }
    var resumeVersion by remember { mutableStateOf(0) }

    // PinDialog trigger: when non-null, the dialog at the bottom of this
    // composable shows and walks the user through PIN setup for a brand-new
    // lock action. Same pattern as TV and phone.
    var genreAwaitingPinSetup by remember { mutableStateOf<StalkerGenre?>(null) }

    // EPG override picker trigger -- opened from a channel row's dots menu.
    var channelForEpgOverride by remember { mutableStateOf<Channel?>(null) }

    val lifecycleOwner = LocalLifecycleOwner.current
    DisposableEffect(lifecycleOwner) {
        val observer = LifecycleEventObserver { _, event ->
            if (event == Lifecycle.Event.ON_RESUME) {
                categoryFilterRepo.invalidateCache()
                resumeVersion++
            }
        }
        lifecycleOwner.lifecycle.addObserver(observer)
        onDispose { lifecycleOwner.lifecycle.removeObserver(observer) }
    }

    var favouriteIds by remember { mutableStateOf<Set<String>>(emptySet()) }
    LaunchedEffect(activePortalId, resumeVersion) {
        if (activePortalId.isBlank()) { favouriteIds = emptySet(); return@LaunchedEffect }
        favouriteIds = withContext(Dispatchers.IO) {
            val portal = PortalRepository(context).getActivePortal() ?: return@withContext emptySet()
            FavoriteRepository(context).getFavoriteCategories(portal.macAddress, ContentType.IPTV).toSet()
        }
    }

    // Optimistic toggle on the main thread, persistence on IO via a real
    // composition-scoped coroutine -- no more GlobalScope.
    fun toggleFav(genre: StalkerGenre) {
        val nowFav = !favouriteIds.contains(genre.id)
        favouriteIds = if (nowFav) favouriteIds + genre.id else favouriteIds - genre.id
        coroutineScope.launch(Dispatchers.IO) {
            val portal = PortalRepository(context).getActivePortal() ?: return@launch
            val repo = FavoriteRepository(context)
            if (nowFav) repo.addFavoriteCategory(portal.macAddress, ContentType.IPTV, genre.id)
            else repo.removeFavoriteCategory(portal.macAddress, ContentType.IPTV, genre.id)
        }
    }

    // Genre list with filters layered: shouldShowCategory (covers keywords
    // AND the hidden-name list), then parental.
    val filteredGenres = remember(genres, resumeVersion, activePortalId) {
        val parentallyLocked: Set<String> =
            if (activePortalId.isNotBlank() &&
                parentalRepo.isEnabled(activePortalId) &&
                !ParentalSession.isUnlocked(activePortalId))
                parentalRepo.getLockedCategoryIds(activePortalId)
            else emptySet()
        genres
            .filter { categoryFilterRepo.shouldShowCategory(it.title) }
            .filter { it.id !in parentallyLocked }
    }

    // -- Dots-menu actions -------------------------------------------------
    val onHideClick: (StalkerGenre) -> Unit = { genre ->
        coroutineScope.launch(Dispatchers.IO) {
            categoryFilterRepo.hideCategory(genre.title)
            withContext(Dispatchers.Main) {
                Toast.makeText(
                    context,
                    context.getString(R.string.parental_toast_hidden, genre.title),
                    Toast.LENGTH_SHORT
                ).show()
                resumeVersion++
            }
        }
    }
    val onLockClick: (StalkerGenre) -> Unit = { genre ->
        val portalIdSnapshot = activePortalId
        when {
            portalIdSnapshot.isBlank() -> {
                Toast.makeText(context, context.getString(R.string.error_no_active_portal), Toast.LENGTH_SHORT).show()
            }
            parentalRepo.isEnabled(portalIdSnapshot) -> {
                // PIN already set: lock the category immediately.
                coroutineScope.launch(Dispatchers.IO) {
                    parentalRepo.lockCategory(portalIdSnapshot, genre.id)
                    withContext(Dispatchers.Main) {
                        Toast.makeText(
                            context,
                            context.getString(R.string.parental_toast_locked, genre.title),
                            Toast.LENGTH_SHORT
                        ).show()
                        resumeVersion++
                    }
                }
            }
            else -> {
                // No PIN yet: trigger PinDialog at the bottom of this composable.
                genreAwaitingPinSetup = genre
            }
        }
    }

    // Apply inline filter
    val filteredChannels = remember(channels, inlineFilter) {
        if (inlineFilter.isBlank()) channels
        else channels.filter { it.name.contains(inlineFilter, ignoreCase = true) }
    }
    val filteredVod = remember(vodItems, inlineFilter) {
        if (inlineFilter.isBlank()) vodItems
        else vodItems.filter { it.name.contains(inlineFilter, ignoreCase = true) }
    }
    val filteredSeries = remember(seriesItems, inlineFilter) {
        if (inlineFilter.isBlank()) seriesItems
        else seriesItems.filter { it.name.contains(inlineFilter, ignoreCase = true) }
    }

    Row(
        modifier = Modifier
            .fillMaxSize()
            .background(BgDark)
            .systemBarsPadding()
    ) {
        // -- LEFT PANE -------------------------------------------------------
        Column(
            modifier = Modifier
                .width(300.dp)
                .fillMaxHeight()
                .background(SurfaceDark)
        ) {
            TabletTopBar(
                portalName      = portalName,
                portals         = portals,
                activePortalId  = activePortalId,
                onPortalSwitch  = onPortalSwitch,
                onSearchClick   = onSearchClick,
                onRefreshClick  = onRefreshClick,
                onSettingsClick = onSettingsClick,
                isReloading     = isReloading
            )

            HorizontalDivider(color = Divider)

            // Content type tabs
            Row(
                modifier = Modifier
                    .fillMaxWidth()
                    .padding(8.dp),
                horizontalArrangement = Arrangement.spacedBy(4.dp)
            ) {
                listOf(ContentType.IPTV to stringResource(R.string.home_menu_iptv), ContentType.VOD to stringResource(R.string.home_menu_movies), ContentType.SERIES to stringResource(R.string.home_menu_series))
                    .forEach { (type, label) ->
                        val sel = contentType == type
                        Box(
                            modifier = Modifier
                                .weight(1f)
                                .clip(RoundedCornerShape(8.dp))
                                .background(if (sel) AccentBlue else CardDark)
                                .clickable { onContentTypeChange(type); selectedChannel = null }
                                .padding(vertical = 6.dp),
                            contentAlignment = Alignment.Center
                        ) {
                            Text(label,
                                color = if (sel) Color.White else TextSecond,
                                fontSize = 11.sp,
                                fontWeight = if (sel) FontWeight.Bold else FontWeight.Normal)
                        }
                    }
            }

            HorizontalDivider(color = Divider)

            // Category dropdown
            TabletCategoryDropdown(
                genres          = filteredGenres,
                selectedGenreId = selectedGenreId,
                favouriteIds    = favouriteIds,
                onGenreSelected = { onGenreSelected(it); selectedChannel = null },
                onFavToggle     = { toggleFav(it) },
                onLockClick     = { onLockClick(it) },
                onHideClick     = { onHideClick(it) }
            )

            HorizontalDivider(color = Divider)

            // Inline filter
            Box(
                modifier = Modifier
                    .fillMaxWidth()
                    .padding(horizontal = 8.dp, vertical = 6.dp)
                    .clip(RoundedCornerShape(8.dp))
                    .background(CardDark)
                    .border(1.dp, if (inlineFilter.isNotEmpty()) AccentBlue.copy(0.4f) else Divider, RoundedCornerShape(8.dp))
                    .padding(horizontal = 10.dp, vertical = 7.dp)
            ) {
                if (inlineFilter.isEmpty()) Text(stringResource(R.string.filter_hint), color = TextSecond, fontSize = 12.sp)
                androidx.compose.foundation.text.BasicTextField(
                    value = inlineFilter,
                    onValueChange = { inlineFilter = it },
                    singleLine = true,
                    textStyle = androidx.compose.ui.text.TextStyle(color = TextPrimary, fontSize = 12.sp),
                    cursorBrush = androidx.compose.ui.graphics.SolidColor(AccentBlue),
                    modifier = Modifier.fillMaxWidth()
                )
            }

            HorizontalDivider(color = Divider)

            // Content list
            Box(modifier = Modifier.weight(1f)) {
                when {
                    isLoading -> Box(Modifier.fillMaxSize(), contentAlignment = Alignment.Center) {
                        CircularProgressIndicator(color = AccentBlue, strokeWidth = 2.dp)
                    }
                    contentType == ContentType.IPTV ->
                        TabletChannelList(
                            channels = filteredChannels,
                            selectedChannel = selectedChannel,
                            onChannelClick = { ch ->
                                selectedChannel = ch
                                // Single tap selects; double-tap (or Play button) launches
                            },
                            onVisibleChannelsChanged = onVisibleChannelsChanged,
                            onAssignEpg = { channelForEpgOverride = it }
                        )
                    contentType == ContentType.VOD ->
                        TabletVodList(items = filteredVod, selectedVod = selectedVod,
                            onVodClick = { selectedVod = it })
                    else ->
                        TabletVodList(items = filteredSeries, selectedVod = selectedVod,
                            onVodClick = { selectedVod = it })
                }
            }
        }

        VerticalDivider(color = Divider, thickness = 1.dp)

        // -- RIGHT PANE ------------------------------------------------------
        Box(
            modifier = Modifier
                .weight(1f)
                .fillMaxHeight()
                .background(BgDark)
        ) {
            when {
                contentType == ContentType.IPTV && selectedChannel != null ->
                    TabletChannelDetail(channel = selectedChannel!!, onPlay = { onChannelClick(selectedChannel!!) })
                contentType != ContentType.IPTV && selectedVod != null ->
                    TabletVodDetail(vod = selectedVod!!, onPlay = { onVodClick(selectedVod!!) })
                else ->
                    Box(Modifier.fillMaxSize(), contentAlignment = Alignment.Center) {
                        Column(horizontalAlignment = Alignment.CenterHorizontally,
                            verticalArrangement = Arrangement.spacedBy(8.dp)) {
                            Image(painterResource(R.drawable.tvlogo2), null,
                                modifier = Modifier.width(120.dp), contentScale = ContentScale.Fit)
                            Text(stringResource(R.string.select_item_details),
                                color = TextSecond, fontSize = 13.sp)
                        }
                    }
            }
        }
    }

    // PinDialog overlay -- the M3 Dialog renders in its own window, so its
    // position in source doesn't affect z-order. Triggered when onLockClick
    // fired without an existing PIN: sets the PIN AND locks the chosen
    // category atomically on confirm. Lives at TabletMainScreen's top-level
    // composable scope, NOT inside the onLockClick callback.
    genreAwaitingPinSetup?.let { genreToLock ->
        val portalIdSnapshot = activePortalId
        if (portalIdSnapshot.isBlank()) {
            genreAwaitingPinSetup = null
        } else {
            PinDialog(
                mode = PinDialogMode.Setup,
                onConfirm = { pin ->
                    coroutineScope.launch(Dispatchers.IO) {
                        parentalRepo.setPin(portalIdSnapshot, pin)
                        parentalRepo.lockCategory(portalIdSnapshot, genreToLock.id)
                        withContext(Dispatchers.Main) {
                            genreAwaitingPinSetup = null
                            Toast.makeText(
                                context,
                                context.getString(R.string.parental_toast_locked_setup, genreToLock.title),
                                Toast.LENGTH_LONG
                            ).show()
                            resumeVersion++
                        }
                    }
                },
                onCancel = { genreAwaitingPinSetup = null }
            )
        }
    }
}

// -- Top bar ------------------------------------------------------------------

@Composable
private fun TabletTopBar(
    portalName: String, portals: List<Portal>, activePortalId: String,
    onPortalSwitch: (Portal) -> Unit,
    onSearchClick: () -> Unit,
    onRefreshClick: () -> Unit,
    onSettingsClick: () -> Unit,
    isReloading: Boolean
) {
    var showMenu by remember { mutableStateOf(false) }
    Row(
        modifier = Modifier
            .fillMaxWidth()
            .padding(horizontal = 10.dp, vertical = 10.dp),
        verticalAlignment = Alignment.CenterVertically,
        horizontalArrangement = Arrangement.spacedBy(6.dp)
    ) {
        Image(painterResource(R.drawable.tvlogo2), null,
            modifier = Modifier.height(20.dp), contentScale = ContentScale.Fit)

        Box(modifier = Modifier.weight(1f)) {
            Row(
                modifier = Modifier
                    .clip(RoundedCornerShape(12.dp))
                    .background(AccentBlue.copy(alpha = 0.12f))
                    .border(1.dp, AccentBlue.copy(alpha = 0.25f), RoundedCornerShape(12.dp))
                    .clickable { if (portals.size > 1) showMenu = true }
                    .padding(horizontal = 8.dp, vertical = 4.dp),
                verticalAlignment = Alignment.CenterVertically,
                horizontalArrangement = Arrangement.spacedBy(4.dp)
            ) {
                Text(portalName.ifBlank { stringResource(R.string.stats_portal_name) }, color = AccentBlue, fontSize = 11.sp,
                    fontWeight = FontWeight.SemiBold, maxLines = 1, overflow = TextOverflow.Ellipsis,
                    modifier = Modifier.weight(1f, fill = false))
                if (portals.size > 1) Text(stringResource(R.string.arrow_down), color = AccentBlue, fontSize = 9.sp)
            }
            DropdownMenu(expanded = showMenu, onDismissRequest = { showMenu = false },
                modifier = Modifier.background(SurfaceDark)) {
                portals.forEach { portal ->
                    val isActive = portal.id == activePortalId
                    DropdownMenuItem(
                        text = { Text(portal.name,
                            color = if (isActive) AccentBlue else TextPrimary,
                            fontWeight = if (isActive) FontWeight.Bold else FontWeight.Normal) },
                        onClick = { showMenu = false; if (!isActive) onPortalSwitch(portal) }
                    )
                }
            }
        }

        // Refresh -- rotates while [isReloading] is true and is non-clickable
        // during that window to prevent stacked reloads. Tint switches to
        // AccentBlue while spinning so the state change is unmissable.
        TabletRefreshIcon(
            onClick = onRefreshClick,
            isSpinning = isReloading
        )
        Box(modifier = Modifier.size(28.dp).clip(RoundedCornerShape(6.dp)).clickable { onSearchClick() },
            contentAlignment = Alignment.Center) {
            Icon(painterResource(R.drawable.ic_search), null, tint = TextSecond, modifier = Modifier.size(16.dp))
        }
        Box(modifier = Modifier.size(28.dp).clip(RoundedCornerShape(6.dp)).clickable { onSettingsClick() },
            contentAlignment = Alignment.Center) {
            Icon(painterResource(R.drawable.ic_settings), null, tint = TextSecond, modifier = Modifier.size(16.dp))
        }
    }
}

/**
 * Refresh icon button for the tablet top bar. When [isSpinning] is true,
 * rotates 360 degrees every 900ms via [rememberInfiniteTransition], tints
 * AccentBlue, and ignores clicks. When false, behaves as a normal grey
 * icon button.
 */
@Composable
private fun TabletRefreshIcon(
    onClick: () -> Unit,
    isSpinning: Boolean
) {
    val rotation = if (isSpinning) {
        val transition = rememberInfiniteTransition(label = "tablet-refresh-spin")
        val angle by transition.animateFloat(
            initialValue = 0f,
            targetValue = 360f,
            animationSpec = infiniteRepeatable(
                animation = tween(900, easing = LinearEasing),
                repeatMode = RepeatMode.Restart
            ),
            label = "tablet-refresh-angle"
        )
        angle
    } else 0f

    Box(
        modifier = Modifier
            .size(28.dp)
            .clip(RoundedCornerShape(6.dp))
            .clickable(enabled = !isSpinning) { onClick() },
        contentAlignment = Alignment.Center
    ) {
        Icon(
            painterResource(R.drawable.ic_refresh),
            contentDescription = null,
            tint = if (isSpinning) AccentBlue else TextSecond,
            modifier = Modifier
                .size(16.dp)
                .rotate(rotation)
        )
    }
}

