@OptIn(ExperimentalTvMaterial3Api::class)
@Composable
fun ContentBrowseScreen(
    contentType:          ContentType,
    categoryName:         String,
    contentItems:         List<Any>,
    isLoading:            Boolean,
    loadingMessage:       String,
    onItemSelected:       (Any) -> Unit,
    activePortal:         Portal?,
    onLoadMore:           () -> Unit,
    externalSearchQuery:  String = "",
    onSearchQueryChanged: ((String) -> Unit)? = null,
    onNavigate:           (androidx.fragment.app.Fragment) -> Unit = {}
) {
    var searchQuery by remember { mutableStateOf(externalSearchQuery) }
    LaunchedEffect(externalSearchQuery) {
        if (externalSearchQuery != searchQuery) searchQuery = externalSearchQuery
    }
    var searchFocused by remember { mutableStateOf(false) }
    val listFocusRequester = remember { FocusRequester() }

    val categoryAccent = remember(categoryName) { contentAccentFor(categoryName) }
    val (categoryPrefix, categoryDisplayName) = remember(categoryName) { contentStripPrefix(categoryName) }

    val filteredContent by remember(searchQuery, contentItems) {
        derivedStateOf {
            if (searchQuery.isBlank()) contentItems
            else contentItems.filter {
                when (it) {
                    is Channel -> it.name.contains(searchQuery, ignoreCase = true)
                    is VodItem -> it.name.contains(searchQuery, ignoreCase = true)
                    else       -> false
                }
            }
        }
    }

    var selectedChannel by remember { mutableStateOf<Channel?>(null) }
    var channelForEpgOverride by remember { mutableStateOf<Channel?>(null) }

    // VOD/SERIES: the movie whose detail modal is currently open (null = closed).
    var vodModalItem by remember { mutableStateOf<VodItem?>(null) }

    // Favourite channels state
    val context = LocalContext.current
    var favoriteChannelIds by remember { mutableStateOf<Set<String>>(emptySet()) }
    val favRepo = remember(activePortal?.id) {
        FavoriteChannelsRepository(context)
    }

    LaunchedEffect(activePortal?.id) {
        val pid = activePortal?.id ?: return@LaunchedEffect
        favoriteChannelIds = withContext(Dispatchers.IO) {
            favRepo.getFavoriteChannels(pid).map { it.id }.toSet()
        }
    }

    fun toggleFav(channel: Channel) {
        val pid = activePortal?.id ?: return
        val isFav = favRepo.toggleFavorite(pid, channel)
        favoriteChannelIds = favRepo.getFavoriteChannels(pid).map { it.id }.toSet()
        android.widget.Toast.makeText(
            context,
            if (isFav) "★ Added to favourites" else "Removed from favourites",
            android.widget.Toast.LENGTH_SHORT
        ).show()
    }

    // Favourite VOD (movies) state -- parallel store to the channel favourites
    // above, kept separate so movies and channels never share one list.
    var favoriteVodIds by remember { mutableStateOf<Set<String>>(emptySet()) }
    val favVodRepo = remember(activePortal?.id) {
        FavoriteVodRepository(context)
    }

    LaunchedEffect(activePortal?.id) {
        val pid = activePortal?.id ?: return@LaunchedEffect
        favoriteVodIds = withContext(Dispatchers.IO) {
            favVodRepo.getFavorites(pid).map { it.id }.toSet()
        }
    }

    fun toggleVodFav(item: VodItem) {
        val pid = activePortal?.id ?: return
        val isFav = favVodRepo.toggleFavorite(pid, item)
        favoriteVodIds = favVodRepo.getFavorites(pid).map { it.id }.toSet()
        android.widget.Toast.makeText(
            context,
            if (isFav) "★ Added to favourites" else "Removed from favourites",
            android.widget.Toast.LENGTH_SHORT
        ).show()
    }

    var rawStreamUrl    by remember { mutableStateOf<String?>(null) }
    var epgLoading      by remember { mutableStateOf(false) }
    var selectedVodItem by remember { mutableStateOf<VodItem?>(null) }

    val isMainPlayerActive by mainPlayerActive

    LaunchedEffect(selectedChannel) {
        val channel = selectedChannel
        if (channel == null || channel.cmd.isNullOrBlank() || activePortal == null) {
            rawStreamUrl = null
            epgLoading   = false
            return@LaunchedEffect
        }

        rawStreamUrl = null
        val (epgNow, _) = EpgRepository.getBestEpg(channel)
        if (epgNow == null) epgLoading = true

        delay(400)

        val url = withContext(Dispatchers.IO) {
            val cmd = channel.cmd
            when {
                cmd.startsWith("http") -> cmd
                ResolvedUrlCache.get(cmd) != null -> {
                    Log.d("MiniPlayer", "URL cache hit for ${channel.name}")
                    ResolvedUrlCache.get(cmd)
                }
                activePortal?.isXtream == true -> { val built = activePortal!!.xtreamStreamUrl(cmd); ResolvedUrlCache.put(cmd, built); built }
                else -> try {
                    val resolved = StalkerClient(activePortal.effectiveUrl, activePortal.macAddress)
                        .resolveStreamUrl(cmd)
                    if (resolved != null) ResolvedUrlCache.put(cmd, resolved)
                    resolved
                } catch (e: Exception) {
                    Log.e("MiniPlayer", "resolveStreamUrl failed for ${channel.name}: ${e.message}")
                    null
                }
            }
        }

        rawStreamUrl = url
        epgLoading   = false
    }

    val miniPlayerUrl = if (isMainPlayerActive) null else rawStreamUrl

    // Return focus to the poster grid when the detail modal closes so the D-pad
    // isn't stranded on a dismissed overlay. Scoped to VOD/SERIES so IPTV focus
    // handling is untouched.
    LaunchedEffect(vodModalItem) {
        if (vodModalItem == null && contentType != ContentType.IPTV && filteredContent.isNotEmpty()) {
            delay(60)
            runCatching { listFocusRequester.requestFocus() }
        }
    }

    Box(modifier = Modifier.fillMaxSize()) {
        Image(
            painter            = painterResource(id = R.drawable.tvbackground),
            contentDescription = null,
            modifier           = Modifier.fillMaxSize(),
            contentScale       = ContentScale.Crop
        )
        Box(modifier = Modifier.fillMaxSize().background(Color.Black.copy(alpha = 0.45f)))

        Row(modifier = Modifier.fillMaxSize()) {

            // ── LEFT SIDEBAR ──────────────────────────────────────────────
            Column(
                modifier = Modifier
                    .width(72.dp)
                    .fillMaxHeight()
                    .background(Color.Black.copy(alpha = 0.4f))
                    .padding(vertical = 16.dp),
                horizontalAlignment = Alignment.CenterHorizontally,
                verticalArrangement = Arrangement.SpaceEvenly
            ) {
                Surface(
                    onClick = { onNavigate(TvHomeComposeFragment()) },
                    shape = ClickableSurfaceDefaults.shape(RoundedCornerShape(10.dp)),
                    colors = ClickableSurfaceDefaults.colors(
                        containerColor        = Color.Transparent,
                        focusedContainerColor = Color.White.copy(alpha = 0.1f)
                    ),
                    border = ClickableSurfaceDefaults.border(
                        border        = Border(BorderStroke(0.dp, Color.Transparent)),
                        focusedBorder = Border(BorderStroke(1.5.dp, Color.White.copy(alpha = 0.4f)), shape = RoundedCornerShape(10.dp))
                    ),
                    scale = ClickableSurfaceDefaults.scale(focusedScale = 1.08f)
                ) {
                    Image(
                        painter = painterResource(id = R.drawable.sqlogo),
                        contentDescription = "Home",
                        modifier = Modifier.size(48.dp).padding(6.dp)
                    )
                }
                SidebarButton(R.drawable.ic_iptv,     stringResource(R.string.home_menu_iptv))     { onNavigate(CategoryBrowseComposeFragment.newInstance(ContentType.IPTV)) }
                SidebarButton(R.drawable.ic_movies,   stringResource(R.string.home_menu_movies))   { onNavigate(CategoryBrowseComposeFragment.newInstance(ContentType.VOD)) }
                SidebarButton(R.drawable.ic_series,   stringResource(R.string.home_menu_series))   { onNavigate(CategoryBrowseComposeFragment.newInstance(ContentType.SERIES)) }
                SidebarButton(R.drawable.ic_search,   stringResource(R.string.home_menu_search))   { onNavigate(GlobalSearchFragment()) }
                SidebarButton(R.drawable.ic_settings, stringResource(R.string.home_menu_settings)) { onNavigate(SettingsTvComposeFragment()) }
            }

            // ── MAIN CONTENT ──────────────────────────────────────────────
            Column(modifier = Modifier.weight(1f).fillMaxHeight().padding(start = 32.dp, end = 32.dp, top = 16.dp, bottom = 24.dp)) {

                // Title row
                Row(
                    modifier = Modifier.fillMaxWidth().padding(bottom = 16.dp),
                    horizontalArrangement = Arrangement.SpaceBetween,
                    verticalAlignment = Alignment.CenterVertically
                ) {
                    Row(verticalAlignment = Alignment.CenterVertically, horizontalArrangement = Arrangement.spacedBy(10.dp)) {
                        if (categoryPrefix.isNotEmpty()) {
                            Text(
                                text       = categoryPrefix,
                                fontSize   = 13.sp,
                                fontWeight = FontWeight.Bold,
                                color      = categoryAccent,
                                modifier   = Modifier
                                    .clip(RoundedCornerShape(4.dp))
                                    .background(categoryAccent.copy(alpha = 0.15f))
                                    .padding(horizontal = 8.dp, vertical = 3.dp)
                            )
                        }
                        Text(
                            text          = if (categoryPrefix.isNotEmpty()) categoryDisplayName else categoryName,
                            fontSize      = 28.sp,
                            fontWeight    = FontWeight.Bold,
                            color         = Color.White,
                            letterSpacing = 0.5.sp
                        )
                    }
                    Box(
                        modifier = Modifier
                            .width(120.dp)
                            .height(2.dp)
                            .background(
                                Brush.horizontalGradient(listOf(Color.Transparent, categoryAccent.copy(alpha = 0.6f))),
                                RoundedCornerShape(1.dp)
                            )
                    )
                }

                if (contentType == ContentType.IPTV) {
                    // IPTV keeps its two-pane layout: channel list (left) + live
                    // MiniPlayer / EPG preview (right). Unchanged.
                    Row(Modifier.fillMaxSize()) {
                        Column(
                            modifier = Modifier
                                .fillMaxHeight()
                                .weight(0.35f)
                        ) {
                            SearchBar(
                                searchQuery = searchQuery,
                                onSearchQueryChanged = { searchQuery = it; onSearchQueryChanged?.invoke(it) },
                                onFocusChanged = { searchFocused = it },
                                accentColor = categoryAccent,
                                downFocusRequester = listFocusRequester
                            )
                            Spacer(modifier = Modifier.height(12.dp))
                            ContentList(
                                contentType        = contentType,
                                contentItems       = filteredContent,
                                isLoading          = isLoading,
                                loadingMessage     = loadingMessage,
                                focusRequester     = listFocusRequester,
                                searchFocused      = searchFocused,
                                categoryAccent     = categoryAccent,
                                onItemSelected     = onItemSelected,
                                onChannelFocused   = { selectedChannel = it },
                                onVodItemFocused   = { selectedVodItem = it },
                                onLoadMore         = onLoadMore,
                                favoriteChannelIds = favoriteChannelIds,
                                onFavoriteToggle   = { toggleFav(it) },
                                onAssignEpg        = { channelForEpgOverride = it },
                                onVodClick         = { vodModalItem = it }
                            )
                        }

                        Box(
                            modifier = Modifier
                                .fillMaxHeight()
                                .weight(0.65f)
                                .padding(start = 32.dp)
                        ) {
                            if (selectedChannel != null) {
                                RightPane(
                                    channel     = selectedChannel!!,
                                    streamUrl   = miniPlayerUrl,
                                    epgLoading  = epgLoading,
                                    accentColor = categoryAccent
                                )
                            } else {
                                RightPanePlaceholder()
                            }
                        }
                    }
                } else {
                    // VOD / SERIES: full-width poster grid. Details now open in a
                    // modal (see VodInfoCard) on movie select, so there's no
                    // inline right pane eating half the width -- that reclaimed
                    // space is what lets the grid run 6 posters wide.
                    Column(Modifier.fillMaxSize()) {
                        SearchBar(
                            searchQuery          = searchQuery,
                            onSearchQueryChanged = { searchQuery = it; onSearchQueryChanged?.invoke(it) },
                            onFocusChanged       = { searchFocused = it },
                            accentColor          = categoryAccent
                        )
                        Spacer(modifier = Modifier.height(12.dp))
                        ContentList(
                            contentType        = contentType,
                            contentItems       = filteredContent,
                            isLoading          = isLoading,
                            loadingMessage     = loadingMessage,
                            focusRequester     = listFocusRequester,
                            searchFocused      = searchFocused,
                            categoryAccent     = categoryAccent,
                            onItemSelected     = onItemSelected,
                            onChannelFocused   = { selectedChannel = it },
                            onVodItemFocused   = { selectedVodItem = it },
                            onLoadMore         = onLoadMore,
                            favoriteChannelIds = favoriteChannelIds,
                            onFavoriteToggle   = { toggleFav(it) },
                            onAssignEpg        = { channelForEpgOverride = it },
                            onVodClick         = { vodModalItem = it }
                        )
                    }
                }
            }  // end main Column
        }  // end Row sidebar+content

        // VOD/Series detail modal -- opened when a movie poster is selected.
        // Series posters bypass this and drill into the episode picker (handled
        // in the grid's onClick), so this only ever shows for movies.
        // VodInfoCard has no BackHandler of its own -- it expects the caller to
        // handle Back -- so we add one here, scoped to when the card is open.
        BackHandler(enabled = vodModalItem != null) { vodModalItem = null }
        vodModalItem?.let { modalItem ->
            VodInfoCard(
                item             = modalItem,
                isFavorite       = modalItem.id in favoriteVodIds,
                onToggleFavorite = { toggleVodFav(modalItem) },  // toggles + refreshes state; card stays open
                onPlay           = { onItemSelected(modalItem); vodModalItem = null },
                onBack           = { vodModalItem = null }
            )
        }

        // EPG override picker (Phase 2) -- opened from a channel's 3-dot menu.
        channelForEpgOverride?.let { ch ->
            val pid = activePortal?.id
            if (pid == null) {
                channelForEpgOverride = null
            } else {
                val overrideRepo = remember(pid) { com.kam.magplayer.epg.EpgOverrideRepository(context) }
                val currentKey = remember(ch.id, pid) { overrideRepo.getOverride(pid, ch.id) }
                EpgChannelPickerDialog(
                    channelName = ch.name,
                    allKeys     = remember { EpgRepository.xmlTvKeys() },
                    currentKey  = currentKey,
                    onSelect    = { key ->
                        if (key == null) {
                            overrideRepo.clearOverride(pid, ch.id)
                            EpgRepository.clearOverride(ch.id)
                        } else {
                            overrideRepo.setOverride(pid, ch.id, key)
                            EpgRepository.setOverride(ch.id, key)
                        }
                        channelForEpgOverride = null
                    },
                    onDismiss   = { channelForEpgOverride = null }
                )
            }
        }
    }
}

