// ── Resolved URL cache ────────────────────────────────────────────────────────
private object ResolvedUrlCache {
    private const val MAX_SIZE = 100
    private val map = LinkedHashMap<String, String>(MAX_SIZE, 0.75f, true)

    // Synchronized because get() runs on Dispatchers.IO (stream resolution)
    // while clear() runs on the main thread (onDestroyView). With
    // accessOrder=true this map mutates its internal links ON READ, so an
    // unsynchronized concurrent get/clear can corrupt the link structure.
    @Synchronized fun get(key: String): String? = map[key]

    @Synchronized fun put(key: String, value: String) {
        if (map.size >= MAX_SIZE) {
            map.iterator().let { it.next(); it.remove() }
        }
        map[key] = value
    }

    @Synchronized fun clear() = map.clear()
}

