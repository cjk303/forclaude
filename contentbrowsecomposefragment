// ─────────────────────────────────────────────────────────────────────────────
// Content list dispatcher
// ─────────────────────────────────────────────────────────────────────────────

@Composable
private fun ContentList(
    contentType:       ContentType,
    contentItems:      List<Any>,
    isLoading:         Boolean,
    loadingMessage:    String,
    focusRequester:    FocusRequester,
    searchFocused:     Boolean,
    categoryAccent:    Color,
    onItemSelected:    (Any) -> Unit,
    onChannelFocused:  (Channel) -> Unit,
    onVodItemFocused:  (VodItem) -> Unit,
    onLoadMore:        () -> Unit,
    favoriteChannelIds: Set<String> = emptySet(),
    onFavoriteToggle:  (Channel) -> Unit = {},
    onAssignEpg:       (Channel) -> Unit = {},
    onVodClick:        (VodItem) -> Unit = {}
) {
    when {
        isLoading && contentItems.isEmpty() -> {
            Box(modifier = Modifier.fillMaxSize(), contentAlignment = Alignment.Center) {
                Column(horizontalAlignment = Alignment.CenterHorizontally) {
                    CircularProgressIndicator(color = Color.White, strokeWidth = 3.dp, modifier = Modifier.size(48.dp))
                    Spacer(modifier = Modifier.height(20.dp))
                    Text(text = loadingMessage, color = Color.White, fontSize = 18.sp, fontWeight = FontWeight.Medium)
                }
            }
        }

        contentItems.isNotEmpty() -> {
            LaunchedEffect(contentItems, isLoading, searchFocused) {
                if (!isLoading && !searchFocused && contentItems.isNotEmpty()) {
                    yield()
                    when (val first = contentItems.first()) {
                        is Channel -> onChannelFocused(first)
                        is VodItem -> onVodItemFocused(first)
                    }
                    focusRequester.requestFocus()
                }
            }

            when (contentType) {
                ContentType.IPTV -> {
                    val listState = rememberLazyListState()
                    // Prefetch trigger as an event stream, not a composition
                    // side effect. snapshotFlow only emits when the last
                    // visible index actually changes, so this can't burst-fire
                    // on recomposition the way the old inline check could.
                    LaunchedEffect(listState, contentItems.size) {
                        snapshotFlow { listState.layoutInfo.visibleItemsInfo.lastOrNull()?.index ?: -1 }
                            .collect { lastVisible ->
                                if (lastVisible >= contentItems.size - 5) onLoadMore()
                            }
                    }
                    LazyColumn(
                        state = listState,
                        // focusGroup: bounds the 2D focus search at the
                        // container's edges instead of letting it enumerate
                        // beyond-bounds candidates (the ANR path).
                        modifier = Modifier.fillMaxSize().focusRequester(focusRequester).focusGroup(),

                        contentPadding        = PaddingValues(top = 12.dp, bottom = 32.dp),
                        verticalArrangement   = Arrangement.spacedBy(4.dp)
                    ) {
                        itemsIndexed(
                            contentItems,
                            key = { index, item ->
                                val id = when (item) { is Channel -> item.id; is VodItem -> item.id; else -> index.toString() }
                                "${index}_$id"
                            }
                        ) { index, item ->
                            if (item is Channel) {
                                ChannelListItem(
                                    channel        = item,
                                    onClick        = { onItemSelected(item) },
                                    onFocus        = { onChannelFocused(item) },
                                    categoryAccent = categoryAccent,
                                    isFavorite     = item.id in favoriteChannelIds,
                                    onLongClick    = { onFavoriteToggle(item) },
                                    onAssignEpg    = onAssignEpg
                                )
                            }
                        }
                    }
                }

                ContentType.VOD, ContentType.SERIES -> {
                    val gridState      = rememberLazyGridState()
                    val coroutineScope = rememberCoroutineScope()
                    // Keyed on contentItems: after a search/filter change the
                    // row indices shift, and a stale lastFocusedRow could
                    // suppress the scroll-into-view for the first focus.
                    var lastFocusedRow by remember(contentItems) { mutableStateOf(-1) }

                    LaunchedEffect(gridState, contentItems.size) {
                        snapshotFlow { gridState.layoutInfo.visibleItemsInfo.lastOrNull()?.index ?: -1 }
                            .collect { lastVisible ->
                                if (lastVisible >= contentItems.size - (POSTER_GRID_COLUMNS * 2)) onLoadMore()
                            }
                    }

                    LazyVerticalGrid(
                        columns               = GridCells.Fixed(POSTER_GRID_COLUMNS),
                        state                 = gridState,
                        modifier              = Modifier.fillMaxSize().focusRequester(focusRequester)
                            .focusProperties { canFocus = false },
                        contentPadding        = PaddingValues(top = 12.dp, bottom = 32.dp, start = 8.dp, end = 8.dp),
                        verticalArrangement   = Arrangement.spacedBy(10.dp),
                        horizontalArrangement = Arrangement.spacedBy(10.dp),
                    ) {
                        itemsIndexed(
                            contentItems,
                            key = { index, item ->
                                val id = when (item) { is VodItem -> item.id; is Channel -> item.id; else -> index.toString() }
                                "${index}_$id"
                            }
                        ) { index, item ->
                            if (item is VodItem) {
                                val currentRow = index / POSTER_GRID_COLUMNS
                                PosterCard(
                                    item        = item,
                                    accentColor = categoryAccent,
                                    onClick     = {
                                        // Movies open the detail modal; series keep
                                        // drilling into the episode picker (handled
                                        // by onItemSelected -> handleItemSelection).
                                        if (item.isSeries) onItemSelected(item)
                                        else onVodClick(item)
                                    },
                                    onFocus     = {
                                        onVodItemFocused(item)
                                        if (currentRow != lastFocusedRow) {
                                            lastFocusedRow = currentRow
                                            coroutineScope.launch {
                                                gridState.animateScrollToItem(index = currentRow * POSTER_GRID_COLUMNS, scrollOffset = 0)
                                            }
                                        }
                                    }
                                )
                            }
                        }
                    }
                }
            }
        }

        else -> {
            Box(modifier = Modifier.fillMaxSize(), contentAlignment = Alignment.Center) {
                Text("No content", color = Color(0xFF64748B), fontSize = 16.sp)
            }
        }
    }
}

// ─────────────────────────────────────────────────────────────────────────────
// Channel list item — D-pad RIGHT moves to ★ button, OK toggles favourite
// ─────────────────────────────────────────────────────────────────────────────

@OptIn(ExperimentalTvMaterial3Api::class)
@Composable
fun ChannelListItem(
    channel:        Channel,
    onClick:        () -> Unit,
    onFocus:        () -> Unit,
    categoryAccent: Color = Color(0xFF3B82F6),
    isFavorite:     Boolean = false,
    onLongClick:    () -> Unit = {},
    onAssignEpg:    (Channel) -> Unit = {}
) {
    val interactionSource = remember { MutableInteractionSource() }
    val isFocused by interactionSource.collectIsFocusedAsState()
    var starFocused by remember { mutableStateOf(false) }
    var menuFocused by remember { mutableStateOf(false) }

    val channelAccent = remember(channel.name) {
        val prefix = contentExtractPrefix(channel.name)
        if (prefix.isNotEmpty()) contentRegionColors[prefix] ?: categoryAccent else categoryAccent
    }
    val (prefix, displayName) = remember(channel.name) { contentStripPrefix(channel.name) }

    val rowFocused = isFocused || starFocused || menuFocused

    Row(
        modifier = Modifier
            .fillMaxWidth()
            .height(48.dp)
            .clip(RoundedCornerShape(6.dp))
            .background(if (rowFocused) Color.Black.copy(alpha = 0.7f) else Color.Black.copy(alpha = 0.5f))
            .border(
                width = if (rowFocused) 2.dp else 1.dp,
                color = if (rowFocused) channelAccent else Color.White.copy(alpha = 0.1f),
                shape = RoundedCornerShape(6.dp)
            ),
        verticalAlignment = Alignment.CenterVertically
    ) {
        Box(modifier = Modifier.width(3.dp).fillMaxHeight()
            .background(if (rowFocused) channelAccent else channelAccent.copy(alpha = 0.4f)))

        Surface(
            onClick = onClick,
            modifier = Modifier
                .weight(1f)
                .fillMaxHeight()
                .onFocusChanged { if (it.isFocused) onFocus() },
            interactionSource = interactionSource,
            shape  = ClickableSurfaceDefaults.shape(RoundedCornerShape(0.dp)),
            scale  = ClickableSurfaceDefaults.scale(focusedScale = 1.0f, pressedScale = 0.98f),
            colors = ClickableSurfaceDefaults.colors(
                containerColor        = Color.Transparent,
                focusedContainerColor = Color.Transparent
            ),
            border = ClickableSurfaceDefaults.border(
                border        = Border(BorderStroke(0.dp, Color.Transparent)),
                focusedBorder = Border(BorderStroke(0.dp, Color.Transparent))
            )
        ) {
            Row(
                modifier = Modifier.fillMaxSize().padding(start = 10.dp),
                verticalAlignment = Alignment.CenterVertically
            ) {
                ChannelLogo(
                    channel = channel,
                    accent = channelAccent,
                    modifier = Modifier.size(28.dp).clip(CircleShape)
                )
                Spacer(modifier = Modifier.width(10.dp))
                if (prefix.isNotEmpty()) {
                    Text(
                        text       = prefix,
                        fontSize   = 10.sp,
                        fontWeight = FontWeight.Bold,
                        color      = channelAccent,
                        modifier   = Modifier
                            .clip(RoundedCornerShape(3.dp))
                            .background(channelAccent.copy(alpha = 0.12f))
                            .padding(horizontal = 5.dp, vertical = 2.dp)
                    )
                    Spacer(modifier = Modifier.width(8.dp))
                }
                Text(
                    text       = if (prefix.isNotEmpty()) displayName else channel.name,
                    modifier   = Modifier.weight(1f),
                    fontSize   = 14.sp,
                    fontWeight = if (rowFocused) FontWeight.SemiBold else FontWeight.Normal,
                    color      = if (rowFocused) Color.White else Color(0xFFCBD5E1),
                    maxLines   = 1,
                    overflow   = TextOverflow.Ellipsis
                )
            }
        }

        // ★ Favourite button — D-pad RIGHT from channel focuses this, OK toggles
        Surface(
            onClick = onLongClick,
            modifier = Modifier
                .width(44.dp)
                .fillMaxHeight()
                .onFocusChanged { starFocused = it.isFocused },
            shape  = ClickableSurfaceDefaults.shape(RoundedCornerShape(topEnd = 6.dp, bottomEnd = 6.dp)),
            scale  = ClickableSurfaceDefaults.scale(focusedScale = 1.0f),
            colors = ClickableSurfaceDefaults.colors(
                containerColor        = Color.Transparent,
                focusedContainerColor = Color(0xFFFBBF24).copy(alpha = 0.15f)
            ),
            border = ClickableSurfaceDefaults.border(
                border        = Border(BorderStroke(0.dp, Color.Transparent)),
                focusedBorder = Border(BorderStroke(0.dp, Color.Transparent))
            )
        ) {
            Box(contentAlignment = Alignment.Center, modifier = Modifier.fillMaxSize()) {
                Text(
                    text     = if (isFavorite) "★" else "☆",
                    fontSize = 16.sp,
                    color    = when {
                        isFavorite  -> Color(0xFFFBBF24)
                        starFocused -> Color(0xFFFBBF24).copy(alpha = 0.8f)
                        rowFocused  -> Color.White.copy(alpha = 0.4f)
                        else        -> Color.White.copy(alpha = 0.15f)
                    }
                )
            }
        }

        // 3-dot menu -- "EPG override" assigns this channel a guide source.
        RowActionMenu(
            items = listOf(
                RowAction(
                    label = "EPG override",
                    onClick = { onAssignEpg(channel) }
                )
            ),
            onFocusChange = { menuFocused = it },
            cornerEnd = 6.dp,
            tint = channelAccent
        )
    }
}

// ─────────────────────────────────────────────────────────────────────────────
// VOD poster card
// ─────────────────────────────────────────────────────────────────────────────

@OptIn(ExperimentalTvMaterial3Api::class)
@Composable
fun PosterCard(
    item:        VodItem,
    onClick:     () -> Unit,
    onFocus:     () -> Unit,
    accentColor: Color = Color(0xFF3B82F6)
) {
    val interactionSource = remember { MutableInteractionSource() }
    val isFocused by interactionSource.collectIsFocusedAsState()

    val scale by animateFloatAsState(
        targetValue = if (isFocused) 1.03f else 1f,
        animationSpec = spring(stiffness = Spring.StiffnessMediumLow),
        label = "poster_scale"
    )

    Card(
        onClick           = onClick,
        interactionSource = interactionSource,
        modifier          = Modifier
            .padding(3.dp)
            .graphicsLayer { scaleX = scale; scaleY = scale }
            .onFocusChanged { if (it.isFocused) onFocus() },
        shape  = CardDefaults.shape(RoundedCornerShape(12.dp)),
        colors = CardDefaults.colors(
            containerColor        = Color.Black.copy(alpha = 0.5f),
            focusedContainerColor = Color.Black.copy(alpha = 0.5f)
        ),
        border = CardDefaults.border(
            border        = Border(border = BorderStroke(1.dp, Color.Transparent), shape = RoundedCornerShape(12.dp)),
            focusedBorder = Border(border = BorderStroke(2.dp, accentColor),       shape = RoundedCornerShape(12.dp))
        ),
        scale  = CardDefaults.scale(focusedScale = 1.0f, pressedScale = 0.98f)
    ) {
        Column(
            horizontalAlignment = Alignment.CenterHorizontally,
            modifier            = Modifier.padding(8.dp)
        ) {
            AsyncImage(
                model = coil.request.ImageRequest.Builder(LocalContext.current)
                    .data(item.poster)
                    .size(300, 450)
                    .allowHardware(DeviceInfo.allowHardwareBitmaps)
                    .build(),
                contentDescription = item.name,
                placeholder        = ColorPainter(Color(0xFF808080).copy(alpha = 0.3f)),
                error              = ColorPainter(Color(0xFF808080).copy(alpha = 0.3f)),
                modifier           = Modifier.aspectRatio(2f / 3f).fillMaxWidth().clip(RoundedCornerShape(8.dp)),
                contentScale       = ContentScale.Crop
            )
            Spacer(modifier = Modifier.height(8.dp))
            Text(
                text       = item.name,
                fontSize   = 12.sp,
                color      = if (isFocused) Color.White else Color(0xFFCBD5E1),
                fontWeight = if (isFocused) FontWeight.SemiBold else FontWeight.Normal,
                maxLines   = 2,
                overflow   = TextOverflow.Ellipsis,
                textAlign  = TextAlign.Center
            )
        }
    }
}
