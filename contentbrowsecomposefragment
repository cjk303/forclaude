@Composable
private fun ChannelLogo(
    channel: Channel,
    accent: Color,
    modifier: Modifier = Modifier
) {
    val primary = channel.logo?.takeIf { it.startsWith("http") }

    // Reactive EPG-icon fallback. A plain remember { iconFor() } evaluated
    // ONCE at first composition -- before the XMLTV (and its icons) had
    // loaded -- and froze the null result, so rows composed during the EPG
    // download never got their fallback logo. (Same bug fixed in the player
    // overlay's ChannelRow in 1.3.7; the TTL fix made it visible here by
    // delaying icon publication behind a real network download.)
    // xmltvVersion bumps right after putXmlTvIcons in the same load pass,
    // so re-resolving on it picks the icons up the moment they exist.
    val xmltvVersion by EpgRepository.xmltvVersion.collectAsState()
    var fallback by remember(channel.id) { mutableStateOf<String?>(null) }
    LaunchedEffect(channel.id, xmltvVersion) {
        fallback = withContext(Dispatchers.Default) { EpgRepository.iconFor(channel) }
    }

    // Step through: primary -> EPG icon -> letter badge.
    // stage 0 = try primary, 1 = try EPG fallback, 2 = letter badge
    var stage by remember(channel.id) { mutableStateOf(if (primary != null) 0 else 1) }

    val model = when (stage) {
        0 -> primary
        1 -> fallback
        else -> null
    }

    if (model == null) {
        Box(
            modifier = modifier.background(accent.copy(alpha = 0.9f)),
            contentAlignment = Alignment.Center
        ) {
            Text(
                text = channel.name.trim().firstOrNull { it.isLetterOrDigit() }?.uppercase() ?: "?",
                color = Color.White,
                fontSize = 12.sp,
                fontWeight = FontWeight.Bold
            )
        }
    } else {
        AsyncImage(
            model = coil.request.ImageRequest.Builder(LocalContext.current)
                .data(model)
                .size(84, 84)
                .allowHardware(DeviceInfo.allowHardwareBitmaps)
                .build(),
            contentDescription = channel.name,
            onError = { stage++ },   // this source failed -> advance to the next
            modifier = modifier,
            contentScale = ContentScale.Crop
        )
    }
}
private val contentDefaultAccent = Color(0xFF64748B)

private fun contentExtractPrefix(name: String): String {
    val pipeIdx = name.indexOf('|')
    if (pipeIdx > 0) return name.substring(0, pipeIdx).trim().uppercase()
    val firstWord = name.substringBefore(' ').trim().uppercase()
    return if (contentRegionColors.containsKey(firstWord)) firstWord else ""
}

private fun contentAccentFor(name: String): Color {
    val prefix = contentExtractPrefix(name)
    return contentRegionColors[prefix] ?: contentDefaultAccent
}

private fun contentStripPrefix(name: String): Pair<String, String> {
    val pipeIdx = name.indexOf('|')
    return if (pipeIdx > 0) {
        val prefix = name.substring(0, pipeIdx).trim()
        val rest   = name.substring(pipeIdx + 1).trim()
        prefix to rest
    } else {
        val firstWord = name.substringBefore(' ').trim()
        if (contentRegionColors.containsKey(firstWord.uppercase()))
            firstWord to name.substring(firstWord.length).trim()
        else "" to name
    }
}

