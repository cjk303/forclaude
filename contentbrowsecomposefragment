@Composable
private fun RightPane(
    channel:     Channel,
    streamUrl:   String?,
    epgLoading:  Boolean = false,
    accentColor: Color   = Color(0xFF3B82F6)
) {
    val formatter    = remember { SimpleDateFormat("HH:mm", Locale.getDefault()) }
    val xmltvVersion by EpgRepository.xmltvVersion.collectAsState()
    val stalkerVersion by EpgRepository.stalkerEpgVersion.collectAsState()

    var epgEvents by remember { mutableStateOf<Pair<com.kam.magplayer.epg.StalkerEpgEvent?, com.kam.magplayer.epg.StalkerEpgEvent?>>(null to null) }
    LaunchedEffect(channel.id, xmltvVersion, stalkerVersion) {
        val result = withContext(Dispatchers.Default) {
            EpgRepository.getBestEpg(channel)
        }
        epgEvents = result
    }
    val (nowEvent, nextEvent) = epgEvents

    Column(
        Modifier
            .fillMaxSize()
            .clip(RoundedCornerShape(12.dp))
            .background(Color.Black.copy(alpha = 0.5f))
            .border(1.dp, Color.White.copy(alpha = 0.1f), RoundedCornerShape(12.dp))
            .padding(16.dp)
    ) {
        Box(
            Modifier
                .fillMaxWidth()
                .aspectRatio(16f / 9f)
                .clip(RoundedCornerShape(8.dp))
                .background(Color.Black)
        ) {
            key(channel.id) {
                MiniPlayer(streamUrl = streamUrl, modifier = Modifier.fillMaxSize())
            }

            if (nowEvent != null) {
                val nowSec   = System.currentTimeMillis() / 1000
                val progress = ((nowSec - nowEvent.start).toFloat() /
                        (nowEvent.end - nowEvent.start).toFloat()).coerceIn(0f, 1f)
                val timeRange = "${formatter.format(Date(nowEvent.start * 1000))} – " +
                        formatter.format(Date(nowEvent.end * 1000))

                Column(
                    modifier = Modifier
                        .fillMaxWidth()
                        .align(Alignment.BottomStart)
                        .background(
                            Brush.verticalGradient(
                                colors = listOf(Color.Transparent, Color.Black.copy(alpha = 0.85f))
                            )
                        )
                        .padding(horizontal = 12.dp, vertical = 8.dp)
                ) {
                    Row(modifier = Modifier.fillMaxWidth(), verticalAlignment = Alignment.CenterVertically) {
                        Text(
                            text       = nowEvent.title,
                            color      = Color.White,
                            fontSize   = 13.sp,
                            fontWeight = FontWeight.SemiBold,
                            maxLines   = 1,
                            overflow   = TextOverflow.Ellipsis,
                            modifier   = Modifier.weight(1f)
                        )
                        Spacer(Modifier.width(8.dp))
                        Text(text = timeRange, color = accentColor, fontSize = 11.sp, fontWeight = FontWeight.Medium)
                    }
                    Spacer(Modifier.height(4.dp))
                    LinearProgressIndicator(
                        progress   = { progress },
                        modifier   = Modifier.fillMaxWidth().height(3.dp).clip(RoundedCornerShape(2.dp)),
                        color      = accentColor,
                        trackColor = Color.White.copy(alpha = 0.2f)
                    )
                }
            }
        }

        Spacer(Modifier.height(12.dp))

        if (nowEvent != null && nowEvent.description.isNotBlank()) {
            Text(text = nowEvent.description, color = Color(0xFFAAAAAA), fontSize = 12.sp,
                maxLines = 3, overflow = TextOverflow.Ellipsis)
            Spacer(Modifier.height(8.dp))
        }

        if (nextEvent != null) {
            Text(text = "Next: ${nextEvent.title}", color = Color(0xFF94A3B8), fontSize = 12.sp,
                maxLines = 1, overflow = TextOverflow.Ellipsis)
            Text(text = formatter.format(Date(nextEvent.start * 1000)), color = accentColor, fontSize = 11.sp)
        }

        if (nowEvent == null) {
            if (epgLoading) {
                Row(verticalAlignment = Alignment.CenterVertically) {
                    CircularProgressIndicator(modifier = Modifier.size(12.dp), color = Color(0xFF64748B), strokeWidth = 1.5.dp)
                    Spacer(Modifier.width(8.dp))
                    Text(text = "Loading guide…", color = Color(0xFF64748B), fontSize = 12.sp)
                }
            } else {
                Text(text = stringResource(id = R.string.no_program_information), color = Color(0xFF64748B), fontSize = 13.sp)
            }
        }
    }
}

