    private fun loadContentInitial() {
        val type  = contentType ?: return
        val catId = categoryId  ?: return

        // Paging state must not survive a reload. A stale reachedEnd=true
        // from a previous life of this fragment (back stack restore, error
        // path) would silently kill pagination for the new content.
        reachedEnd     = false
        isPageLoading  = false
        nextPageToLoad = 0

        isLoading      = true
        loadingMessage = getString(R.string.loading)

        viewLifecycleOwner.lifecycleScope.launch(Dispatchers.IO) {
            if (activePortal == null) {
                val repo = PortalRepository(requireContext())
                val portal = repo.getPortals().find { it.id == repo.getActivePortalId() }
                withContext(Dispatchers.Main) { activePortal = portal }
                portal?.let { p ->
                    when {
                        p.isXtream -> xtreamClient = XtreamClient(p.effectiveUrl, p.username, p.password)
                        p.isM3U    -> { /* no client needed */ }
                        else       -> {
                            stalkerClient = StalkerClient(p.effectiveUrl, p.macAddress)
                            vodClient     = VodClient(p.effectiveUrl, p.macAddress)
                        }
                    }
                }
            }

            val portal = activePortal ?: run {
                withContext(Dispatchers.Main) { isLoading = false }
                return@launch
            }
            val cache = PortalCache.get(portal.id)
            val cachedItems: List<Any> = when (type) {
                ContentType.IPTV -> {
                    val pageMap = cache.channelPagesByGenre[catId]
                    if (pageMap != null && pageMap.isNotEmpty()) {
                        val sorted = pageMap.keys.sorted()
                        nextPageToLoad = (sorted.maxOrNull() ?: 0) + 1
                        sorted.flatMap { pageMap[it].orEmpty() }
                    } else { nextPageToLoad = 1; emptyList() }
                }
                ContentType.VOD -> {
                    val pageMap = cache.vodPagesByCategory[catId]
                    if (pageMap != null && pageMap.isNotEmpty()) {
                        val sorted = pageMap.keys.sorted()
                        nextPageToLoad = (sorted.maxOrNull() ?: 0) + 1
                        sorted.flatMap { pageMap[it].orEmpty() }
                    } else { nextPageToLoad = 1; emptyList() }
                }
                ContentType.SERIES -> {
                    val pageMap = cache.seriesPagesByCategory[catId]
                    if (pageMap != null && pageMap.isNotEmpty()) {
                        val sorted = pageMap.keys.sorted()
                        nextPageToLoad = (sorted.maxOrNull() ?: 0) + 1
                        sorted.flatMap { pageMap[it].orEmpty() }
                    } else { nextPageToLoad = 1; emptyList() }
                }
            }

            withContext(Dispatchers.Main) {
                if (cachedItems.isNotEmpty()) {
                    allContent.clear()
                    allContent.addAll(cachedItems)
                    isLoading      = false
                    loadingMessage = ""
                }
            }

            if (cachedItems.isEmpty()) {
                loadPage(type, portal, cache, catId, nextPageToLoad, append = false)
            } else if (type == ContentType.IPTV) {
                prefetchEpgForChannels(portal, cachedItems.filterIsInstance<Channel>())
            }
        }
    }

    private fun requestNextPage() {
        val portal = activePortal ?: return
        val type   = contentType  ?: return
        val catId  = categoryId   ?: return
        if (reachedEnd || isPageLoading) return
        // Claim BEFORE launching. The old code claimed inside loadPage on
        // the IO thread, leaving a window where two rapid onLoadMore calls
        // both passed the guard and both launched a page load.
        isPageLoading = true

        val cache = PortalCache.get(portal.id)
        viewLifecycleOwner.lifecycleScope.launch(Dispatchers.IO) {
            loadPage(type, portal, cache, catId, nextPageToLoad,
                append = allContent.isNotEmpty(), preClaimed = true)
        }
    }

    private suspend fun loadPage(
        type:       ContentType,
        portal:     Portal,
        cache:      PortalMemoryCache,
        catId:      String,
        page:       Int,
        append:     Boolean,
        retryCount: Int = 0,
        preClaimed: Boolean = false
    ) {
        // preClaimed = true when the caller already set isPageLoading
        // (requestNextPage's synchronous claim, or the retry recursion
        // below -- which under the old guard ALWAYS bailed out instantly,
        // because the outer call still held isPageLoading=true, so the
        // retry never actually ran and a failed page left an infinite
        // spinner).
        if (reachedEnd) {
            if (preClaimed) isPageLoading = false
            return
        }
        if (!preClaimed && isPageLoading) return
        isPageLoading = true

        withContext(Dispatchers.Main) {
            loadingMessage = getString(R.string.loading_page, page)
            if (!append) isLoading = true
        }

        try {
            val items: List<Any> = when (type) {
                ContentType.IPTV -> {
                    when {
                        portal.isM3U -> {
                            val channels = M3uCache.loadChannelsForCategory(
                                requireContext(), portal.effectiveUrl, catId, ContentType.IPTV
                            ) ?: emptyList()
                            if (channels.isEmpty()) { reachedEnd = true; emptyList() }
                            else {
                                val pageMap = cache.getOrPutChannelPage(catId)
                                pageMap[1] = channels; reachedEnd = true
                                prefetchEpgForChannels(portal, channels); channels
                            }
                        }
                        portal.isXtream -> {
                            val client = xtreamClient ?: XtreamClient(portal.effectiveUrl, portal.username, portal.password)
                                .also { xtreamClient = it }
                            val channels = client.getLiveStreams(catId)
                            if (channels.isEmpty()) { reachedEnd = true; emptyList() }
                            else {
                                val pageMap = cache.getOrPutChannelPage(catId)
                                pageMap[1] = channels; reachedEnd = true
                                prefetchEpgForChannels(portal, channels); channels
                            }
                        }
                        else -> {
                            val client = stalkerClient ?: StalkerClient(portal.effectiveUrl, portal.macAddress)
                                .also { stalkerClient = it }
                            val pageResult = client.getChannelsPage(catId, page, limit = 2000)
                            val channels   = pageResult.channels
                            if (channels.isEmpty()) { reachedEnd = true; emptyList() }
                            else {
                                val pageMap = cache.getOrPutChannelPage(catId)
                                pageMap[page] = channels
                                if (pageResult.totalItems > 0)
                                    cache.channelCountByGenre[catId] = pageResult.totalItems
                                prefetchEpgForChannels(portal, channels); channels
                            }
                        }
                    }
                }

                ContentType.VOD -> {
                    when {
                        portal.isM3U -> {
                            val channels = M3uCache.loadChannelsForCategory(
                                requireContext(), portal.effectiveUrl, catId, ContentType.VOD
                            ) ?: emptyList()
                            val vodItems = channels.map { ch ->
                                VodItem(id = ch.id, name = ch.name, poster = ch.logo,
                                    description = "", year = "", cmd = ch.cmd, isSeries = false, isMovie = true)
                            }
                            if (vodItems.isEmpty()) { reachedEnd = true; emptyList() }
                            else {
                                val pageMap = cache.getOrPutVodPage(catId)
                                pageMap[1] = vodItems; reachedEnd = true; vodItems
                            }
                        }
                        portal.isXtream -> {
                            val client = xtreamClient ?: XtreamClient(portal.effectiveUrl, portal.username, portal.password)
                                .also { xtreamClient = it }
                            val items = client.getVodStreams(catId)
                            if (items.isEmpty()) { reachedEnd = true; emptyList() }
                            else {
                                val pageMap = cache.getOrPutVodPage(catId)
                                pageMap[1] = items; reachedEnd = true; items
                            }
                        }
                        else -> {
                            val client = vodClient ?: VodClient(portal.effectiveUrl, portal.macAddress)
                                .also { vodClient = it }
                            val pageResult = client.getVodItems(catId, page)
                            if (pageResult.items.isEmpty()) { reachedEnd = true; emptyList() }
                            else {
                                val pageMap = cache.getOrPutVodPage(catId)
                                pageMap[page] = pageResult.items
                                if (pageResult.totalItems > 0)
                                    cache.vodCountByCategory[catId] = pageResult.totalItems
                                pageResult.items
                            }
                        }
                    }
                }

                ContentType.SERIES -> {
                    when {
                        portal.isM3U -> {
                            val channels = M3uCache.loadChannelsForCategory(
                                requireContext(), portal.effectiveUrl, catId, ContentType.SERIES
                            ) ?: emptyList()
                            val seriesItems = channels.map { ch ->
                                VodItem(id = ch.id, name = ch.name, poster = ch.logo,
                                    description = "", year = "", cmd = ch.cmd, isSeries = true, isMovie = false)
                            }
                            if (seriesItems.isEmpty()) { reachedEnd = true; emptyList() }
                            else {
                                val pageMap = cache.getOrPutSeriesPage(catId)
                                pageMap[1] = seriesItems; reachedEnd = true; seriesItems
                            }
                        }
                        portal.isXtream -> {
                            val client = xtreamClient ?: XtreamClient(portal.effectiveUrl, portal.username, portal.password)
                                .also { xtreamClient = it }
                            val items = client.getSeries(catId)
                            if (items.isEmpty()) { reachedEnd = true; emptyList() }
                            else {
                                val pageMap = cache.getOrPutSeriesPage(catId)
                                pageMap[1] = items; reachedEnd = true; items
                            }
                        }
                        else -> {
                            val client = vodClient ?: VodClient(portal.effectiveUrl, portal.macAddress)
                                .also { vodClient = it }
                            val pageResult = client.getSeriesList(catId, page)
                            if (pageResult.items.isEmpty()) { reachedEnd = true; emptyList() }
                            else {
                                val pageMap = cache.getOrPutSeriesPage(catId)
                                pageMap[page] = pageResult.items
                                if (pageResult.totalItems > 0)
                                    cache.seriesCountByCategory[catId] = pageResult.totalItems
                                pageResult.items
                            }
                        }
                    }
                }
            }

            withContext(Dispatchers.Main) {
                if (items.isNotEmpty()) {
                    if (!append) allContent.clear()
                    allContent.addAll(items)
                    nextPageToLoad = page + 1
                } else {
                    reachedEnd = true
                }
                isLoading      = false
                loadingMessage = ""
            }
        } catch (e: Exception) {
            if (retryCount < 1) {
                Log.e("CONTENT_PAGING", "Failed to load page $page — ${e.message}, retrying in 2s")
                kotlinx.coroutines.delay(2000)
                loadPage(type, portal, cache, catId, page, append, retryCount + 1, preClaimed = true)
            } else {
                Log.e("CONTENT_PAGING", "Retry also failed for page $page — ${e.message}")
                withContext(Dispatchers.Main) {
                    isLoading      = false
                    loadingMessage = getString(R.string.loading_error)
                }
            }
        } finally {
            isPageLoading = false
        }
    }

    private suspend fun prefetchEpgForChannels(portal: Portal, channels: List<Channel>) {
        try {
            val channelsToPreload = channels.take(20)
            kotlinx.coroutines.coroutineScope {
                if (portal.isXtream) {
                    val baseUrl  = portal.effectiveUrl
                    val username = portal.username.ifBlank { return@coroutineScope }
                    val password = portal.password.ifBlank { return@coroutineScope }
                    channelsToPreload.forEach { ch ->
                        launch {
                            val streamId = XtreamEpgClient.extractStreamId(ch.cmd) ?: return@launch
                            if (EpgRepository.getXtreamEvents(streamId).isNotEmpty()) return@launch
                            try {
                                val events = XtreamEpgClient.getShortEpg(baseUrl, username, password, streamId)
                                if (events.isNotEmpty()) EpgRepository.putXtreamEvents(streamId, events)
                            } catch (_: Exception) {}
                        }
                    }
                } else if (portal.isM3U) {
                    val uri      = android.net.Uri.parse(portal.effectiveUrl)
                    val baseUrl  = "${uri.scheme}://${uri.host}:${uri.port}"
                    val username = uri.getQueryParameter("username") ?: return@coroutineScope
                    val password = uri.getQueryParameter("password") ?: return@coroutineScope
                    channelsToPreload.forEach { ch ->
                        launch {
                            val streamId = XtreamEpgClient.extractStreamId(ch.cmd) ?: return@launch
                            if (EpgRepository.getXtreamEvents(streamId).isNotEmpty()) return@launch
                            try {
                                val events = XtreamEpgClient.getShortEpg(baseUrl, username, password, streamId)
                                if (events.isNotEmpty()) EpgRepository.putXtreamEvents(streamId, events)
                            } catch (_: Exception) {}
                        }
                    }
                } else {
                    Log.d("EPG_PREFETCH", "Stalker prefetch via MagEpg: ${channelsToPreload.size} channels")
                    channelsToPreload.forEach { ch ->
                        val key = ch.id.toString()
                        if (EpgRepository.getStalkerEvents(key).isEmpty()) {
                            MagEpg.request(key)
                        }
                    }
                }
            }
        } catch (_: Exception) {}
    }

    private fun handleItemSelection(item: Any) {
        when (item) {
            is Channel -> playIptvChannel(item)
            is VodItem -> {
                if (item.isSeries) {
                    val portal = activePortal
                    if (portal != null && portal.isM3U) playVodMovie(item)
                    else {
                        tvGoDrillDown(SeriesBrowseFragment.newInstance(item))
                    }
                } else {
                    playVodMovie(item)
                }
            }
        }
    }

    private fun playIptvChannel(channel: Channel) {
        val portal = activePortal ?: return
        val catId  = categoryId   ?: return

        viewLifecycleOwner.lifecycleScope.launch(Dispatchers.Default) {
            val allChannels  = allContent.filterIsInstance<Channel>()
            val currentIndex = allChannels.indexOf(channel)

            withContext(Dispatchers.Main) {
                if (currentIndex == -1) {
                    android.widget.Toast.makeText(requireContext(), "Channel not found", android.widget.Toast.LENGTH_SHORT).show()
                    return@withContext
                }

                val cache = PortalCache.get(portal.id)
                val catList: List<Pair<String, String>> = when (contentType) {
                    ContentType.IPTV   -> cache.genres.map { it.id to it.title }
                    ContentType.VOD    -> cache.vodCategories.map { it.id to it.title }
                    ContentType.SERIES -> cache.seriesCategories.map { it.id to it.title }
                    else               -> emptyList()
                }
                val catIds   = catList.map { it.first }.toTypedArray()
                val catNames = catList.map { it.second }.toTypedArray()

                val intent = Intent(requireContext(), PlayerActivity::class.java).apply {
                    putExtra("PORTAL_URL",    portal.effectiveUrl)
                    putExtra("MAC_ADDRESS",   portal.macAddress)
                    putExtra("PORTAL_ID",     portal.id)
                    putExtra("CATEGORY_ID",   catId)
                    putExtra("CATEGORY_NAME", categoryName ?: "")
                    putExtra("CONTENT_TYPE",  contentType?.name ?: ContentType.IPTV.name)
                    putExtra("CURRENT_INDEX", currentIndex)
                    putExtra("EPG_URL",       portal.epgUrl.orEmpty())
                    putExtra("FILTER",        searchQuery)
                    putStringArrayListExtra("CAT_IDS",   ArrayList(catIds.toList()))
                    putStringArrayListExtra("CAT_NAMES", ArrayList(catNames.toList()))
                    if (portal.isXtream) {
                        putExtra("IS_XTREAM",       true)
                        putExtra("XTREAM_USERNAME", portal.username)
                        putExtra("XTREAM_PASSWORD", portal.password)
                    }
                }
                playerLauncher.launch(intent)
            }
        }
    }

    private fun playVodMovie(item: VodItem) {
        val portal = activePortal ?: return

        if (portal.isM3U || portal.isXtream) {
            val intent = Intent(requireContext(), PlayerActivity::class.java).apply {
                putExtra("VIDEO_URL",   item.cmd)
                putExtra("VIDEO_ID",    item.id)
                putExtra("TITLE",       item.name)
                putExtra("PORTAL_URL",  portal.effectiveUrl)
                putExtra("MAC_ADDRESS", portal.macAddress)
            }
            startActivity(intent)
            return
        }

        viewLifecycleOwner.lifecycleScope.launch(Dispatchers.IO) {
            val client = vodClient ?: VodClient(portal.effectiveUrl, portal.macAddress).also { vodClient = it }
            try {
                val vodFile = client.getVodFile(item)
                withContext(Dispatchers.Main) {
                    val intent = Intent(requireContext(), PlayerActivity::class.java).apply {
                        putExtra("VIDEO_URL",   vodFile.cmd)
                        putExtra("VIDEO_ID",    item.id)
                        putExtra("TITLE",       item.name)
                        putExtra("PORTAL_URL",  portal.effectiveUrl)
                        putExtra("MAC_ADDRESS", portal.macAddress)
                    }
                    startActivity(intent)
                }
            } catch (e: Exception) {
                Log.e("VOD_PLAY", "Failed to resolve VOD URL for ${item.name}", e)
            }
        }
    }

    companion object {
        private const val ARG_CONTENT_TYPE  = "content_type"
        private const val ARG_CATEGORY_ID   = "category_id"
        private const val ARG_CATEGORY_NAME = "category_name"

        fun newInstance(
            contentType:  ContentType,
            categoryId:   String,
            categoryName: String
        ): ContentBrowseComposeFragment {
            return ContentBrowseComposeFragment().apply {
                arguments = Bundle().apply {
                    putSerializable(ARG_CONTENT_TYPE, contentType)
                    putString(ARG_CATEGORY_ID,        categoryId)
                    putString(ARG_CATEGORY_NAME,      categoryName)
                }
            }
        }
    }
}

