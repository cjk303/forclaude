@OptIn(ExperimentalTvMaterial3Api::class)
@Composable
private fun SearchBar(
    searchQuery: String,
    onSearchQueryChanged: (String) -> Unit,
    onFocusChanged: (Boolean) -> Unit,
    accentColor: Color = Color(0xFF3B82F6),
    downFocusRequester: FocusRequester? = null
) {
    var searchFocused by remember { mutableStateOf(false) }

    Box(
        modifier = Modifier
            .fillMaxWidth()
            .clip(RoundedCornerShape(8.dp))
            .background(Color.Black.copy(alpha = 0.5f))
            .border(
                width = if (searchFocused) 2.dp else 1.dp,
                color = if (searchFocused) accentColor else Color.White.copy(alpha = 0.15f),
                shape = RoundedCornerShape(8.dp)
            )
    ) {
        TextField(
            value         = searchQuery,
            onValueChange = onSearchQueryChanged,
            placeholder   = {
                Text(stringResource(id = R.string.search_label), color = Color.White.copy(alpha = 0.4f))
            },
            modifier = Modifier
                .fillMaxWidth()
                // ANR fix: DOWN from search used to trigger Compose's
                // beyond-bounds focus search, which synchronously composes
                // and measures grid items beyond the viewport hunting for a
                // landing target -- two Play Console ANRs on weak boxes,
                // both entering via the IME path. Pinning DOWN to the list
                // container skips the hunt entirely.
                .focusProperties { downFocusRequester?.let { fr -> down = fr } }
                .onFocusChanged {
                    searchFocused = it.isFocused
                    onFocusChanged(it.isFocused)
                },
            singleLine = true,
            textStyle  = TextStyle(color = Color.White, fontSize = 15.sp, letterSpacing = 0.3.sp),
            colors     = TextFieldDefaults.colors(
                focusedContainerColor   = Color.Transparent,
                unfocusedContainerColor = Color.Transparent,
                disabledContainerColor  = Color.Transparent,
                focusedIndicatorColor   = Color.Transparent,
                unfocusedIndicatorColor = Color.Transparent,
                disabledIndicatorColor  = Color.Transparent,
                cursorColor             = accentColor
            )
        )
    }
}

