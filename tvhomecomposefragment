// ============================================================================
// SECTION 5 -- PORTAL DATA LOADER
//
// Pure suspend functions, one entry point per portal type. Each returns a
// Result that the ViewModel folds into HomeUiState. No Compose, no
// LaunchedEffect, no main-thread surprises -- testable in isolation.
// ============================================================================

internal class PortalDataLoader(
    private val context: Context,
    private val viewModel: TvHomeViewModel
) {
    data class StatsAndItems(
        val stats: PortalStats,
        val items: List<ContinueWatchingItem>
    )

    // ------------------------------------------------------------------------
    // Recommendation visibility filter (#1a)
    //
    // Categories the user hid via the dots-menu "Hide" -- or excluded via the
    // keyword filter -- must not feed the home "Recommended" row. Built fresh
    // per call so a freshly-hidden category takes effect on the next home
    // refresh (the repo caches internally and this loader can outlive a hide).
    // ------------------------------------------------------------------------
    private fun categoryVisibilityPredicate(): (String) -> Boolean {
        val repo = CategoryFilterRepository(context)
        return { title -> repo.shouldShowCategory(title) }
    }

    /**
     * Loads recent channels and favourite channels from local storage for a
     * given portal. Always disk-only -- safe to call as soon as the portal is
     * known, before any network handshake completes.
     */
    suspend fun loadLocalChannels(portal: Portal): Pair<List<Channel>, List<Channel>> =
        withContext(Dispatchers.IO) {
            val historyKey = portal.id.ifBlank { portal.macAddress }
            val recent = HistoryRepository(context).getRecentlyWatched(historyKey).take(20)
            val favs = FavoriteChannelsRepository(context).getFavoriteChannels(portal.id)
            recent to favs
        }

    /**
     * Pre-warm Coil's memory cache for visible channel logos so the first
     * render is hit-cached and doesn't flash placeholder colours.
     */
    suspend fun prewarmLogos(channels: List<Channel>) = withContext(Dispatchers.IO) {
        val urls = channels.mapNotNull { it.logo?.takeIf { l -> l.startsWith("http") } }
            .distinct().take(20)
        val loader = context.imageLoader          // <-- Coil singleton, shared with AsyncImage/coil.load
        urls.forEach { url ->
            val req = ImageRequest.Builder(context).data(url).size(240, 160)
                .allowHardware(DeviceInfo.allowHardwareBitmaps)
                .memoryCachePolicy(CachePolicy.ENABLED)
                .diskCachePolicy(CachePolicy.ENABLED)
                .build()
            loader.enqueue(req)
        }
    }

    /**
     * Resolves favourite categories. Returns immediately if the portal cache
     * has genres; otherwise waits (up to 10 s) for the parallel handshake to
     * fill the cache.
     */
    suspend fun loadFavouriteCategories(portal: Portal): List<Pair<String, String>> =
        withContext(Dispatchers.IO) {
            val mac = portal.macAddress
            val favIds = FavoriteRepository(context).getFavoriteCategories(mac, ContentType.IPTV)
            if (favIds.isEmpty()) return@withContext emptyList()

            val cache = PortalCache.get(portal.id)

            // Suspend-await pattern: poll the cache until it's populated, then
            // map to (id, title) pairs. The poll is cheap (500 ms) and bounded.
            // Caller can cancel cleanly via coroutine scope.
            val deadline = System.currentTimeMillis() + 10_000
            while (cache.genres.isEmpty() && System.currentTimeMillis() < deadline) {
                delay(500)
            }
            cache.genres.filter { it.id in favIds }.map { it.id to it.title }
        }

    // ------------------------------------------------------------------------
    // M3U
    // ------------------------------------------------------------------------

    suspend fun loadM3u(portal: Portal, userRegion: String): StatsAndItems =
        withContext(Dispatchers.IO) {
            val cache = PortalCache.get(portal.id)
            val url = portal.effectiveUrl

            // Step 1: ensure M3U meta (genres + categories) is loaded
            if (!cache.m3uLoaded) {
                val meta = M3uCache.loadMeta(context, url)
                if (meta != null) {
                    cache.genres.clear()
                    cache.genres.addAll(meta.genres)
                    cache.vodCategories.clear()
                    cache.vodCategories.addAll(meta.vodCategories)
                    cache.seriesCategories.clear()
                    cache.seriesCategories.addAll(meta.seriesCategories)
                    cache.m3uLoaded = true
                } else {
                    cache.m3uLoadMutex.lock()
                    try {
                        if (!cache.m3uLoaded) {
                            val result = M3uClient().load(url, context)
                            M3uGenreRepository.populateCache(cache, result.channels)
                            M3uCache.saveCategories(context, url,
                                cache.genres, cache.vodCategories, cache.seriesCategories)
                            cache.m3uLoaded = true
                        }
                    } catch (e: Exception) {
                        Log.e("PortalDataLoader", "M3U load failed", e)
                        cache.m3uLastError = e.message ?: e.javaClass.simpleName
                    } finally {
                        cache.m3uLoadMutex.unlock()
                    }
                }
            }

            val stats = PortalStats(
                name = portal.name,
                isOnline = cache.m3uLoaded,
                iptvCategoryCount = (cache.genres.size - 1).coerceAtLeast(0),
                movieCategoryCount = (cache.vodCategories.size - 1).coerceAtLeast(0),
                seriesCategoryCount = (cache.seriesCategories.size - 1).coerceAtLeast(0),
                errorMessage = if (!cache.m3uLoaded) cache.m3uLastError else null
            )

            // Step 2: build continue-watching items
            val items = try {
                val watchProgressRepo = WatchProgressRepository(context)
                val allProgress = watchProgressRepo.getAllProgress()

                // #1a: drop hidden/filtered categories from the recommendation
                // pool. For M3U the maps are shared with the watched lookup, so
                // a watched item in a category you've hidden also won't surface
                // in continue-watching -- an acceptable, intuitive tradeoff.
                val showCat = categoryVisibilityPredicate()
                val hiddenVodCatIds = cache.vodCategories
                    .filterNot { showCat(it.title) }.map { it.id }.toSet()
                val hiddenSeriesCatIds = cache.seriesCategories
                    .filterNot { showCat(it.title) }.map { it.id }.toSet()

                var vodById = cache.vodPagesByCategory
                    .filterKeys { it !in hiddenVodCatIds }
                    .values.flatMap { it.values.flatten() }.distinctBy { it.id }.associateBy { it.id }
                var seriesById = cache.seriesPagesByCategory
                    .filterKeys { it !in hiddenSeriesCatIds }
                    .values.flatMap { it.values.flatten() }.distinctBy { it.id }.associateBy { it.id }

                if (vodById.isEmpty() && seriesById.isEmpty() && M3uCache.isFresh(context, url)) {
                    val allChannels = M3uClient().loadFromStream(M3uCache.rawFile(context, url).inputStream())
                    val vodChannels = allChannels.filter {
                        M3uContentType.detect(it.category, it.cmd) == ContentType.VOD && showCat(it.category)
                    }
                    val seriesChannels = allChannels.filter {
                        M3uContentType.detect(it.category, it.cmd) == ContentType.SERIES && showCat(it.category)
                    }
                    vodById = vodChannels.map { ch ->
                        VodItem(id = ch.id, name = ch.name, poster = ch.logo,
                            description = "", year = "", cmd = ch.cmd, isSeries = false, isMovie = true)
                    }.associateBy { it.id }
                    seriesById = seriesChannels.map { ch ->
                        VodItem(id = ch.id, name = ch.name, poster = ch.logo,
                            description = "", year = "", cmd = ch.cmd, isSeries = true, isMovie = false)
                    }.associateBy { it.id }
                }

                val allItemsById = vodById + seriesById
                val watched = allProgress.entries
                    .filter { it.value in 1..99 }
                    .sortedByDescending { it.value }
                    .take(10)
                    .mapNotNull { (key, pct) ->
                        val item = allItemsById[key] ?: return@mapNotNull null
                        val progress = watchProgressRepo.getProgress(key)
                        val pos = progress?.first ?: 0L
                        ContinueWatchingItem(item, pct, formatPlaybackTime(pos))
                    }
                val watchedIds = watched.map { it.vodItem.id }.toSet()

                val recommendations = sortByRegion(
                    allItemsById.values.filter { it.id !in watchedIds }.shuffled().take(30),
                    userRegion
                ).take((10 - watched.size).coerceAtLeast(0))
                    .map { ContinueWatchingItem(it, 0, "") }

                (watched + recommendations).take(10)
            } catch (e: Exception) {
                Log.e("PortalDataLoader", "M3U recommendations failed", e)
                emptyList()
            }

            StatsAndItems(stats, items)
        }

    // ------------------------------------------------------------------------
    // Xtream
    // ------------------------------------------------------------------------

    /** Returns stats only -- items are loaded separately via [loadXtreamItems]. */
    suspend fun loadXtreamStats(portal: Portal): PortalStats = withContext(Dispatchers.IO) {
        val cache = PortalCache.get(portal.id)
        try {
            withTimeout(15_000) {
                val client = XtreamClient(portal.effectiveUrl, portal.username, portal.password)
                if (cache.genres.isEmpty()) {
                    cache.genres.addAll(client.getLiveCategories().map { StalkerGenre(it.id, it.title, "") })
                }
                if (cache.vodCategories.isEmpty()) cache.vodCategories.addAll(client.getVodCategories())
                if (cache.seriesCategories.isEmpty()) cache.seriesCategories.addAll(client.getSeriesCategories())
                val stats = PortalStats(
                    name = portal.name, isOnline = true,
                    iptvCategoryCount = cache.genres.size,
                    movieCategoryCount = cache.vodCategories.size,
                    seriesCategoryCount = cache.seriesCategories.size
                )
                PortalStatsCache.put(portal.id, stats)
                stats
            }
        } catch (e: Exception) {
            Log.e("PortalDataLoader", "Xtream stats failed: " + e.message)
            PortalStats(portal.name, false)
        }
    }

    suspend fun loadXtreamItems(portal: Portal, userRegion: String): List<ContinueWatchingItem> =
        withContext(Dispatchers.IO) {
            try {
                withTimeout(15_000) {
                    val client = XtreamClient(portal.effectiveUrl, portal.username, portal.password)
                    val cache = PortalCache.get(portal.id)
                    val cats = if (cache.vodCategories.isNotEmpty()) cache.vodCategories
                    else client.getVodCategories().also { cache.vodCategories.addAll(it) }

                    // #1a: skip categories the user has hidden/filtered out.
                    val showCat = categoryVisibilityPredicate()
                    val pool = mutableListOf<VodItem>()
                    cats.filter { showCat(it.title) }.take(3).forEach { cat ->
                        if (pool.size >= 30) return@forEach
                        try { pool.addAll(client.getVodStreams(cat.id).take(10)) }
                        catch (e: Exception) { /* skip category */ }
                    }
                    sortByRegion(pool.shuffled(), userRegion).take(10)
                        .map { ContinueWatchingItem(it, 0, "") }
                }
            } catch (e: Exception) {
                Log.e("PortalDataLoader", "Xtream recommendations failed: " + e.message)
                emptyList()
            }
        }

    // ------------------------------------------------------------------------
    // Stalker
    // ------------------------------------------------------------------------

    /** Fast stats from in-memory cache, or null if we need a network call. */
    fun stalkerQuickStats(portal: Portal): PortalStats? {
        val cache = PortalCache.get(portal.id)
        if (cache.genres.isEmpty() ||
            cache.vodCategories.isEmpty() ||
            cache.seriesCategories.isEmpty()) {
            return PortalStatsCache.get(portal.id)
        }
        return PortalStats(
            name = portal.name, isOnline = true,
            iptvCategoryCount = cache.genres.size,
            movieCategoryCount = cache.vodCategories.size,
            seriesCategoryCount = cache.seriesCategories.size
        ).also { PortalStatsCache.put(portal.id, it) }
    }

    suspend fun loadStalkerStats(portal: Portal): PortalStats = withContext(Dispatchers.IO) {
        val cache = PortalCache.get(portal.id)
        try {
            withTimeout(15_000) {
                if (cache.genres.isNotEmpty() &&
                    cache.vodCategories.isNotEmpty() &&
                    cache.seriesCategories.isNotEmpty()) {
                    return@withTimeout PortalStats(
                        name = portal.name, isOnline = true,
                        iptvCategoryCount = cache.genres.size,
                        movieCategoryCount = cache.vodCategories.size,
                        seriesCategoryCount = cache.seriesCategories.size
                    )
                }
                val stalkerClient = viewModel.getStalkerClient(portal.effectiveUrl, portal.macAddress)
                val vodClient = viewModel.getVodClient(portal.effectiveUrl, portal.macAddress)
                stalkerClient.handshake(force = false)

                val iptvCount = if (cache.genres.isNotEmpty()) cache.genres.size
                else { val g = stalkerClient.getGenres(); cache.genres.addAll(g); g.size }
                val movieCount = if (cache.vodCategories.isNotEmpty()) cache.vodCategories.size
                else { val c = vodClient.getVodCategories(); cache.vodCategories.addAll(c); c.size }
                val seriesCount = if (cache.seriesCategories.isNotEmpty()) cache.seriesCategories.size
                else { val c = vodClient.getSeriesCategories(); cache.seriesCategories.addAll(c); c.size }

                PortalStats(
                    name = portal.name, isOnline = true,
                    iptvCategoryCount = iptvCount,
                    movieCategoryCount = movieCount,
                    seriesCategoryCount = seriesCount
                ).also { PortalStatsCache.put(portal.id, it) }
            }
        } catch (e: Exception) {
            if (e !is TimeoutCancellationException &&
                e.message?.contains("composition", ignoreCase = true) != true) {
                Log.e("PortalDataLoader", "Stalker stats failed", e)
            }
            PortalStats(portal.name, false)
        }
    }

    suspend fun loadStalkerItems(portal: Portal, userRegion: String): List<ContinueWatchingItem> {
        // Show hero immediately from any in-memory cache so the banner is
        // never blank during a transient network failure.
        val quickVod = withContext(Dispatchers.Default) {
            val cache = PortalCache.get(portal.id)
            // #1a: exclude cached pages whose category is hidden/filtered out.
            val showCat = categoryVisibilityPredicate()
            val hiddenCatIds = cache.vodCategories
                .filterNot { showCat(it.title) }.map { it.id }.toSet()
            cache.vodPagesByCategory
                .filterKeys { it !in hiddenCatIds }
                .values
                .flatMap { it.values.flatten() }
                .filter { !it.poster.isNullOrBlank() }
                .shuffled().take(5)
                .map { ContinueWatchingItem(it, 0, "") }
        }

        return try {
            withTimeout(8_000) { loadStalkerItemsInner(portal, userRegion) }
        } catch (e: TimeoutCancellationException) {
            Log.w("PortalDataLoader", "Recommendations timed out (slow portal)")
            quickVod
        } catch (e: java.net.SocketException) {
            Log.w("PortalDataLoader", "Connection reset, retrying in 2 s")
            delay(2000)
            runCatching {
                val vodClient = viewModel.getVodClient(portal.effectiveUrl, portal.macAddress)
                loadQuickRecommendations(vodClient, userRegion)
            }.getOrElse { quickVod }
        } catch (e: Exception) {
            val msg = e.message ?: ""
            if (!msg.contains("composition", ignoreCase = true) &&
                !msg.contains("coroutine scope", ignoreCase = true) &&
                !msg.contains("CancellationException", ignoreCase = true)) {
                Log.e("PortalDataLoader", "Failed to load continue watching", e)
            }
            quickVod
        }
    }

    private suspend fun loadStalkerItemsInner(
        portal: Portal,
        userRegion: String
    ): List<ContinueWatchingItem> = withContext(Dispatchers.IO) {
        val watchProgressRepo = WatchProgressRepository(context)
        val allProgress = watchProgressRepo.getAllProgress()
        val vodClient = viewModel.getVodClient(portal.effectiveUrl, portal.macAddress)

        val watchedVideoIds = allProgress.entries
            .filter { it.value in 1..99 }
            .sortedByDescending { it.value }
            .take(10).map { it.key }
        val parentSeriesIds = watchProgressRepo.getParentSeriesIds(watchedVideoIds)
        val combinedIds = (watchedVideoIds + parentSeriesIds).toSet()

        if (combinedIds.isEmpty()) {
            return@withContext loadQuickRecommendationsWithRetry(vodClient, userRegion)
        }

        val movieCats = vodClient.getVodCategories()
        val seriesCats = vodClient.getSeriesCategories()
        val watchedItems = collectWatchedItems(
            movieCats, vodClient, combinedIds, allProgress, watchProgressRepo,
            watchedVideoIds, parentSeriesIds
        )
        val finalWatched = watchedItems.sortedByDescending { it.percentage }.take(5)

        // #1a: recommendations only draw from visible (non-hidden) categories.
        // Watched items above stay unfiltered -- the user explicitly watched
        // them, so hiding a category shouldn't drop continue-watching.
        val showCat = categoryVisibilityPredicate()
        val recommendations = if (finalWatched.size < 8) {
            loadRecommendations(
                vodClient,
                movieCats.filter { showCat(it.title) },
                seriesCats.filter { showCat(it.title) },
                finalWatched, 8 - finalWatched.size, userRegion
            )
        } else emptyList()

        (finalWatched + recommendations).take(10)
    }

    private suspend fun collectWatchedItems(
        movieCats: List<VodCategory>,
        vodClient: VodClient,
        combinedIds: Set<String>,
        allProgress: Map<String, Int>,
        watchProgressRepo: WatchProgressRepository,
        watchedVideoIds: List<String>,
        parentSeriesIds: Set<String>
    ): MutableList<ContinueWatchingItem> {
        val watchedItems = mutableListOf<ContinueWatchingItem>()
        for (cat in movieCats.take(2)) {
            if (watchedItems.size >= 5) break
            try {
                vodClient.getVodItems(cat.id, 1).items.forEach { item ->
                    if (item.id in combinedIds) {
                        val pct = allProgress[item.id] ?: return@forEach
                        val (pos, _) = watchProgressRepo.getProgress(item.id) ?: return@forEach
                        watchedItems.add(ContinueWatchingItem(item, pct, formatPlaybackTime(pos)))
                    }
                }
            } catch (e: Exception) {
                Log.e("PortalDataLoader", "Error in movie category " + cat.id, e)
            }
        }
        if (watchedItems.size < 5 && parentSeriesIds.isNotEmpty()) {
            val seriesMetadata = watchProgressRepo.getAllSeriesMetadata(watchedVideoIds)
            seriesMetadata.forEach { (seriesId, metadata) ->
                if (watchedItems.size >= 5) return@forEach
                val (seriesName, seriesPoster, percentage) = metadata
                val episodeId = watchedVideoIds.firstOrNull {
                    watchProgressRepo.getParentSeriesId(it) == seriesId
                }
                val (position, _) = if (episodeId != null)
                    watchProgressRepo.getProgress(episodeId) ?: (0L to 0L)
                else (0L to 0L)
                watchedItems.add(ContinueWatchingItem(
                    VodItem(id = seriesId, name = seriesName, description = "",
                        poster = seriesPoster, cmd = "", isSeries = true, isMovie = false),
                    percentage, formatPlaybackTime(position)
                ))
            }
        }
        return watchedItems
    }

    private suspend fun loadQuickRecommendationsWithRetry(
        vodClient: VodClient,
        userRegion: String
    ): List<ContinueWatchingItem> = try {
        loadQuickRecommendations(vodClient, userRegion)
    } catch (e: java.net.SocketException) {
        Log.w("PortalDataLoader", "Connection reset on recommendations, retrying")
        delay(1500)
        runCatching { loadQuickRecommendations(vodClient, userRegion) }.getOrDefault(emptyList())
    }

    private suspend fun loadQuickRecommendations(
        vodClient: VodClient,
        userRegion: String
    ): List<ContinueWatchingItem> = try {
        val showCat = categoryVisibilityPredicate()   // #1a
        val movieCats = vodClient.getVodCategories().filter { showCat(it.title) }
        val pool = mutableListOf<VodItem>()
        movieCats.take(2).forEach { cat ->
            try { pool.addAll(vodClient.getVodItems(cat.id, 1).items.take(6)) }
            catch (e: Exception) { Log.e("PortalDataLoader", "Error loading recommendations", e) }
        }
        sortByRegion(pool.shuffled(), userRegion).take(8)
            .map { ContinueWatchingItem(it, 0, "") }
    } catch (e: Exception) {
        Log.w("PortalDataLoader", "Error in quick recommendations", e)
        emptyList()
    }

    private suspend fun loadRecommendations(
        vodClient: VodClient,
        movieCats: List<VodCategory>,
        seriesCats: List<VodCategory>,
        exclude: List<ContinueWatchingItem>,
        count: Int,
        userRegion: String
    ): List<ContinueWatchingItem> {
        val pool = mutableListOf<VodItem>()
        return try {
            movieCats.take(2).forEach { cat ->
                if (pool.size >= count * 4) return@forEach
                try { pool.addAll(vodClient.getVodItems(cat.id, 1).items.take(6)) }
                catch (e: Exception) { Log.w("PortalDataLoader", "movie cat error", e) }
            }
            seriesCats.take(1).forEach { cat ->
                if (pool.size >= count * 4) return@forEach
                try { pool.addAll(vodClient.getSeriesList(cat.id, 1).items.take(6)) }
                catch (e: Exception) { Log.w("PortalDataLoader", "series cat error", e) }
            }
            sortByRegion(
                pool.filter { vod -> exclude.none { it.vodItem.id == vod.id } }.shuffled(),
                userRegion
            ).take(count).map { ContinueWatchingItem(it, 0, "") }
        } catch (e: Exception) {
            Log.w("PortalDataLoader", "Error in recommendations", e)
            emptyList()
        }
    }

    // ------------------------------------------------------------------------
    // New-portal first-channel fetch -- used when nothing else surfaced any
    // content so the Live TV row isn't empty for first-time portal users.
    // ------------------------------------------------------------------------

    suspend fun fetchFirstChannelsForNewPortal(portal: Portal): List<Channel> =
        withContext(Dispatchers.IO) {
            runCatching {
                val cache = PortalCache.get(portal.id)
                when {
                    portal.isXtream -> {
                        val client = XtreamClient(portal.effectiveUrl, portal.username, portal.password)
                        val cats = client.getLiveCategories()
                        if (cats.isEmpty()) return@runCatching emptyList<Channel>()
                        val firstCat = cats.first()
                        val ch = client.getLiveStreams(firstCat.id).take(20)
                        cache.getOrPutChannelPage(firstCat.id)[1] = ch
                        if (cache.genres.isEmpty())
                            cache.genres.addAll(cats.map { StalkerGenre(it.id, it.title, "") })
                        ch
                    }
                    portal.isM3U -> {
                        cache.channelPagesByGenre.values.firstOrNull()
                            ?.values?.flatten()?.take(20) ?: emptyList()
                    }
                    else -> {
                        val client = StalkerClient(portal.effectiveUrl, portal.macAddress)
                        val genres = if (cache.genres.isNotEmpty()) cache.genres
                        else client.getGenres().also { cache.genres.addAll(it) }
                        if (genres.isEmpty()) return@runCatching emptyList<Channel>()
                        val firstGenre = genres.first()
                        val result = client.getChannelsPage(firstGenre.id, page = 1, limit = 20)
                        cache.getOrPutChannelPage(firstGenre.id)[1] = result.channels
                        result.channels
                    }
                }
            }.getOrElse { emptyList() }
        }
}
class TvHomeComposeFragment : Fragment() {

    private val viewModel: TvHomeViewModel by viewModels()

    override fun onCreateView(
        inflater: LayoutInflater,
        container: ViewGroup?,
        savedInstanceState: Bundle?
    ): View = ComposeView(requireContext()).apply {
        setContent {
            MaterialTheme {
                HomeScreen(
                    viewModel = viewModel,
                    fragment = this@TvHomeComposeFragment
                )
            }
        }
    }

    override fun onResume() {
        super.onResume()
        Log.d("TvHomeComposeFragment", "onResume")
    }

    /** Top-level sidebar destination -- resets the back stack to one section. */
    fun navigateSection(fragment: Fragment) = tvGoTopLevel(fragment)

    fun navigateToCategories(contentType: ContentType) =
        tvGoTopLevel(CategoryBrowseComposeFragment.newInstance(contentType))

    /** Drill into a screen within the current section (stacks normally). */
    fun navigateDrillDown(fragment: Fragment) = tvGoDrillDown(fragment)

    fun playVodMovie(item: VodItem) {
        if (item.isSeries) {
            navigateDrillDown(SeriesBrowseFragment.newInstance(item))
            return
        }
        viewLifecycleOwner.lifecycleScope.launch(Dispatchers.IO) {
            try {
                val activePortal = PortalRepository(requireContext()).getActivePortal() ?: return@launch
                val (videoUrl, _) = if (activePortal.isM3U || activePortal.isXtream) {
                    item.cmd to null
                } else {
                    viewModel.getVodClient(activePortal.effectiveUrl, activePortal.macAddress)
                        .getVodFile(item).cmd to null
                }
                withContext(Dispatchers.Main) {
                    startActivity(Intent(requireContext(), PlayerActivity::class.java).apply {
                        putExtra("VIDEO_URL", videoUrl)
                        putExtra("VIDEO_ID", item.id)
                        putExtra("TITLE", item.name)
                        putExtra("PORTAL_URL", activePortal.effectiveUrl)
                        putExtra("MAC_ADDRESS", activePortal.macAddress)
                    })
                }
            } catch (e: Exception) {
                Log.e("TvHomeComposeFragment", "Failed to play VOD movie", e)
            }
        }
    }

    fun playChannelFromFavourites(
        channel: Channel,
        favourites: List<Channel>,
        categoryName: String
    ) {
        viewLifecycleOwner.lifecycleScope.launch(Dispatchers.IO) {
            val portal = PortalRepository(requireContext()).getActivePortal() ?: return@launch
            val cache = PortalCache.get(portal.id)
            val recentKey = "__fav_channels__"
            cache.channelPagesByGenre.getOrPut(recentKey) { mutableMapOf() }[1] = favourites
            val idx = favourites.indexOfFirst { it.id == channel.id }.coerceAtLeast(0)
            // Filter genres through parental controls before passing to player.
            // Without this, the player's category rail would let the user
            // navigate into a category that's locked on the home screen --
            // a back-door into parentally-locked content.
            val parentalRepo = ParentalControlsRepository(requireContext())
            val visibleGenres = ParentalFilter.filterGenres(
                cache.genres.toList(), portal.id, parentalRepo
            )
            withContext(Dispatchers.Main) {
                startActivity(Intent(requireContext(), PlayerActivity::class.java).apply {
                    putExtra("PORTAL_URL", portal.effectiveUrl)
                    putExtra("MAC_ADDRESS", portal.macAddress)
                    putExtra("PORTAL_ID", portal.id)
                    putExtra("CURRENT_INDEX", idx)
                    putExtra("CONTENT_TYPE", ContentType.IPTV.name)
                    putExtra("CATEGORY_ID", recentKey)
                    putExtra("CATEGORY_NAME", categoryName)
                    putStringArrayListExtra("CAT_IDS", ArrayList(visibleGenres.map { it.id }))
                    putStringArrayListExtra("CAT_NAMES", ArrayList(visibleGenres.map { it.title }))
                    if (portal.isXtream) {
                        putExtra("IS_XTREAM", true)
                        putExtra("XTREAM_USERNAME", portal.username)
                        putExtra("XTREAM_PASSWORD", portal.password)
                    }
                })
            }
        }
    }
}

// ============================================================================
// SECTION 7 -- COMPOSABLE: HomeScreen
//
// Pure renderer. Reads HomeUiState from the ViewModel, dispatches user actions
// back. No business logic, no Dispatchers.IO, no caches -- just layout.
// ============================================================================

@Composable
private fun HomeScreen(
    viewModel: TvHomeViewModel,
    fragment: TvHomeComposeFragment
) {
    val context = LocalContext.current
    val ui by viewModel.homeUiState.collectAsState()
    val clockText by viewModel.clockText.collectAsState()

    // Parental controls plumbing. The repo is cheap (just wraps
    // SharedPreferences) so creating it per composition is fine. The
    // filtered favourite-categories list is keyed on a coarse time tick
    // so the unlock-window expiry naturally re-evaluates without forcing
    // a recompose elsewhere.
    val parentalRepo = remember { ParentalControlsRepository(context) }
    val visibleFavCategories = remember(
        ui.favouriteCategories,
        ui.activePortalId,
        System.currentTimeMillis() / 60_000L
    ) {
        if (ui.activePortalId.isNotBlank() &&
            parentalRepo.isEnabled(ui.activePortalId) &&
            !ParentalSession.isUnlocked(ui.activePortalId)) {
            val locked = parentalRepo.getLockedCategoryIds(ui.activePortalId)
            ui.favouriteCategories.filterNot { (id, _) -> id in locked }
        } else ui.favouriteCategories
    }

    // Boot the ViewModel once. It will then re-load whenever the lifecycle
    // signals a resume (see DisposableEffect below).
    LaunchedEffect(Unit) { viewModel.initialize(context) }

    val lifecycleOwner = androidx.compose.ui.platform.LocalLifecycleOwner.current
    DisposableEffect(lifecycleOwner) {
        val observer = LifecycleEventObserver { _, event ->
            if (event == androidx.lifecycle.Lifecycle.Event.ON_RESUME) viewModel.onResume(context)
        }
        lifecycleOwner.lifecycle.addObserver(observer)
        onDispose { lifecycleOwner.lifecycle.removeObserver(observer) }
    }

    // Refresh and portal-switch handlers for the top bar. Refresh uses the
    // shared PortalReloader (same path as TV settings + phone) and then
    // re-triggers the ViewModel's onResume so the UI picks up fresh data.
    var isRefreshing by remember { mutableStateOf(false) }
    var infoCardItem by remember { mutableStateOf<VodItem?>(null) }
    androidx.activity.compose.BackHandler(enabled = infoCardItem != null) {
        infoCardItem = null
    }
    val coroutineScope = rememberCoroutineScope()
    val onRefresh: () -> Unit = {
        val active = ui.allPortals.firstOrNull { it.id == ui.activePortalId }
        if (active != null && !isRefreshing) {
            isRefreshing = true
            Toast.makeText(context, "Refreshing " + active.name + "...", Toast.LENGTH_SHORT).show()
            coroutineScope.launch {
                try {
                    val result = PortalReloader.reload(context, active)
                    viewModel.onResume(context)
                    Toast.makeText(
                        context, result.message,
                        if (result.success) Toast.LENGTH_SHORT else Toast.LENGTH_LONG
                    ).show()
                } finally {
                    isRefreshing = false
                }
            }
        }
    }
    val onPortalSwitch: (Portal) -> Unit = { portal ->
        coroutineScope.launch {
            PortalRepository(context).setActivePortalId(portal.id)
            PortalStatsCache.invalidate()
            viewModel.onResume(context)
        }
    }

    Box(modifier = Modifier.fillMaxSize()) {
        // Background image + dim
        Image(
            painter = painterResource(id = R.drawable.tvbackground),
            contentDescription = null,
            modifier = Modifier.fillMaxSize(),
            contentScale = ContentScale.Crop
        )
        Box(modifier = Modifier.fillMaxSize().background(Color.Black.copy(alpha = 0.55f)))

        // Sidebar + content. Top bar is PINNED above the scrolling area --
        // it used to be inside the verticalScroll Column, which meant any
        // D-pad focus auto-scroll pushed it off the top of the screen.
        // Now it stays anchored and the cards row also keeps its bottom
        // breathing room.
        Row(modifier = Modifier.fillMaxSize()) {
            Sidebar(fragment = fragment)

            Column(
                modifier = Modifier
                    .weight(1f)
                    .fillMaxHeight()
                    .zIndex(1f)
                    .padding(start = 80.dp, end = 32.dp, top = 16.dp)
            ) {
                // Pinned top bar -- refresh, portal switcher, status, clock.
                // Lives outside the scroll so focus shifts can't hide it.
                TopBar(
                    statsState = ui.statsState,
                    clockText = clockText,
                    allPortals = ui.allPortals,
                    activePortalId = ui.activePortalId,
                    isRefreshing = isRefreshing,
                    onRefresh = onRefresh,
                    onPortalSwitch = onPortalSwitch
                )

// Scrollable content area below the top bar.
                val scrollState = rememberScrollState()

                // First-load shimmer gate. Fail-safe by construction: it shows
                // only while a portal is selected, NO content of any kind has
                // arrived yet, and none of the existing status cards apply.
                // The instant any content lands -- or the screen resolves to a
                // status card -- the condition flips false on its own, so the
                // skeleton can never get stuck on screen.
                val activePortalName = ui.allPortals
                    .firstOrNull { it.id == ui.activePortalId }?.name ?: ""
                val hasAnyHomeContent = ui.continueWatchingItems.isNotEmpty() ||
                        ui.favoriteChannels.isNotEmpty() ||
                        visibleFavCategories.isNotEmpty()
                val showingStatusCard = ui.allPortals.isEmpty() ||
                        (ui.hasNothingToShow &&
                                (ui.isFetchingForNewPortal || ui.newPortalFetchDone))
                val showHomeSkeleton = ui.allPortals.isNotEmpty() &&
                        !showingStatusCard &&
                        !hasAnyHomeContent

                Column(
                    modifier = Modifier
                        .weight(1f)
                        .fillMaxWidth()
                        .verticalScroll(scrollState)
                        .graphicsLayer { clip = false }
                        .padding(bottom = 32.dp)
                ) {
                    when {
                        ui.allPortals.isEmpty() -> NoPortalCard(fragment)
                        ui.hasNothingToShow && ui.isFetchingForNewPortal -> NewPortalSpinner()
                        ui.hasNothingToShow && ui.newPortalFetchDone -> NothingToShowCard(fragment)
                    }

                    if (showHomeSkeleton) {
                        HomeLoadingSkeleton(portalName = activePortalName)
                    } else if (ui.allPortals.isNotEmpty()) {
                        HeroSection(
                            heroItem = ui.continueWatchingItems.firstOrNull(),
                            onPlay = { it ->
                                val v = it.vodItem
                                if (v.isSeries) fragment.playVodMovie(v) else infoCardItem = v
                            }
                        )
                        Spacer(Modifier.height(24.dp))
                        ContinueWatchingSection(
                            items = ui.continueWatchingItems,
                            isLoading = ui.isLoadingRecommendations,
                            onClick = { it ->
                                val v = it.vodItem
                                if (v.isSeries) fragment.playVodMovie(v) else infoCardItem = v
                            }
                        )
                        FavouriteChannelsSection(
                            favourites = ui.favoriteChannels,
                            onClick = { ch, label ->
                                fragment.playChannelFromFavourites(ch, ui.favoriteChannels, label)
                            }
                        )
                        FavouriteCategoriesSection(
                            categories = visibleFavCategories,
                            onCategoryClick = { id, name ->
                                fragment.navigateDrillDown(ContentBrowseComposeFragment.newInstance(
                                    ContentType.IPTV, id, name
                                ))
                            }
                        )
                    }
                }
            }
        }

        infoCardItem?.let { card ->
            VodInfoCard(
                item = card,
                onPlay = {
                    infoCardItem = null
                    fragment.playVodMovie(card)
                },
                onBack = { infoCardItem = null }
            )
        }
    }
}

