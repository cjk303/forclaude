enum class CardType { LANDSCAPE, PORTRAIT }

@Composable
fun ContentRow(
    title: String,
    items: List<ContinueWatchingItem>,
    onItemClick: (ContinueWatchingItem) -> Unit,
    cardType: CardType = CardType.LANDSCAPE,
    isLoading: Boolean = false
) {
    Column {
        if (title.isNotEmpty()) {
            Text(title, color = Color.White, fontSize = 16.sp,
                fontWeight = FontWeight.SemiBold,
                modifier = Modifier.padding(bottom = 10.dp))
        }
        if (isLoading && items.isEmpty()) {
            Row(
                modifier = Modifier.fillMaxWidth(),
                horizontalArrangement = Arrangement.spacedBy(14.dp)
            ) {
                repeat(5) {
                    Box(modifier = Modifier.weight(1f).aspectRatio(2f / 3f)
                        .clip(RoundedCornerShape(10.dp))
                        .background(Color.White.copy(alpha = 0.06f)))
                }
            }
        } else if (items.isNotEmpty()) {
            val listState = rememberLazyListState()
            val snapFling = androidx.compose.foundation.gestures.snapping.rememberSnapFlingBehavior(listState)
            BoxWithConstraints(modifier = Modifier.fillMaxWidth()) {
                val gap = 14.dp
                val cardWidth = (maxWidth - gap * 4) / 5
                LazyRow(
                    state = listState,
                    horizontalArrangement = Arrangement.spacedBy(gap),
                    contentPadding = PaddingValues(start = 8.dp, end = 8.dp, top = 8.dp, bottom = 8.dp),
                    modifier = Modifier.fillMaxWidth(),
                    flingBehavior = snapFling
                ) {
                    itemsIndexed(items, key = { i, item -> item.vodItem.id + "_" + i }) { _, item ->
                        Box(modifier = Modifier.width(cardWidth)) {
                            LandscapeContentCard(item = item, onClick = { onItemClick(item) })
                        }
                    }
                }
            }
        }
    }
}

