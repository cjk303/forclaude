@Composable
private fun TopBar(
    statsState: StatsViewState,
    clockText: String,
    allPortals: List<Portal>,
    activePortalId: String,
    isRefreshing: Boolean,
    onRefresh: () -> Unit,
    onPortalSwitch: (Portal) -> Unit
) {
    var showPortalSwitcher by remember { mutableStateOf(false) }
    val canSwitchPortals = allPortals.size > 1

    Row(
        modifier = Modifier.fillMaxWidth().padding(top = 16.dp, bottom = 12.dp),
        horizontalArrangement = Arrangement.End,
        verticalAlignment = Alignment.CenterVertically
    ) {
        if (statsState is StatsViewState.Success) {
            val s = statsState.stats
            Row(
                verticalAlignment = Alignment.CenterVertically,
                horizontalArrangement = Arrangement.spacedBy(8.dp)
            ) {
                // Refresh icon -- spins while reloading the active portal.
                TopBarRefreshButton(isRefreshing = isRefreshing, onClick = onRefresh)

                // Portal name -- clickable when multiple portals exist.
                // Hosts a DropdownMenu that auto-positions below the button.
                Box {
                    PortalNameButton(
                        portalName = s.name ?: "",
                        canSwitch = canSwitchPortals,
                        isExpanded = showPortalSwitcher,
                        onClick = {
                            if (canSwitchPortals) showPortalSwitcher = !showPortalSwitcher
                        }
                    )
                    DropdownMenu(
                        expanded = showPortalSwitcher,
                        onDismissRequest = { showPortalSwitcher = false },
                        modifier = Modifier.background(Color(0xFF0F1923))
                    ) {
                        Column(
                            modifier = Modifier.width(260.dp).padding(6.dp),
                            verticalArrangement = Arrangement.spacedBy(2.dp)
                        ) {
                            Text(
                                "Switch portal",
                                color = Color(0xFF3B82F6),
                                fontSize = 11.sp,
                                fontWeight = FontWeight.SemiBold,
                                letterSpacing = 0.5.sp,
                                modifier = Modifier.padding(horizontal = 8.dp, vertical = 4.dp)
                            )
                            Divider(color = Color(0xFF3B82F6).copy(alpha = 0.3f))
                            Spacer(Modifier.height(2.dp))
                            allPortals.forEach { portal ->
                                PortalSwitcherRow(
                                    portal = portal,
                                    isActive = portal.id == activePortalId,
                                    onClick = {
                                        showPortalSwitcher = false
                                        onPortalSwitch(portal)
                                    }
                                )
                            }
                        }
                    }
                }

                Text(stringResource(R.string.bullet_separator),
                    color = if (s.isOnline) Color(0xFF4CAF50) else Color(0xFFF44336),
                    fontSize = 12.sp)
                Text(
                    stringResource(if (s.isOnline) R.string.stats_status_online else R.string.stats_status_offline),
                    color = if (s.isOnline) Color(0xFF4CAF50) else Color(0xFFF44336),
                    fontSize = 12.sp, fontWeight = FontWeight.SemiBold
                )
                if (clockText.isNotBlank()) {
                    Spacer(Modifier.width(8.dp))
                    ClockText(clockText)
                }
            }
        } else if (clockText.isNotBlank()) {
            ClockText(clockText)
        }
    }
}

