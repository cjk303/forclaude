/**
 * Strip an IPTV prefix like "PL|" or "DE -" from a display name so the user
 * sees the human-readable title in the UI. Centralised so the heuristics
 * stay consistent across HeroBanner, LandscapeContentCard, LiveChannelCard,
 * and FavCategoryChip.
 */
internal fun stripContentPrefix(name: String): String {
    val pipeIdx = name.indexOf('|')
    return when {
        pipeIdx > 0 -> name.substring(pipeIdx + 1).trim()
        name.length > 4 && name[2] == ' ' && name[3] == '-' && name[4] == ' ' ->
            name.substring(5).trim()
        name.length > 5 && name[3] == ' ' && name[4] == '-' && name[5] == ' ' ->
            name.substring(6).trim()
        else -> name
    }
}

private fun formatPlaybackTime(ms: Long): String {
    val sec = (ms / 1000) % 60
    val min = (ms / (1000 * 60)) % 60
    val hr = ms / (1000 * 60 * 60)
    return if (hr > 0) String.format("%d:%02d:%02d", hr, min, sec)
    else String.format("%02d:%02d", min, sec)
}

