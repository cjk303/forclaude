@Composable
private fun ContinueWatchingSection(
    items: List<ContinueWatchingItem>,
    isLoading: Boolean,
    onClick: (ContinueWatchingItem) -> Unit
) {
    val watchedItems = items.filter { it.percentage > 0 && !it.vodItem.poster.isNullOrBlank() }
    val recommendedItems = items.filter { it.percentage == 0 && !it.vodItem.poster.isNullOrBlank() }
    val merged = watchedItems + recommendedItems
    if (merged.isEmpty() && !isLoading) return

    Row(
        modifier = Modifier.fillMaxWidth().padding(bottom = 10.dp),
        verticalAlignment = Alignment.CenterVertically,
        horizontalArrangement = Arrangement.spacedBy(8.dp)
    ) {
        if (watchedItems.isNotEmpty()) {
            Text(stringResource(R.string.recently_watched),
                color = Color.White, fontSize = 16.sp, fontWeight = FontWeight.SemiBold)
        }
        if (watchedItems.isNotEmpty() && recommendedItems.isNotEmpty()) {
            Text(stringResource(R.string.dot_separator), color = Color.White.copy(alpha = 0.3f), fontSize = 16.sp)
        }
        if (recommendedItems.isNotEmpty() || isLoading) {
            Text(stringResource(R.string.home_recommended_short),
                color = if (watchedItems.isEmpty()) Color.White else Color.White.copy(alpha = 0.5f),
                fontSize = if (watchedItems.isEmpty()) 16.sp else 14.sp,
                fontWeight = if (watchedItems.isEmpty()) FontWeight.SemiBold else FontWeight.Normal)
        }
    }
    ContentRow(
        title = "",
        items = merged,
        onItemClick = onClick,
        isLoading = isLoading
    )
    Spacer(Modifier.height(20.dp))
}

