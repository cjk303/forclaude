                    fontSize = 10.sp,
                    fontWeight = if (isFocused) FontWeight.SemiBold else FontWeight.Normal,
                    color = if (isFocused) Color.White else Color.White.copy(alpha = 0.35f),
                    maxLines = 1, overflow = TextOverflow.Ellipsis, letterSpacing = 0.5.sp)
            }
        }
    }
}

