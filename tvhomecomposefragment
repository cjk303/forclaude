/**
 * Cross-field-consistent cache: stores portalId, stats, and timestamp as a single
 * atomic unit. Previous version used three separate @Volatile fields and could
 * publish torn reads to the Main thread (e.g. portalId already updated but stats
 * still showing the old portal's data).
 */
object PortalStatsCache {
    private const val CACHE_DURATION_MS = 5 * 60 * 1000L

    private data class Entry(val portalId: String, val stats: PortalStats, val timestamp: Long)
    private val ref = java.util.concurrent.atomic.AtomicReference<Entry?>(null)

    fun get(portalId: String): PortalStats? {
        val entry = ref.get() ?: return null
        if (entry.portalId != portalId) return null
        if (System.currentTimeMillis() - entry.timestamp >= CACHE_DURATION_MS) return null
        if (!entry.stats.isOnline || entry.stats.iptvCategoryCount == 0) return null
        return entry.stats
    }

    fun put(portalId: String, stats: PortalStats) {
        ref.set(Entry(portalId, stats, System.currentTimeMillis()))
    }

    fun invalidate() { ref.set(null) }
}

// ============================================================================
// SECTION 2 -- REGION INFERENCE
//
// Uses the app language the user explicitly set in LanguageSettingsScreen,
// falling back to the system locale. Zero permission, zero network, zero Play
// policy risk. The user's chosen language reflects content preference better
// than IP geolocation would.
// ============================================================================

private val LANGUAGE_TO_REGION = mapOf(
    "pl" to "PL", "de" to "DE", "fr" to "FR", "it" to "IT", "es" to "ES",
    "nl" to "NL", "pt" to "PT", "ru" to "RU", "uk" to "UK", "ar" to "ARAB",
    "tr" to "TR", "cs" to "CZ", "cz" to "CZ", "sk" to "SK", "hu" to "HU",
    "ro" to "RO", "bg" to "BG", "el" to "GR", "gr" to "GR", "sv" to "SE",
    "no" to "NO", "nb" to "NO", "nn" to "NO", "da" to "DK", "fi" to "FI",
    "sr" to "RS", "hr" to "HR", "hi" to "IN", "zh" to "CN", "ja" to "JP",
    "ko" to "KR", "th" to "TH"
)

private fun inferRegionFromLocale(): String {
    val appLocales = AppCompatDelegate.getApplicationLocales()
    val appTag = if (!appLocales.isEmpty) appLocales[0]?.language else null
    val tag = appTag?.ifBlank { null } ?: Locale.getDefault().language
    return LANGUAGE_TO_REGION[tag.lowercase()] ?: "EN"
}

private fun extractItemPrefix(name: String): String {
    val pipeIdx = name.indexOf('|')
    return if (pipeIdx > 0) name.substring(0, pipeIdx).trim().uppercase() else ""
}

private fun regionScore(name: String, userRegion: String): Int {
    val prefix = extractItemPrefix(name)
    return when {
        prefix == userRegion -> 2
        prefix == "EN" || prefix == "US" || prefix == "UK" -> 1
        prefix.isEmpty() -> 1
        else -> 0
    }
}

private fun sortByRegion(items: List<VodItem>, userRegion: String): List<VodItem> =
    items.sortedByDescending { regionScore(it.name, userRegion) }

