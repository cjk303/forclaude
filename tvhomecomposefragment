@OptIn(ExperimentalTvMaterial3Api::class)
@Composable
fun CompactStatsBox(
    state: StatsViewState,
    portals: List<Portal> = emptyList(),
    activePortalId: String = "",
    onPortalSwitch: (Portal) -> Unit = {}
) {
    var showSwitcher by remember { mutableStateOf(false) }
    val interactionSource = remember { MutableInteractionSource() }
    val isFocused by interactionSource.collectIsFocusedAsState()
    LaunchedEffect(activePortalId) { showSwitcher = false }
    val canSwitch = portals.size > 1
    val portalName = when (state) {
        is StatsViewState.Success -> state.stats.name ?: stringResource(R.string.stats_portal_name)
        else -> stringResource(R.string.stats_portal_name)
    }
    Box(modifier = Modifier.width(240.dp).wrapContentHeight()) {
        Column(
            modifier = Modifier.fillMaxWidth()
                .clip(RoundedCornerShape(12.dp))
                .background(Color.Black.copy(alpha = 0.5f))
                .border(1.dp, Color.White.copy(alpha = 0.1f), RoundedCornerShape(12.dp))
                .padding(16.dp),
            verticalArrangement = Arrangement.spacedBy(8.dp)
        ) {
            Surface(
                onClick = { if (canSwitch) showSwitcher = !showSwitcher },
                modifier = Modifier.fillMaxWidth(),
                interactionSource = interactionSource,
                shape = ClickableSurfaceDefaults.shape(RoundedCornerShape(6.dp)),
                colors = ClickableSurfaceDefaults.colors(
                    containerColor = Color.Transparent,
                    focusedContainerColor = Color.White.copy(alpha = 0.08f)
                )
            ) {
                Row(Modifier.fillMaxWidth().padding(vertical = 4.dp, horizontal = 2.dp),
                    verticalAlignment = Alignment.CenterVertically,
                    horizontalArrangement = Arrangement.SpaceBetween) {
                    Text(portalName,
                        color = if (isFocused) Color(0xFF3B82F6) else Color.White,
                        fontWeight = FontWeight.Bold, fontSize = 14.sp,
                        maxLines = 1, overflow = TextOverflow.Ellipsis,
                        modifier = Modifier.weight(1f))
                    if (canSwitch) {
                        Text(if (showSwitcher) stringResource(R.string.arrow_up) else stringResource(R.string.arrow_down),
                            color = Color(0xFF3B82F6), fontSize = 10.sp,
                            modifier = Modifier.padding(start = 4.dp))
                    }
                }
            }
            Divider(color = Color.White.copy(alpha = 0.1f))
            when (state) {
                is StatsViewState.Success -> {
                    val s = state.stats
                    CompactInfoRow(stringResource(R.string.stats_status),
                        stringResource(if (s.isOnline) R.string.stats_status_online else R.string.stats_status_offline),
                        if (s.isOnline) Color(0xFF4CAF50) else Color(0xFFF44336))
                    if (!s.isOnline && !s.errorMessage.isNullOrBlank()) {
                        Text(s.errorMessage, color = Color(0xFFF44336).copy(alpha = 0.85f),
                            fontSize = 10.sp, maxLines = 3,
                            overflow = TextOverflow.Ellipsis,
                            modifier = Modifier.padding(top = 4.dp))
                    }
                    CompactInfoRow(stringResource(R.string.stats_iptv_categories), s.iptvCategoryCount.toString())
                    CompactInfoRow(stringResource(R.string.stats_vod_categories), s.movieCategoryCount.toString())
                    CompactInfoRow(stringResource(R.string.stats_series_categories), s.seriesCategoryCount.toString())
                }
                else -> Text(stringResource(R.string.loading_text), color = Color.White, fontSize = 12.sp)
            }
        }
        if (showSwitcher && portals.isNotEmpty()) {
            Box(modifier = Modifier.fillMaxWidth().wrapContentHeight().offset(y = 0.dp).zIndex(10f)) {
                Column(
                    modifier = Modifier.fillMaxWidth()
                        .clip(RoundedCornerShape(12.dp))
                        .background(Color(0xFF0F1923))
                        .border(1.dp, Color(0xFF3B82F6).copy(alpha = 0.5f), RoundedCornerShape(12.dp))
                        .padding(8.dp),
                    verticalArrangement = Arrangement.spacedBy(2.dp)
                ) {
                    Text(portalName,
                        color = Color(0xFF3B82F6), fontWeight = FontWeight.Bold, fontSize = 14.sp,
                        maxLines = 1, overflow = TextOverflow.Ellipsis,
                        modifier = Modifier.padding(horizontal = 6.dp, vertical = 4.dp))
                    Divider(color = Color(0xFF3B82F6).copy(alpha = 0.3f))
                    Spacer(Modifier.height(4.dp))
                    portals.forEach { portal ->
                        val isActive = portal.id == activePortalId
                        PortalSwitcherRow(portal, isActive) {
                            showSwitcher = false
                            if (!isActive) onPortalSwitch(portal)
                        }
                    }
                }
            }
        }
    }
}

@OptIn(ExperimentalTvMaterial3Api::class)
@Composable
private fun PortalSwitcherRow(portal: Portal, isActive: Boolean, onClick: () -> Unit) {
    val interactionSource = remember { MutableInteractionSource() }
    val isFocused by interactionSource.collectIsFocusedAsState()
    Surface(
        onClick = onClick,
        modifier = Modifier.fillMaxWidth(),
        interactionSource = interactionSource,
        shape = ClickableSurfaceDefaults.shape(RoundedCornerShape(4.dp)),
        colors = ClickableSurfaceDefaults.colors(
            containerColor = if (isActive) Color(0xFF1E3A5F).copy(alpha = 0.6f) else Color.Transparent,
            focusedContainerColor = Color(0xFF1E3A5F).copy(alpha = 0.8f)
        )
    ) {
        Row(
            Modifier.fillMaxWidth().padding(horizontal = 6.dp, vertical = 6.dp),
            verticalAlignment = Alignment.CenterVertically,
            horizontalArrangement = Arrangement.SpaceBetween
        ) {
            Text(portal.name,
                color = if (isActive || isFocused) Color.White else Color.White.copy(alpha = 0.7f),
                fontSize = 12.sp,
                fontWeight = if (isActive) FontWeight.SemiBold else FontWeight.Normal,
                maxLines = 1, overflow = TextOverflow.Ellipsis,
                modifier = Modifier.weight(1f))
            if (isActive) Text(stringResource(R.string.check_mark_icon), color = Color(0xFF3B82F6), fontSize = 11.sp)
        }
    }
}

@Composable
fun CompactInfoRow(label: String, value: String, color: Color = Color.White) {
    Row(Modifier.fillMaxWidth(), horizontalArrangement = Arrangement.SpaceBetween) {
        Text(label, color = Color.LightGray, fontSize = 11.sp)
        Text(value, color = color, fontSize = 11.sp, fontWeight = FontWeight.Bold)
    }
}
