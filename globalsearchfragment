class GlobalSearchFragment : Fragment() {

    private var savedQuery: String = ""

    override fun onCreateView(
        inflater: LayoutInflater,
        container: ViewGroup?,
        savedInstanceState: Bundle?
    ): View = ComposeView(requireContext()).apply {
        setContent {
            MaterialTheme {
                GlobalSearchScreen(
                    initialQuery       = savedQuery,
                    onQueryChanged     = { savedQuery = it },
                    onChannelSelected  = { channel, portal -> launchChannel(channel, portal) },
                    onVodSelected      = { vod, portal     -> launchVod(vod, portal) },
                    onBack             = { requireActivity().finish() },
                    onNavigate         = { frag -> tvGoTopLevel(frag) }
                )
            }
        }
    }

    private fun launchChannel(channel: Channel, portal: Portal) {
        val cache = PortalCache.get(portal.id)
        val catId = channel.category.ifBlank { "0" }

        // Find the index of the selected channel within its category's cached list.
        val channelsInCategory = cache.channelPagesByGenre[catId]?.values?.flatten() ?: emptyList()
        val index = channelsInCategory.indexOfFirst { it.id == channel.id }

        val intent = Intent(requireContext(), PlayerActivity::class.java).apply {
            putExtra("PORTAL_URL",  portal.portalUrl)
            putExtra("MAC_ADDRESS", portal.macAddress)
            putExtra("PORTAL_ID",   portal.id)
            if (portal.isXtream) {
                putExtra("IS_XTREAM",       true)
                putExtra("XTREAM_USERNAME", portal.username)
                putExtra("XTREAM_PASSWORD", portal.password)
            }

            // FIX: Pass the correct category and index so PlayerActivity plays the selected channel
            putExtra("CATEGORY_ID",   catId)
            putExtra("CATEGORY_NAME", cache.genres.find { it.id == catId }?.title ?: "")
            putExtra("CURRENT_INDEX", if (index != -1) index else 0)
            putExtra("CONTENT_TYPE",  ContentType.IPTV.name)

            // Pass the full lists so navigation/overlay works correctly in the player
            val catIds = ArrayList(cache.genres.map { it.id })
            val catNames = ArrayList(cache.genres.map { it.title })
            putStringArrayListExtra("CAT_IDS",   catIds)
            putStringArrayListExtra("CAT_NAMES", catNames)
        }
        startActivity(intent)
    }

    private fun launchVod(vod: VodItem, portal: Portal) {
        if (portal.isM3U || portal.isXtream) {
            if (vod.isSeries) {
                tvGoDrillDown(SeriesBrowseFragment.newInstance(vod))
            } else {
                val intent = Intent(requireContext(), PlayerActivity::class.java).apply {
                    putExtra("VIDEO_URL",   vod.cmd)
                    putExtra("VIDEO_ID",    vod.id)
                    putExtra("TITLE",       vod.name)
                    putExtra("PORTAL_URL",  portal.effectiveUrl)
                    putExtra("MAC_ADDRESS", portal.macAddress)
                }
                startActivity(intent)
            }
        } else {
            if (vod.isSeries) {
                val fragment = SeriesBrowseFragment.newInstance(vod)
                parentFragmentManager.beginTransaction()
                    .replace(R.id.tv_fragment_container, fragment)
                    .addToBackStack(null).commit()
            } else {
                lifecycleScope.launch(Dispatchers.IO) {
                    try {
                        val vodClient = VodClient(portal.effectiveUrl, portal.macAddress)
                        val vodFile   = vodClient.getVodFile(vod)
                        withContext(Dispatchers.Main) {
                            val intent = Intent(requireContext(), PlayerActivity::class.java).apply {
                                putExtra("VIDEO_URL",   vodFile.cmd)
                                putExtra("VIDEO_ID",    vod.id)
                                putExtra("TITLE",       vod.name)
                                putExtra("PORTAL_URL",  portal.effectiveUrl)
                                putExtra("MAC_ADDRESS", portal.macAddress)
                            }
                            startActivity(intent)
                        }
                    } catch (e: Exception) {
                        withContext(Dispatchers.Main) {
                            android.widget.Toast.makeText(requireContext(),
                                getString(R.string.error_resolve_stream, e.message),
                                android.widget.Toast.LENGTH_LONG).show()
                        }
                    }
                }
            }
        }
    }
}

// ── Data ──────────────────────────────────────────────────────────────────────

internal data class SearchResults(
    val channels: List<Channel> = emptyList(),
    val vod:      List<VodItem> = emptyList(),
    val series:   List<VodItem> = emptyList(),
    // False when part of the search plan failed or was cancelled --
    // such results must not be cached as authoritative.
    val complete: Boolean = true
) {
    val isEmpty get() = channels.isEmpty() && vod.isEmpty() && series.isEmpty()
    val total   get() = channels.size + vod.size + series.size
}

private val M3U_GROUP_TITLE_REGEX = Regex("""group-title="([^"]*)"""", RegexOption.IGNORE_CASE)
private val M3U_TVG_LOGO_REGEX    = Regex("""tvg-logo="([^"]*)"""",    RegexOption.IGNORE_CASE)
private val M3U_TVG_ID_REGEX      = Regex("""tvg-id="([^"]*)"""",      RegexOption.IGNORE_CASE)

internal object SearchCache {
    private const val MAX_ENTRIES = 50
    private val map = object : LinkedHashMap<String, SearchResults>(MAX_ENTRIES, 0.75f, false) {
        override fun removeEldestEntry(eldest: MutableMap.MutableEntry<String, SearchResults>) =
            size > MAX_ENTRIES
    }
    fun key(portalId: String, query: String) = "$portalId|${query.trim().lowercase()}"
    fun get(portalId: String, query: String): SearchResults? =
        synchronized(this) { map[key(portalId, query)] }
    fun put(portalId: String, query: String, results: SearchResults) {
        if (!results.isEmpty && results.complete)
            synchronized(this) { map[key(portalId, query)] = results }
    }
    fun clearPortal(portalId: String) {
        synchronized(this) { map.keys.removeAll { it.startsWith("$portalId|") } }
    }
}

