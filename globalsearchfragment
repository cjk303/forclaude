// ── Search logic ──────────────────────────────────────────────────────────────

private suspend fun performSearchWithProgress(
    query:           String,
    portal:          Portal,
    context:         android.content.Context,
    onProgress:      suspend (text: String, fraction: Float) -> Unit,
    onPartialResult: suspend (SearchResults) -> Unit
): SearchResults = withContext(Dispatchers.IO) {
    val q = query.trim().lowercase()
    Log.d("GlobalSearch", "performSearchWithProgress: q='$q'")

    SearchCache.get(portal.id, q)?.let { cached ->
        withContext(Dispatchers.Main) { onPartialResult(cached) }
        return@withContext cached
    }

    try {
        val result = when {
            portal.isXtream -> searchXtream(context, q, portal, onProgress, onPartialResult)
            portal.isM3U    -> searchM3u(context, q, portal, onProgress, onPartialResult)
            else            -> searchStalker(context, q, portal, onProgress, onPartialResult)
        }
        SearchCache.put(portal.id, q, result)
        result
    } catch (e: kotlinx.coroutines.CancellationException) {
        val cache = PortalCache.get(portal.id)
        val partial = SearchResults(
            channels = cache.channelPagesByGenre.values.flatMap { it.values.flatten() }.distinctBy { it.id }.filter { it.name.lowercase().contains(q) }.take(30),
            vod      = cache.vodPagesByCategory.values.flatMap { it.values.flatten() }.distinctBy { it.id }.filter { it.name.lowercase().contains(q) }.take(20),
            series   = cache.seriesPagesByCategory.values.flatMap { it.values.flatten() }.distinctBy { it.id }.filter { it.name.lowercase().contains(q) }.take(20),
            complete = false   // user cancelled mid-search; never pin this
        )
        SearchCache.put(portal.id, q, partial)
        partial
    } catch (e: Exception) {
        Log.e("GlobalSearch", "Search failed", e)
        SearchResults()
    }
}

private suspend fun performSearch(
    query:   String,
    portal:  Portal,
    context: android.content.Context
): SearchResults = performSearchWithProgress(query, portal, context, { _, _ -> }, { _ -> })

private suspend fun searchStalker(
    context:         android.content.Context,
    q:               String,
    portal:          Portal,
    onProgress:      suspend (String, Float) -> Unit,
    onPartialResult: suspend (SearchResults) -> Unit
): SearchResults {
    val cache = PortalCache.get(portal.id)
    val sc = StalkerSession.clientOrNull ?: StalkerClient(portal.portalUrl, portal.macAddress).also {
        StalkerSession.client = it
    }
    sc.handshake(force = false)

    val genres = if (cache.genres.isNotEmpty()) cache.genres.toList()
    else {
        withContext(Dispatchers.Main) { onProgress(context.getString(R.string.search_loading_categories), 0f) }
        val loaded = sc.getGenres()
        cache.genres.clear(); cache.genres.addAll(loaded); loaded
    }
// Channels are the only per-category phase now -- VOD/series use one
    // server-side search call each (below), so no category prefetch needed.
    val totalSteps = genres.size
    var stepsComplete = 0
    var coverageComplete = true
    val matchedChannels = mutableListOf<Channel>()
    val matchedVod      = mutableListOf<VodItem>()
    val matchedSeries   = mutableListOf<VodItem>()

    for (genreChunk in genres.chunked(5)) {
        coroutineScope {
            genreChunk.map { genre ->
                async(Dispatchers.IO) {
                    val cached = cache.channelPagesByGenre[genre.id]?.values?.flatten()
                    if (cached != null) return@async cached

                    try {
                        val page = sc.getChannelsPage(genre.id, 1, limit = 2000)
                        // FIX: Populate cache so PlayerActivity can find the channel index
                        cache.getOrPutChannelPage(genre.id)[1] = page.channels
                        if (page.totalItems > 0) cache.channelCountByGenre[genre.id] = page.totalItems
                        page.channels
                    } catch (_: Exception) { emptyList<Channel>() }
                }
            }.forEach { deferred ->
                deferred.await().filterTo(matchedChannels) { it.name.lowercase().contains(q) }
            }
        }
        stepsComplete += genreChunk.size
        val fraction = stepsComplete.toFloat() / totalSteps
        val pct = (fraction * 100).toInt()
        val partialCh = matchedChannels.distinctBy { it.id }.take(30)
        val partialVo = matchedVod.distinctBy { it.id }.take(30)
        withContext(Dispatchers.Main) {
            onProgress(context.getString(R.string.search_progress_channels, genreChunk.last().title, pct), fraction)
            if (partialCh.isNotEmpty() || partialVo.isNotEmpty())
                onPartialResult(SearchResults(channels = partialCh, vod = partialVo))
        }
    }

// VOD + series via SERVER-SIDE search: the portal filters its entire
    // library. The old per-category loop fetched only page 1 (~14 items)
    // per category -- or trusted a PARTIAL browse cache as complete -- so
    // most of the VOD library was invisible to search.
    val vodClient = VodClient(portal.portalUrl, portal.macAddress)

    yield()
    withContext(Dispatchers.Main) {
        onProgress(context.getString(R.string.search_loading_movies), 0.85f)
    }
    try {
        matchedVod.addAll(vodClient.searchVod(q))
    } catch (e: Exception) {
        Log.w("GlobalSearch", "Server-side VOD search failed: ${e.message}")
        coverageComplete = false
    }
    withContext(Dispatchers.Main) {
        val pCh = matchedChannels.distinctBy { it.id }.take(30)
        val pVo = matchedVod.distinctBy { it.id }.take(30)
        if (pVo.isNotEmpty()) onPartialResult(SearchResults(channels = pCh, vod = pVo))
    }

    yield()
    withContext(Dispatchers.Main) {
        onProgress(context.getString(R.string.search_loading_series), 0.95f)
    }
    try {
        matchedSeries.addAll(vodClient.searchSeries(q))
    } catch (e: Exception) {
        Log.w("GlobalSearch", "Server-side series search failed: ${e.message}")
        coverageComplete = false
    }

    return SearchResults(
        channels = matchedChannels.distinctBy { it.id }.take(30),
        vod      = matchedVod.distinctBy { it.id }.take(30),
        series   = matchedSeries.distinctBy { it.id }.take(20),
        complete = coverageComplete
    )
}

private fun buildResults(q: String, channels: List<Channel>, vod: List<VodItem>, series: List<VodItem>) =
    SearchResults(
        channels = channels.distinctBy { it.id }.filter { it.name.lowercase().contains(q) }.take(30),
        vod      = vod.distinctBy { it.id }.filter { it.name.lowercase().contains(q) }.take(30),
        series   = series.distinctBy { it.id }.filter { it.name.lowercase().contains(q) }.take(20)
    )

private suspend fun searchXtream(
    context:         android.content.Context,
    q:               String,
    portal:          Portal,
    onProgress:      suspend (String, Float) -> Unit = { _, _ -> },
    onPartialResult: suspend (SearchResults) -> Unit = { _ -> }
): SearchResults {
    val cache  = PortalCache.get(portal.id)
    val client = XtreamClient(portal.portalUrl, portal.username, portal.password)

    val cachedCh = cache.channelPagesByGenre.values.flatMap { it.values.flatten() }.distinctBy { it.id }.filter { it.name.lowercase().contains(q) }.take(30)
    val cachedVo = cache.vodPagesByCategory.values.flatMap { it.values.flatten() }.distinctBy { it.id }.filter { it.name.lowercase().contains(q) }.take(20)
    val cachedSe = cache.seriesPagesByCategory.values.flatMap { it.values.flatten() }.distinctBy { it.id }.filter { it.name.lowercase().contains(q) }.take(20)
    if (cachedCh.isNotEmpty() || cachedVo.isNotEmpty() || cachedSe.isNotEmpty())
        return SearchResults(cachedCh, cachedVo, cachedSe)

    withContext(Dispatchers.Main) { onProgress(context.getString(R.string.search_loading_streams), 0.2f) }
    val channels = mutableListOf<Channel>()
    try {
        val cats = if (cache.genres.isNotEmpty()) cache.genres
        else client.getLiveCategories().map { StalkerGenre(it.id, it.title, "") }.also { cache.genres.addAll(it) }
        for (cat in cats) {
            if (channels.size >= 30) break
            try { val s = client.getLiveStreams(cat.id); cache.getOrPutChannelPage(cat.id)[1] = s; channels.addAll(s.filter { it.name.lowercase().contains(q) }) } catch (_: Exception) {}
        }
    } catch (_: Exception) {}

    withContext(Dispatchers.Main) { onProgress(context.getString(R.string.search_loading_movies), 0.5f) }
    val vod = mutableListOf<VodItem>()
    try {
        val cats = if (cache.vodCategories.isNotEmpty()) cache.vodCategories else client.getVodCategories().also { cache.vodCategories.addAll(it) }
        for (cat in cats) {
            if (vod.size >= 20) break
            try { val i = client.getVodStreams(cat.id); cache.getOrPutVodPage(cat.id)[1] = i; vod.addAll(i.filter { it.name.lowercase().contains(q) }) } catch (_: Exception) {}
        }
    } catch (_: Exception) {}

    withContext(Dispatchers.Main) { onProgress(context.getString(R.string.search_loading_series), 0.8f) }
    val series = mutableListOf<VodItem>()
    try {
        val cats = if (cache.seriesCategories.isNotEmpty()) cache.seriesCategories else client.getSeriesCategories().also { cache.seriesCategories.addAll(it) }
        for (cat in cats) {
            if (series.size >= 20) break
            try { val i = client.getSeries(cat.id); cache.getOrPutSeriesPage(cat.id)[1] = i; series.addAll(i.filter { it.name.lowercase().contains(q) }) } catch (_: Exception) {}
        }
    } catch (_: Exception) {}

    return SearchResults(channels.take(30), vod.take(20), series.take(20))
}

private suspend fun searchM3u(
    context:         android.content.Context,
    q:               String,
    portal:          Portal,
    onProgress:      suspend (String, Float) -> Unit = { _, _ -> },
    onPartialResult: suspend (SearchResults) -> Unit = { _ -> }
): SearchResults {
    val cache = PortalCache.get(portal.id)
    val channels = cache.channelPagesByGenre.values.flatMap { it.values.flatten() }.distinctBy { it.id }.filter { it.name.lowercase().contains(q) }.take(30)
    val vod      = cache.vodPagesByCategory.values.flatMap { it.values.flatten() }.distinctBy { it.id }.filter { it.name.lowercase().contains(q) }.take(20)
    val series   = cache.seriesPagesByCategory.values.flatMap { it.values.flatten() }.distinctBy { it.id }.filter { it.name.lowercase().contains(q) }.take(20)
    if (channels.isNotEmpty() || vod.isNotEmpty() || series.isNotEmpty())
        return SearchResults(channels, vod, series)

    withContext(Dispatchers.Main) { onProgress(context.getString(R.string.search_loading_progress), 0.3f) }
    val rawFile = M3uCache.rawFile(context, portal.portalUrl)
    if (rawFile.exists()) {
        val matchedCh = mutableListOf<Channel>(); val matchedVo = mutableListOf<VodItem>(); val matchedSe = mutableListOf<VodItem>()
        var currentName = ""; var currentGroup = ""; var currentLogo = ""; var currentId = ""
        rawFile.bufferedReader().use { reader ->
            var line: String?
            while (reader.readLine().also { line = it } != null) {
                val t = line!!.trim()
                when {
                    t.startsWith("#EXTINF:") -> {
                        currentName  = t.substringAfterLast(",").trim()
                        currentGroup = M3U_GROUP_TITLE_REGEX.find(t)?.groupValues?.get(1)?.ifBlank { context.getString(R.string.uncategorized) } ?: context.getString(R.string.uncategorized)
                        currentLogo  = M3U_TVG_LOGO_REGEX.find(t)?.groupValues?.get(1) ?: ""
                        currentId    = M3U_TVG_ID_REGEX.find(t)?.groupValues?.get(1) ?: currentName
                    }
                    t.isNotBlank() && !t.startsWith("#") -> {
                        if (currentName.lowercase().contains(q)) {
                            val cmd = t
                            when (M3uContentType.detect(currentGroup, cmd)) {
                                ContentType.IPTV   -> if (matchedCh.size < 30) {
                                    val ch = Channel(id=currentId, name=currentName, logo=currentLogo, category=currentGroup, cmd=cmd, epgId="", realId="")
                                    matchedCh.add(ch)
                                    // Ensure it's in the cache for PlayerActivity
                                    val pageMap = cache.getOrPutChannelPage(currentGroup)
                                    val list = pageMap[1]?.toMutableList() ?: mutableListOf()
                                    if (list.none { it.id == ch.id }) { list.add(ch); pageMap[1] = list }
                                }
                                ContentType.VOD    -> if (matchedVo.size < 20) {
                                    val v = VodItem(id=currentId, name=currentName, poster=currentLogo, description="", year="", cmd=cmd, isSeries=false, isMovie=true)
                                    matchedVo.add(v)
                                    val pageMap = cache.getOrPutVodPage(currentGroup)
                                    val list = pageMap[1]?.toMutableList() ?: mutableListOf()
                                    if (list.none { it.id == v.id }) { list.add(v); pageMap[1] = list }
                                }
                                ContentType.SERIES -> if (matchedSe.size < 20) {
                                    val s = VodItem(id=currentId, name=currentName, poster=currentLogo, description="", year="", cmd=cmd, isSeries=true, isMovie=false)
                                    matchedSe.add(s)
                                    val pageMap = cache.getOrPutSeriesPage(currentGroup)
                                    val list = pageMap[1]?.toMutableList() ?: mutableListOf()
                                    if (list.none { it.id == s.id }) { list.add(s); pageMap[1] = list }
                                }
                            }
                        }
                        currentName = ""; currentGroup = ""; currentLogo = ""; currentId = ""
                    }
                }
                if (matchedCh.size >= 30 && matchedVo.size >= 20 && matchedSe.size >= 20) break
            }
        }
        return SearchResults(matchedCh, matchedVo, matchedSe)
    }
    return SearchResults()
}

