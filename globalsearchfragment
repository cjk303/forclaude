@OptIn(ExperimentalTvMaterial3Api::class)
@Composable
private fun GlobalSearchScreen(
    initialQuery:      String = "",
    onQueryChanged:    (String) -> Unit = {},
    onChannelSelected: (Channel, Portal) -> Unit,
    onVodSelected:     (VodItem, Portal) -> Unit,
    onBack:            () -> Unit,
    onNavigate:        (androidx.fragment.app.Fragment) -> Unit = {}
) {
    val context = androidx.compose.ui.platform.LocalContext.current
    val scope   = rememberCoroutineScope()

    var query            by remember { mutableStateOf(initialQuery) }
    var results          by remember { mutableStateOf(SearchResults()) }
    var isSearching      by remember { mutableStateOf(false) }
    var portal           by remember { mutableStateOf<Portal?>(null) }
    var searchJob        by remember { mutableStateOf<Job?>(null) }
    var progressText     by remember { mutableStateOf("") }
    var progressFraction by remember { mutableStateOf(0f) }
    var fromCache        by remember { mutableStateOf(false) }

    val searchFocusRequester = remember { FocusRequester() }
    var searchBarFocused by remember { mutableStateOf(false) }
    val configuration = androidx.compose.ui.platform.LocalConfiguration.current
    val isTV = configuration.uiMode and
            android.content.res.Configuration.UI_MODE_TYPE_MASK ==
            android.content.res.Configuration.UI_MODE_TYPE_TELEVISION

    if (!isTV) {
        BackHandler { onBack() }
    }

    LaunchedEffect(Unit) {
        val loaded = withContext(Dispatchers.IO) {
            val repo = PortalRepository(context)
            repo.getActivePortal()
        }
        if (portal != null && portal?.id != loaded?.id) {
            portal?.id?.let { SearchCache.clearPortal(it) }
        }
        portal = loaded
        try { searchFocusRequester.requestFocus() } catch (_: Exception) {}
    }

    LaunchedEffect(query, portal) {
        val p = portal ?: return@LaunchedEffect
        if (query.length < 2) {
            results = SearchResults(); isSearching = false
            progressText = ""; progressFraction = 0f
            return@LaunchedEffect
        }
        searchJob?.cancel()
        isSearching = true; progressText = ""; progressFraction = 0f
        fromCache = false; results = SearchResults()
        delay(400)
        searchJob = scope.launch(Dispatchers.IO) {
            performSearchWithProgress(
                query = query, portal = p, context = context,
                onProgress = { text, fraction -> progressText = text; progressFraction = fraction },
                onPartialResult = { partial -> if (!partial.isEmpty) results = partial }
            ).also { final ->
                withContext(Dispatchers.Main) {
                    results = final; isSearching = false
                    progressText = ""; progressFraction = 0f
                }
            }
        }
    }

    if (isTV) {
        // ── TV: background + sidebar + main content ───────────────────────────
        Box(Modifier.fillMaxSize()) {
            Image(painter = painterResource(R.drawable.tvbackground), contentDescription = null,
                modifier = Modifier.fillMaxSize(), contentScale = ContentScale.Crop)
            Box(modifier = Modifier.fillMaxSize().background(Color.Black.copy(alpha = 0.45f)))

            Row(modifier = Modifier.fillMaxSize()) {
                // Sidebar
                Column(
                    modifier = Modifier.width(72.dp).fillMaxHeight()
                        .background(Color.Black.copy(alpha = 0.4f)).padding(vertical = 16.dp),
                    horizontalAlignment = Alignment.CenterHorizontally,
                    verticalArrangement = Arrangement.SpaceEvenly

                ) {
                    Surface(
                        onClick = { onNavigate(TvHomeComposeFragment()) },
                        shape  = ClickableSurfaceDefaults.shape(RoundedCornerShape(10.dp)),
                        colors = ClickableSurfaceDefaults.colors(containerColor = Color.Transparent, focusedContainerColor = Color.White.copy(alpha = 0.1f)),
                        border = ClickableSurfaceDefaults.border(border = Border(BorderStroke(0.dp, Color.Transparent)), focusedBorder = Border(BorderStroke(1.5.dp, Color.White.copy(alpha = 0.4f)), shape = RoundedCornerShape(10.dp))),
                        scale  = ClickableSurfaceDefaults.scale(focusedScale = 1.08f)
                    ) {
                        Image(painter = painterResource(R.drawable.sqlogo), contentDescription = stringResource(R.string.home_menu_home),
                            modifier = Modifier.size(48.dp).padding(6.dp))
                    }
                    SidebarButton(R.drawable.ic_iptv,     stringResource(R.string.home_menu_iptv))     { onNavigate(CategoryBrowseComposeFragment.newInstance(ContentType.IPTV)) }
                    SidebarButton(R.drawable.ic_movies,   stringResource(R.string.home_menu_movies))   { onNavigate(CategoryBrowseComposeFragment.newInstance(ContentType.VOD)) }
                    SidebarButton(R.drawable.ic_series,   stringResource(R.string.home_menu_series))   { onNavigate(CategoryBrowseComposeFragment.newInstance(ContentType.SERIES)) }
                    SidebarButton(R.drawable.ic_search,   stringResource(R.string.home_menu_search))   { /* already here */ }
                    SidebarButton(R.drawable.ic_settings, stringResource(R.string.home_menu_settings)) { onNavigate(SettingsTvComposeFragment()) }
                }

                // Main content
                Column(
                    modifier = Modifier.weight(1f).fillMaxHeight()
                        .padding(start = 32.dp, end = 32.dp, top = 16.dp, bottom = 24.dp)
                ) {
                    // Title row
                    Row(modifier = Modifier.fillMaxWidth().padding(bottom = 16.dp),
                        horizontalArrangement = Arrangement.SpaceBetween,
                        verticalAlignment = Alignment.CenterVertically
                    ) {
                        Text(stringResource(R.string.search_title), color = Color.White,
                            fontSize = 28.sp, fontWeight = FontWeight.Bold, letterSpacing = 0.5.sp)
                        Box(modifier = Modifier.width(120.dp).height(2.dp).background(
                            Brush.horizontalGradient(listOf(Color.Transparent, Color(0xFF3B82F6).copy(alpha = 0.6f))),
                            RoundedCornerShape(1.dp)))
                    }

                    // Search bar
                    SearchBar(query = query, onQueryChange = { query = it; onQueryChanged(it) },
                        focusRequester = searchFocusRequester, isFocused = searchBarFocused,
                        onFocusChanged = { searchBarFocused = it })

                    Spacer(Modifier.height(20.dp))

                    // Results — TV shows logos
                    SearchResultsArea(
                        query = query, isSearching = isSearching, results = results,
                        progressText = progressText, progressFraction = progressFraction,
                        fromCache = fromCache, portal = portal, searchJob = searchJob,
                        onChannelSelected = onChannelSelected, onVodSelected = onVodSelected,
                        showLogos = true
                    )
                }
            }
        }
    } else {
        // ── Phone: simple column, no sidebar, no logos ────────────────────────
        Box(Modifier.fillMaxSize().background(Color(0xFF0A0A0F))) {
            Column(Modifier.fillMaxSize().systemBarsPadding()
                .padding(horizontal = 16.dp, vertical = 16.dp)
            ) {
                Row(Modifier.fillMaxWidth(), verticalAlignment = Alignment.CenterVertically,
                    horizontalArrangement = Arrangement.spacedBy(12.dp)
                ) {
                    Box(
                        modifier = Modifier.size(36.dp)
                            .clip(RoundedCornerShape(10.dp))
                            .background(Color.Black.copy(alpha = 0.4f))
                            .border(1.dp, Color.White.copy(alpha = 0.12f), RoundedCornerShape(10.dp))
                            .clickable(onClick = onBack),
                        contentAlignment = Alignment.Center
                    ) { Text("←", color = Color.White, fontSize = 16.sp) }
                    Text(stringResource(R.string.search_title), color = Color.White,
                        fontSize = 18.sp, fontWeight = FontWeight.SemiBold)
                }

                Spacer(Modifier.height(16.dp))

                SearchBar(query = query, onQueryChange = { query = it; onQueryChanged(it) },
                    focusRequester = searchFocusRequester, isFocused = searchBarFocused,
                    onFocusChanged = { searchBarFocused = it })

                Spacer(Modifier.height(16.dp))

                // Results — phone has NO logos
                SearchResultsArea(
                    query = query, isSearching = isSearching, results = results,
                    progressText = progressText, progressFraction = progressFraction,
                    fromCache = fromCache, portal = portal, searchJob = searchJob,
                    onChannelSelected = onChannelSelected, onVodSelected = onVodSelected,
                    showLogos = false
                )
            }
        }
    }
}

