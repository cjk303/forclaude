    }
}

@OptIn(ExperimentalTvMaterial3Api::class)
@Composable
private fun ChannelSearchCard(channel: Channel, onClick: () -> Unit) {
    val interactionSource = remember { MutableInteractionSource() }
    val isFocused by interactionSource.collectIsFocusedAsState()
    Surface(
        onClick = onClick, interactionSource = interactionSource,
        modifier = Modifier.width(180.dp),
        shape  = ClickableSurfaceDefaults.shape(RoundedCornerShape(8.dp)),
        colors = ClickableSurfaceDefaults.colors(containerColor = Color.Black.copy(alpha = 0.5f), focusedContainerColor = Color.Black.copy(alpha = 0.7f)),
        border = ClickableSurfaceDefaults.border(
            focusedBorder = Border(BorderStroke(2.dp, Color(0xFF3B82F6)), shape = RoundedCornerShape(8.dp)),
            border        = Border(BorderStroke(1.dp, Color.White.copy(alpha = 0.1f)), shape = RoundedCornerShape(8.dp))
        ),
        scale = ClickableSurfaceDefaults.scale(focusedScale = 1.03f)
    ) {
        Row(Modifier.padding(10.dp), verticalAlignment = Alignment.CenterVertically) {
            AsyncImage(model = channel.logo, contentDescription = channel.name,
                placeholder = painterResource(R.drawable.ic_iptv), error = painterResource(R.drawable.ic_iptv),
                modifier = Modifier.size(36.dp).clip(CircleShape), contentScale = ContentScale.Crop)
            Spacer(Modifier.width(10.dp))
            Text(channel.name, color = if (isFocused) Color.White else Color(0xFFCBD5E1),
