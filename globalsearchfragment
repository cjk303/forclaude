@OptIn(ExperimentalTvMaterial3Api::class)
@Composable
private fun SearchResultsList(
    results:           SearchResults,
    portal:            Portal,
    onChannelSelected: (Channel, Portal) -> Unit,
    onVodSelected:     (VodItem, Portal) -> Unit
) {
    LazyColumn(verticalArrangement = Arrangement.spacedBy(24.dp),
        contentPadding = PaddingValues(bottom = 40.dp)) {
        if (results.channels.isNotEmpty()) {
            item { SearchSection(stringResource(R.string.search_channels_header, results.channels.size), Color(0xFF3B82F6)) }
            item {
                LazyRow(horizontalArrangement = Arrangement.spacedBy(12.dp)) {
                    items(results.channels, key = { "ch_" + it.id }) { ch -> ChannelSearchCard(ch) { onChannelSelected(ch, portal) } }
                }
            }
        }
        if (results.vod.isNotEmpty()) {
            item { SearchSection(stringResource(R.string.search_movies_header, results.vod.size), Color(0xFFF57C00)) }
            item {
                LazyRow(horizontalArrangement = Arrangement.spacedBy(12.dp)) {
                    items(results.vod, key = { "vod_" + it.id }) { v -> VodSearchCard(v) { onVodSelected(v, portal) } }
                }
            }
        }
        if (results.series.isNotEmpty()) {
            item { SearchSection(stringResource(R.string.search_series_header, results.series.size), Color(0xFF4CAF50)) }
            item {
                LazyRow(horizontalArrangement = Arrangement.spacedBy(12.dp)) {
                    items(results.series, key = { "ser_" + it.id }) { s -> VodSearchCard(s) { onVodSelected(s, portal) } }
                }
            }
        }
    }
}

@Composable
