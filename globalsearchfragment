@Composable
private fun SearchResultsArea(
    query: String, isSearching: Boolean, results: SearchResults,
    progressText: String, progressFraction: Float,
    fromCache: Boolean, portal: Portal?, searchJob: Job?,
    onChannelSelected: (Channel, Portal) -> Unit,
    onVodSelected: (VodItem, Portal) -> Unit,
    showLogos: Boolean
) {
    when {
        query.length < 2 -> {
            Box(Modifier.fillMaxSize(), contentAlignment = Alignment.Center) {
                Text(stringResource(R.string.search_min_chars), color = Color(0xFF64748B), fontSize = 16.sp)
            }
        }
        isSearching && results.isEmpty -> {
            Box(Modifier.fillMaxSize(), contentAlignment = Alignment.Center) {
                Column(horizontalAlignment = Alignment.CenterHorizontally,
                    modifier = Modifier.clip(RoundedCornerShape(16.dp))
                        .background(Color.Black.copy(alpha = 0.6f))
                        .padding(horizontal = 40.dp, vertical = 32.dp)
                ) {
                    LinearProgressIndicator(
                        progress = { progressFraction },
                        modifier = Modifier.width(300.dp).height(4.dp).clip(RoundedCornerShape(2.dp)),
                        color = Color(0xFF3B82F6), trackColor = Color.White.copy(alpha = 0.15f)
                    )
                    Spacer(Modifier.height(16.dp))
                    Text(progressText.ifBlank { stringResource(R.string.search_loading_progress) },
                        color = Color.White.copy(alpha = 0.8f), fontSize = 14.sp)
                    Spacer(Modifier.height(20.dp))
                    androidx.compose.material3.TextButton(
                        onClick = { searchJob?.cancel(); }
                    ) { Text(stringResource(R.string.search_stop), color = Color(0xFF3B82F6), fontSize = 14.sp) }
                }
            }
        }
        else -> {
            if (!results.isEmpty && portal != null) {
                val p = portal
                Column {
                    if (fromCache && !isSearching) {
                        Text(stringResource(R.string.search_cached_results, results.total),
                            color = Color(0xFF3B82F6).copy(alpha = 0.7f), fontSize = 12.sp,
                            modifier = Modifier.padding(bottom = 6.dp))
                    }
                    if (isSearching) {
                        Row(Modifier.fillMaxWidth().clip(RoundedCornerShape(8.dp))
                            .background(Color.Black.copy(alpha = 0.5f))
                            .padding(horizontal = 16.dp, vertical = 8.dp),
                            verticalAlignment = Alignment.CenterVertically,
                            horizontalArrangement = Arrangement.spacedBy(12.dp)
                        ) {
                            LinearProgressIndicator(progress = { progressFraction },
                                modifier = Modifier.weight(1f).height(4.dp).clip(RoundedCornerShape(2.dp)),
                                color = Color(0xFF3B82F6), trackColor = Color.White.copy(alpha = 0.15f))
                            Text(progressText, color = Color.White.copy(alpha = 0.6f), fontSize = 12.sp)
                            androidx.compose.material3.TextButton(onClick = { searchJob?.cancel() }) {
                                Text(stringResource(R.string.search_stop), color = Color(0xFF3B82F6), fontSize = 12.sp)
                            }
                        }
                        Spacer(Modifier.height(8.dp))
                    }

                    if (showLogos) {
                        // TV — horizontal rows with cards (logo + name)
                        SearchResultsList(results = results, portal = p,
                            onChannelSelected = onChannelSelected, onVodSelected = onVodSelected)
                    } else {
                        // Phone — vertical list, text only, no logos.
                        // Keys are namespaced per section ("ch_"/"vod_"/"ser_")
                        // because channels, vod and series share this single
                        // LazyColumn -- a channel id can equal a movie id, and
                        // results stream in (onPartialResult rewrites the list
                        // mid-scroll), so position-based or bare-id keys can
                        // collide during a measure pass and throw the
                        // SubcomposeLayout IllegalArgumentException.
                        LazyColumn(verticalArrangement = Arrangement.spacedBy(2.dp),
                            contentPadding = PaddingValues(bottom = 40.dp)
                        ) {
                            if (results.channels.isNotEmpty()) {
                                item { SearchSectionHeader(stringResource(R.string.search_channels_header, results.channels.size), Color(0xFF3B82F6)) }
                                items(results.channels, key = { "ch_" + it.id }) { ch ->
                                    PhoneResultRow(name = ch.name, onClick = { onChannelSelected(ch, p) })
                                }
                            }
                            if (results.vod.isNotEmpty()) {
                                item { SearchSectionHeader(stringResource(R.string.search_movies_header, results.vod.size), Color(0xFFF57C00)) }
                                items(results.vod, key = { "vod_" + it.id }) { v ->
                                    PhoneResultRow(name = v.name, subtitle = v.year.takeIf { !it.isNullOrBlank() }, onClick = { onVodSelected(v, p) })
                                }
                            }
                            if (results.series.isNotEmpty()) {
                                item { SearchSectionHeader(stringResource(R.string.search_series_header, results.series.size), Color(0xFF4CAF50)) }
                                items(results.series, key = { "ser_" + it.id }) { s ->
                                    PhoneResultRow(name = s.name, onClick = { onVodSelected(s, p) })
                                }
                            }
                        }
                    }
                }
            } else if (!isSearching) {
                Box(Modifier.fillMaxSize(), contentAlignment = Alignment.Center) {
                    Text(stringResource(R.string.search_no_results, query),
                        color = Color(0xFF64748B), fontSize = 16.sp)
                }
            }
        }
    }
}

